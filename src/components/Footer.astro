---
// =====================================================
// STOPKA STRONY
// =====================================================
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-main">
    <div class="footer-grid">
      <!-- Kolumna 1: Logo + opis -->
      <div class="footer-col footer-col-brand">
        <div class="footer-logo">
          <img src="/images/logo-icon.svg" alt="MATHOUSE" class="footer-logo-img" width="32" height="32" />
          <span class="logo-text">MATHOUSE</span>
        </div>
        <p class="footer-tagline">Coś więcej niż matma.</p>
        <p class="footer-desc">
          Uczę matematyki od 2012 roku. Kursy wideo, korepetycje, kompendia maturalne.
        </p>
        <div class="footer-social">
          <a
            href="https://www.tiktok.com/@mathouse_pl"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok"
          >
            <i class="ti ti-brand-tiktok"></i>
          </a>
          <a
            href="https://www.instagram.com/mathouse_pl/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <i class="ti ti-brand-instagram"></i>
          </a>
          <a
            href="https://www.youtube.com/@olafpieprzak9987"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
          >
            <i class="ti ti-brand-youtube"></i>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=100072045862164"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
          >
            <i class="ti ti-brand-facebook"></i>
          </a>
        </div>
      </div>

      <!-- Kolumna 2: Oferta -->
      <div class="footer-col">
        <h4 class="footer-h">Oferta</h4>
        <a href="/kursy">Kursy wideo</a>
        <a href="/korepetycje">Korepetycje</a>
        <a href="/arkusze">Arkusze CKE (gratis)</a>
        <a href="/sklep">Sklep PDF</a>
        <a href="/kalkulatory">Kalkulatory</a>
      </div>

      <!-- Kolumna 3: Informacje -->
      <div class="footer-col">
        <h4 class="footer-h">Informacje</h4>
        <a href="/o-mnie">O mnie</a>
        <a href="/kontakt">Kontakt</a>
        <a href="/polityka-prywatnosci">Polityka prywatności</a>
        <a href="/regulamin">Regulamin</a>
      </div>

      <!-- Kolumna 4: Kontakt -->
      <div class="footer-col">
        <h4 class="footer-h">Kontakt</h4>
        <a href="mailto:olaf.pieprzak@gmail.com" class="footer-contact">
          <i class="ti ti-mail"></i> olaf.pieprzak@gmail.com
        </a>
        <a href="tel:+48570840416" class="footer-contact">
          <i class="ti ti-phone"></i> 570 840 416
        </a>
        <p class="footer-address">
          <i class="ti ti-map-pin"></i>
          ul. Piłsudskiego 26A/16<br />
          39-100 Ropczyce
        </p>
        <p class="footer-collab">
          Współpraca: <a href="mailto:olaf.pieprzak@gmail.com">olaf.pieprzak@gmail.com</a>
        </p>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© {year} MATHOUSE · Olaf Pieprzak</span>
    <span class="footer-tech">
      Strona zbudowana z miłością do matematyki
    </span>
  </div>
</footer>

<style>
  .footer {
    background: #020516;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
    margin-top: 60px;
  }

  .footer-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 36px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    color: rgba(235, 238, 255, 0.6);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: #FFDE59;
  }

  .footer-h {
    font-size: 11px;
    color: #3FCECF;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
  }

  /* === Kolumna z logo === */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .footer-logo .logo-mark {
    width: 32px;
    height: 32px;
    background: #FFDE59;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #050A24;
    font-weight: 700;
    font-size: 15px;
  }
  .footer-logo-img {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    display: block;
    object-fit: contain;
  }
  .footer-logo .logo-text {
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.5px;
    color: #EBEEFF;
  }
  .footer-tagline {
    font-family: 'Instrument Serif', serif;
    font-size: 18px;
    color: #FFDE59;
    font-style: italic;
    margin-bottom: 4px;
  }
  .footer-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.55);
    line-height: 1.6;
    max-width: 280px;
  }

  /* === Social media === */
  .footer-social {
    display: flex;
    gap: 8px;
    margin-top: 14px;
  }
  .footer-social a {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
  }
  .footer-social a:hover {
    background: rgba(255, 222, 89, 0.1);
    border-color: rgba(255, 222, 89, 0.3);
  }
  .footer-social i {
    font-size: 16px;
    color: #EBEEFF;
  }

  /* === Kontakt === */
  .footer-contact {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
  }
  .footer-address {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 12px;
    color: rgba(235, 238, 255, 0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .footer-collab {
    margin-top: 8px;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
  }
  .footer-collab a {
    color: #3FCECF;
    font-size: 11px;
  }

  /* === Stopka dolna === */
  .footer-bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding: 20px 32px;
    border-top: 1px solid rgba(235, 238, 255, 0.06);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.35);
  }
  .footer-tech {
    font-style: italic;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer-col-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 600px) {
    .footer-main {
      padding: 36px 18px 24px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 6px;
      text-align: center;
      padding: 18px;
    }
  }
</style>
