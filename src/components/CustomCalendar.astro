---
// =====================================================
// CUSTOM CALENDAR — własny widget rezerwacji MATHOUSE
// =====================================================
// Zastępuje TidyCal embed (placeholder TidyCal demo + brak kontroli)
// Pobiera sloty z Cloudflare Worker /api/upcoming-slots
// 
// Layout:
//   Desktop: kalendarz miesięczny po LEWEJ + godziny po PRAWEJ
//   Mobile:  kalendarz na górze + godziny pod spodem (responsive)
//
// Logika:
//   - Domyślnie: agregowane sloty z wszystkich booking types (jeśli wolne w którymkolwiek → pokazuję dzień jako wolny)
//   - Po wyborze w BookingSelector: filtruje sloty tylko dla wybranego booking type
//   - Klient klika dzień → pokazuje godziny → klika godzinę → leci do TidyCal z prefilled date+time
//
// Strefa: Europa/Warszawa
// =====================================================
import { TIDYCAL_CONFIG } from '../config/tidycal.js';
---

<section id="kalendarz" class="custom-calendar-section">
  <div class="container-content">
    <div class="section-label">REZERWUJ TERMIN · KALENDARZ MATHOUSE</div>
    <h2 class="cc-title">Wybierz dzień i godzinę, która Ci pasuje.</h2>
    <p class="cc-subtitle" data-cc-subtitle>
      Pokazuję moją dostępność na najbliższe tygodnie. Kliknij wolny dzień, wybierz godzinę, gotowe.
    </p>

    <!-- KONTAINER WIDGETU -->
    <div class="cc-widget" data-cc-widget>

      <!-- LOADER (pokazywany dopóki nie pobierze danych) -->
      <div class="cc-loader" data-cc-loader>
        <div class="cc-spinner"></div>
        <p>Ładuję wolne terminy z kalendarza…</p>
      </div>

      <!-- WIDOK PO ZAŁADOWANIU -->
      <div class="cc-content" data-cc-content hidden>

        <!-- LEWA: kalendarz miesięczny -->
        <div class="cc-calendar">
          <!-- Header: ‹ Maj 2026 › -->
          <div class="cc-cal-header">
            <button class="cc-cal-nav" data-cc-prev type="button" aria-label="Poprzedni miesiąc">‹</button>
            <div class="cc-cal-title" data-cc-month-title>Maj 2026</div>
            <button class="cc-cal-nav" data-cc-next type="button" aria-label="Następny miesiąc">›</button>
          </div>

          <!-- Dni tygodnia -->
          <div class="cc-cal-weekdays">
            <div>PN</div>
            <div>WT</div>
            <div>ŚR</div>
            <div>CZW</div>
            <div>PT</div>
            <div>SB</div>
            <div>ND</div>
          </div>

          <!-- Siatka dni (generowana JS) -->
          <div class="cc-cal-grid" data-cc-grid>
            <!-- Wypełniane przez JavaScript -->
          </div>

          <!-- Legenda -->
          <div class="cc-cal-legend">
            <span><span class="cc-dot cc-dot-today"></span> dziś</span>
            <span><span class="cc-dot cc-dot-free"></span> wolny termin</span>
            <span><span class="cc-dot cc-dot-booked"></span> zajęte</span>
          </div>
        </div>

        <!-- PRAWA: godziny dla wybranego dnia -->
        <div class="cc-times">
          <div class="cc-times-header" data-cc-times-header>
            <span class="cc-times-label" data-cc-day-label>Wybierz dzień z kalendarza</span>
          </div>

          <div class="cc-times-list" data-cc-times-list>
            <!-- Wypełniane przez JavaScript po wyborze dnia -->
            <div class="cc-times-empty">
              👈 Kliknij wolny dzień w kalendarzu, żeby zobaczyć godziny
            </div>
          </div>

          <!-- Przycisk rezerwacji (widoczny po wyborze slotu) -->
          <div class="cc-cta-wrap" data-cc-cta-wrap hidden>
            <div class="cc-selected-info">
              <div class="cc-selected-label">WYBRANY TERMIN:</div>
              <div class="cc-selected-value" data-cc-selected-text>—</div>
              <div class="cc-selected-meta" data-cc-selected-meta>—</div>
            </div>
            <a
              href="#"
              class="btn-primary cc-cta-btn"
              data-cc-cta-btn
              target="_blank"
              rel="noopener noreferrer"
            >
              Rezerwuj termin →
            </a>
          </div>

          <div class="cc-times-info">
            <i class="ti ti-clock"></i>
            <span>Strefa czasowa: <strong>Europa/Warszawa</strong></span>
          </div>
        </div>

      </div>

      <!-- BŁĄD — gdy API nie odpowiada -->
      <div class="cc-error" data-cc-error hidden>
        <i class="ti ti-alert-circle"></i>
        <div>
          <strong>Kalendarz chwilowo niedostępny</strong>
          <p>Spróbuj <a href="#" data-cc-retry>odświeżyć</a> albo użyj zewnętrznego kalendarza TidyCal:</p>
          <a href={TIDYCAL_CONFIG.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Otwórz kalendarz TidyCal →
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom info -->
    <div class="cc-bottom-info">
      <div class="cc-info-item">
        <i class="ti ti-shield-check"></i>
        Bezpieczna rezerwacja
      </div>
      <div class="cc-info-item">
        <i class="ti ti-mail"></i>
        Potwierdzenie + przypomnienie mailem
      </div>
      <div class="cc-info-item">
        <i class="ti ti-calendar"></i>
        Wydarzenie automatycznie w kalendarzu
      </div>
    </div>
  </div>
</section>

<script>
  // ============================================================
  // CUSTOM CALENDAR — logika
  // ============================================================
  import { TIDYCAL_CONFIG } from '../config/tidycal.js';

  // === KONFIG ===
  const TIMEZONE = 'Europe/Warsaw';
  const POLSKIE_MIESIACE = [
    'Styczeń', 'Luty', 'Marzec', 'Kwiecień', 'Maj', 'Czerwiec',
    'Lipiec', 'Sierpień', 'Wrzesień', 'Październik', 'Listopad', 'Grudzień',
  ];
  const POLSKIE_DNI = ['Niedziela', 'Poniedziałek', 'Wtorek', 'Środa', 'Czwartek', 'Piątek', 'Sobota'];

  // === STATE ===
  let currentMonth = new Date(); // pierwszy dzień widocznego miesiąca
  currentMonth.setDate(1);
  let selectedDay = null; // string YYYY-MM-DD
  let selectedSlot = null; // obiekt { starts_at, booking_type_slug }
  let slotsByDay = {}; // { 'YYYY-MM-DD': [slot1, slot2, ...] }
  let slotsByDayPerType = {}; // { bookingTypeSlug: { 'YYYY-MM-DD': [...] } }
  let bookingTypes = []; // lista booking types z API
  let currentBookingSlug = null; // slug aktualnie wybrany w BookingSelector (null = wszystkie)

  // === REFS ===
  const loader = document.querySelector('[data-cc-loader]');
  const content = document.querySelector('[data-cc-content]');
  const errorBox = document.querySelector('[data-cc-error]');
  const gridEl = document.querySelector('[data-cc-grid]');
  const monthTitleEl = document.querySelector('[data-cc-month-title]');
  const prevBtn = document.querySelector('[data-cc-prev]');
  const nextBtn = document.querySelector('[data-cc-next]');
  const dayLabelEl = document.querySelector('[data-cc-day-label]');
  const timesListEl = document.querySelector('[data-cc-times-list]');
  const ctaWrap = document.querySelector('[data-cc-cta-wrap]');
  const ctaBtn = document.querySelector('[data-cc-cta-btn]');
  const selectedTextEl = document.querySelector('[data-cc-selected-text]');
  const selectedMetaEl = document.querySelector('[data-cc-selected-meta]');
  const retryEl = document.querySelector('[data-cc-retry]');
  const subtitleEl = document.querySelector('[data-cc-subtitle]');

  // ============================================================
  // KROK 1: Pobranie slotów z Workera
  // ============================================================
  async function fetchSlots() {
    showLoader();
    try {
      const response = await fetch(`${TIDYCAL_CONFIG.apiUrl}/api/upcoming-slots`, {
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();

      bookingTypes = data.booking_types || [];

      // Przetwarzamy sloty per booking type
      slotsByDayPerType = {};
      for (const [btId, btData] of Object.entries(data.by_booking_type || {})) {
        const slug = bookingTypes.find(bt => String(bt.id) === btId)?.url_slug;
        if (!slug) continue;
        slotsByDayPerType[slug] = {};
        for (const slot of btData.slots || []) {
          const day = slot.starts_at.split('T')[0];
          if (!slotsByDayPerType[slug][day]) slotsByDayPerType[slug][day] = [];
          slotsByDayPerType[slug][day].push({
            ...slot,
            booking_type_slug: slug,
            booking_type_title: btData.title,
            duration_minutes: btData.duration_minutes,
          });
        }
      }

      // Agregujemy wszystkie sloty (dla domyślnego widoku)
      computeAggregatedSlots();

      hideLoader();
      content?.removeAttribute('hidden');
      renderCalendar();
    } catch (err) {
      console.error('[CustomCalendar] Błąd pobierania slotów:', err);
      hideLoader();
      errorBox?.removeAttribute('hidden');
    }
  }

  /**
   * Agreguje sloty z wszystkich booking types (lub konkretnego) do slotsByDay
   */
  function computeAggregatedSlots() {
    slotsByDay = {};
    const source = currentBookingSlug && slotsByDayPerType[currentBookingSlug]
      ? { [currentBookingSlug]: slotsByDayPerType[currentBookingSlug] }
      : slotsByDayPerType;

    for (const [slug, daysMap] of Object.entries(source)) {
      for (const [day, slots] of Object.entries(daysMap)) {
        if (!slotsByDay[day]) slotsByDay[day] = [];
        slotsByDay[day].push(...slots);
      }
    }

    // Sortuj sloty w każdym dniu po czasie + usuń duplikaty
    for (const day in slotsByDay) {
      const seen = new Set();
      slotsByDay[day] = slotsByDay[day].filter(s => {
        const key = `${s.starts_at}_${s.booking_type_slug}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      }).sort((a, b) => new Date(a.starts_at) - new Date(b.starts_at));
    }
  }

  // ============================================================
  // KROK 2: Renderowanie kalendarza
  // ============================================================
  function renderCalendar() {
    if (!gridEl || !monthTitleEl) return;

    const year = currentMonth.getFullYear();
    const month = currentMonth.getMonth();

    monthTitleEl.textContent = `${POLSKIE_MIESIACE[month]} ${year}`;

    // Pierwszy dzień miesiąca i jego dzień tygodnia (PN=1, ND=7)
    const firstDay = new Date(year, month, 1);
    let firstDayOfWeek = firstDay.getDay(); // 0=ND, 1=PN, ..., 6=SB
    firstDayOfWeek = firstDayOfWeek === 0 ? 6 : firstDayOfWeek - 1; // konwert do PN=0

    // Ostatni dzień miesiąca
    const lastDay = new Date(year, month + 1, 0);
    const daysInMonth = lastDay.getDate();

    // Ostatni dzień poprzedniego miesiąca
    const prevLastDay = new Date(year, month, 0);
    const daysInPrevMonth = prevLastDay.getDate();

    // Buduj siatkę 6 tygodni x 7 dni = 42 komórki
    let html = '';
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const todayStr = formatDate(today);

    // Dni poprzedniego miesiąca (wyszarzone)
    for (let i = firstDayOfWeek - 1; i >= 0; i--) {
      const dayNum = daysInPrevMonth - i;
      html += `<div class="cc-day cc-day-other">${dayNum}</div>`;
    }

    // Dni bieżącego miesiąca
    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(year, month, day);
      const dateStr = formatDate(date);
      const isToday = dateStr === todayStr;
      const isPast = date < today && !isToday;
      const hasSlots = slotsByDay[dateStr] && slotsByDay[dateStr].length > 0;
      const isSelected = dateStr === selectedDay;

      let classes = ['cc-day'];
      if (isToday) classes.push('cc-day-today');
      if (isPast) classes.push('cc-day-past');
      if (hasSlots && !isPast) classes.push('cc-day-free');
      else if (!isPast) classes.push('cc-day-booked');
      if (isSelected) classes.push('cc-day-selected');

      const clickable = hasSlots && !isPast;
      const attrs = clickable ? `data-cc-day="${dateStr}" role="button" tabindex="0"` : '';

      html += `<div class="${classes.join(' ')}" ${attrs}>
        <span class="cc-day-num">${day}</span>
        ${hasSlots && !isPast ? `<span class="cc-day-marker"></span>` : ''}
      </div>`;
    }

    // Dni następnego miesiąca (wypełnij do 42 komórek)
    const filledCells = firstDayOfWeek + daysInMonth;
    const remaining = 42 - filledCells;
    for (let day = 1; day <= remaining; day++) {
      html += `<div class="cc-day cc-day-other">${day}</div>`;
    }

    gridEl.innerHTML = html;

    // Bind clicki na dni
    gridEl.querySelectorAll('[data-cc-day]').forEach(el => {
      el.addEventListener('click', () => {
        const day = el.getAttribute('data-cc-day');
        if (day) selectDay(day);
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const day = el.getAttribute('data-cc-day');
          if (day) selectDay(day);
        }
      });
    });

    // Update nav buttons — disable prev jeśli jesteśmy w bieżącym miesiącu
    if (prevBtn) {
      const todayMonth = new Date();
      todayMonth.setDate(1);
      todayMonth.setHours(0,0,0,0);
      if (currentMonth.getTime() <= todayMonth.getTime()) {
        prevBtn.setAttribute('disabled', '');
      } else {
        prevBtn.removeAttribute('disabled');
      }
    }
  }

  // ============================================================
  // KROK 3: Wybór dnia
  // ============================================================
  function selectDay(dayStr) {
    selectedDay = dayStr;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  }

  function renderTimes() {
    if (!timesListEl || !dayLabelEl) return;

    if (!selectedDay) {
      dayLabelEl.textContent = 'Wybierz dzień z kalendarza';
      timesListEl.innerHTML = '<div class="cc-times-empty">👈 Kliknij wolny dzień w kalendarzu, żeby zobaczyć godziny</div>';
      return;
    }

    const date = parseDate(selectedDay);
    const dayName = POLSKIE_DNI[date.getDay()];
    const dayNum = date.getDate();
    const monthName = POLSKIE_MIESIACE[date.getMonth()].toLowerCase();
    dayLabelEl.textContent = `${dayName} · ${dayNum} ${monthName}`;

    const slots = slotsByDay[selectedDay] || [];
    if (slots.length === 0) {
      timesListEl.innerHTML = '<div class="cc-times-empty">Brak wolnych terminów w tym dniu</div>';
      return;
    }

    // Grupuj sloty per godzina (godzina + warianty)
    // Najpierw zbierz unikalne godziny
    const byTime = {};
    for (const slot of slots) {
      const time = formatTime(slot.starts_at);
      if (!byTime[time]) byTime[time] = [];
      byTime[time].push(slot);
    }

    let html = '';
    for (const [time, timeSlots] of Object.entries(byTime).sort()) {
      // Jeśli wybrany konkretny wariant — pokazujemy tylko pasujące
      const firstSlot = timeSlots[0];
      const slotKey = `${selectedDay}_${time}`;
      const isSelected = selectedSlot && selectedSlot._key === slotKey;
      html += `
        <button
          class="cc-time-btn ${isSelected ? 'cc-time-selected' : ''}"
          data-cc-time="${time}"
          data-cc-slot-key="${slotKey}"
          type="button"
        >
          <span class="cc-time-hour">${time}</span>
          ${timeSlots.length > 1 ? `<span class="cc-time-variants">${timeSlots.length} warianty</span>` : ''}
        </button>
      `;
    }

    timesListEl.innerHTML = html;

    // Bind clicki
    timesListEl.querySelectorAll('[data-cc-time]').forEach(el => {
      el.addEventListener('click', () => {
        const time = el.getAttribute('data-cc-time');
        const key = el.getAttribute('data-cc-slot-key');
        if (time && key) selectTime(time, key);
      });
    });
  }

  // ============================================================
  // KROK 4: Wybór godziny
  // ============================================================
  function selectTime(time, slotKey) {
    if (!selectedDay) return;

    const slots = slotsByDay[selectedDay] || [];
    const matchingSlots = slots.filter(s => formatTime(s.starts_at) === time);
    if (matchingSlots.length === 0) return;

    // Jeśli mamy filtr na wariant — bierzemy pierwszy pasujący do filtru
    // W przeciwnym razie pierwszy z listy (możemy poprosić użytkownika o wybór wariantu w przyszłości)
    let slot = matchingSlots[0];
    if (currentBookingSlug) {
      const filtered = matchingSlots.find(s => s.booking_type_slug === currentBookingSlug);
      if (filtered) slot = filtered;
    }

    selectedSlot = { ...slot, _key: slotKey };
    renderTimes();
    showCTA();
  }

  /**
   * Pokazuje przycisk "Rezerwuj termin" + buduje URL do TidyCal
   */
  function showCTA() {
    if (!selectedSlot || !ctaWrap || !ctaBtn) return;

    const date = parseDate(selectedDay);
    const dayName = POLSKIE_DNI[date.getDay()];
    const dayNum = date.getDate();
    const monthName = POLSKIE_MIESIACE[date.getMonth()].toLowerCase();
    const time = formatTime(selectedSlot.starts_at);

    selectedTextEl.textContent = `${dayName}, ${dayNum} ${monthName} · ${time}`;
    selectedMetaEl.textContent = `${selectedSlot.booking_type_title} (${selectedSlot.duration_minutes} min)`;

    // URL TidyCal z parametrami daty/godziny (TidyCal wykrywa i pre-fill)
    const startsAt = new Date(selectedSlot.starts_at);
    const dateParam = formatDate(startsAt);
    const timeParam = formatTime(selectedSlot.starts_at);
    const slug = selectedSlot.booking_type_slug;
    ctaBtn.href = `${TIDYCAL_CONFIG.bookingUrl}/${slug}?date=${dateParam}&time=${timeParam}`;

    ctaWrap.removeAttribute('hidden');
  }

  // ============================================================
  // Pomocnicze: formatowanie dat w strefie Europe/Warsaw
  // ============================================================
  function formatDate(date) {
    // Zwraca YYYY-MM-DD w strefie Europe/Warsaw
    const opts = { timeZone: TIMEZONE, year: 'numeric', month: '2-digit', day: '2-digit' };
    const parts = new Intl.DateTimeFormat('sv-SE', opts).format(date); // sv-SE używa formatu YYYY-MM-DD
    return parts;
  }

  function formatTime(isoString) {
    // Zwraca HH:MM w strefie Europe/Warsaw
    const date = new Date(isoString);
    return new Intl.DateTimeFormat('pl-PL', {
      timeZone: TIMEZONE,
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).format(date);
  }

  function parseDate(dayStr) {
    // YYYY-MM-DD → Date w lokalnym czasie
    const [y, m, d] = dayStr.split('-').map(Number);
    return new Date(y, m - 1, d);
  }

  // ============================================================
  // Loader controls
  // ============================================================
  function showLoader() {
    loader?.removeAttribute('hidden');
    if (loader) loader.style.display = 'flex';
    content?.setAttribute('hidden', '');
    errorBox?.setAttribute('hidden', '');
  }

  function hideLoader() {
    loader?.setAttribute('hidden', '');
    if (loader) loader.style.display = 'none';
  }

  // ============================================================
  // Nawigacja miesiącami
  // ============================================================
  prevBtn?.addEventListener('click', () => {
    currentMonth.setMonth(currentMonth.getMonth() - 1);
    selectedDay = null;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  });

  nextBtn?.addEventListener('click', () => {
    currentMonth.setMonth(currentMonth.getMonth() + 1);
    selectedDay = null;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  });

  // ============================================================
  // Retry
  // ============================================================
  retryEl?.addEventListener('click', (e) => {
    e.preventDefault();
    errorBox?.setAttribute('hidden', '');
    fetchSlots();
  });

  // ============================================================
  // Nasłuch wydarzenia z BookingSelector
  // ============================================================
  // BookingSelector emituje 'tidycal-select' gdy zmieni się wybór
  // Wtedy filtrujemy sloty pokazywane w kalendarzu
  window.addEventListener('tidycal-select', (e) => {
    const slug = e.detail?.slug;
    if (slug) {
      currentBookingSlug = slug;
      computeAggregatedSlots();
      selectedDay = null;
      selectedSlot = null;
      ctaWrap?.setAttribute('hidden', '');
      renderCalendar();
      renderTimes();

      // Update subtitle
      if (subtitleEl) {
        const bt = bookingTypes.find(b => b.url_slug === slug);
        if (bt) {
          subtitleEl.innerHTML = `Pokazuję dostępność dla: <strong>${bt.title}</strong> (${bt.duration_minutes} min). Kliknij wolny dzień, wybierz godzinę.`;
        }
      }
    }
  });

  // ============================================================
  // START
  // ============================================================
  fetchSlots();
</script>

<style>
  .custom-calendar-section {
    padding: 40px 0;
  }
  .cc-title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.5px;
    line-height: 1.15;
    margin-top: 6px;
    margin-bottom: 8px;
  }
  .cc-subtitle {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.6;
    margin-bottom: 22px;
    max-width: 640px;
  }
  .cc-subtitle strong {
    color: #FFDE59;
  }

  /* === WIDGET CONTAINER === */
  .cc-widget {
    position: relative;
    min-height: 520px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  /* === LOADER === */
  .cc-loader {
    min-height: 520px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: rgba(235, 238, 255, 0.5);
    padding: 40px 20px;
  }
  .cc-loader[hidden] {
    display: none !important;
  }
  .cc-loader p {
    font-size: 13px;
    margin-top: 14px;
  }
  .cc-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 222, 89, 0.2);
    border-top-color: #FFDE59;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* === BŁĄD === */
  .cc-error {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 32px;
  }
  .cc-error[hidden] {
    display: none !important;
  }
  .cc-error i {
    color: #FFDE59;
    font-size: 28px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .cc-error strong {
    font-size: 16px;
    display: block;
    margin-bottom: 4px;
