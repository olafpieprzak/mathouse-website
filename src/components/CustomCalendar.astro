---
// =====================================================
// CUSTOM CALENDAR V9 — filtrowanie godzin + naprawione style
// =====================================================
// - Tylko sloty z dozwolonych godzin (12:00, 12:45, 13:30, ..., 18:45)
// - Dni innych miesięcy: puste pola (nie pokazujemy)
// - Wolne dni: granat kafelek + żółty tekst (mocne !important)
// - Booking type: prawidłowe filtrowanie z BookingSelector
// =====================================================
import { TIDYCAL_CONFIG } from '../config/tidycal.js';
---

<section id="kalendarz" class="custom-calendar-section">
  <div class="container-content">
    <div class="section-label">REZERWUJ TERMIN · KALENDARZ MATHOUSE</div>
    <h2 class="cc-title">Wybierz dzień i godzinę, która Ci pasuje.</h2>
    <p class="cc-subtitle" data-cc-subtitle>
      Pokazuję moją dostępność na najbliższe tygodnie. Kliknij wolny dzień, wybierz godzinę, gotowe.
    </p>

    <div class="cc-widget" data-cc-widget>

      <div class="cc-loader" data-cc-loader>
        <div class="cc-spinner"></div>
        <p>Ładuję wolne terminy z kalendarza…</p>
      </div>

      <div class="cc-content" data-cc-content hidden>

        <div class="cc-calendar">
          <div class="cc-cal-header">
            <button class="cc-cal-nav" data-cc-prev type="button" aria-label="Poprzedni miesiąc">‹</button>
            <div class="cc-cal-title" data-cc-month-title>Maj 2026</div>
            <button class="cc-cal-nav" data-cc-next type="button" aria-label="Następny miesiąc">›</button>
          </div>

          <div class="cc-cal-weekdays">
            <div>Pn</div><div>Wt</div><div>Śr</div><div>Cz</div><div>Pt</div><div>Sb</div><div>Nd</div>
          </div>

          <div class="cc-cal-grid" data-cc-grid></div>

          <div class="cc-cal-legend">
            <span><span class="cc-dot cc-dot-today"></span> dziś</span>
            <span><span class="cc-dot cc-dot-free"></span> wolny termin</span>
          </div>
        </div>

        <div class="cc-times">
          <div class="cc-times-header">
            <span class="cc-times-label" data-cc-day-label>Wybierz dzień z kalendarza</span>
          </div>

          <div class="cc-times-list" data-cc-times-list>
            <div class="cc-times-empty">👈 Kliknij wolny dzień w kalendarzu, żeby zobaczyć dostępne godziny</div>
          </div>

          <div class="cc-cta-wrap" data-cc-cta-wrap hidden>
            <div class="cc-selected-info">
              <div class="cc-selected-label">WYBRANY TERMIN:</div>
              <div class="cc-selected-value" data-cc-selected-text>—</div>
              <div class="cc-selected-meta" data-cc-selected-meta>—</div>
            </div>
            <a href="#" class="btn-primary cc-cta-btn" data-cc-cta-btn target="_blank" rel="noopener noreferrer">
              Rezerwuj termin →
            </a>
          </div>

          <div class="cc-times-info">
            <i class="ti ti-clock"></i>
            <span>Strefa czasowa: <strong>Europa/Warszawa</strong></span>
          </div>
        </div>

      </div>

      <div class="cc-error" data-cc-error hidden>
        <i class="ti ti-alert-circle"></i>
        <div>
          <strong>Kalendarz chwilowo niedostępny</strong>
          <p>Spróbuj <a href="#" data-cc-retry>odświeżyć</a> albo użyj zewnętrznego kalendarza TidyCal:</p>
          <a href={TIDYCAL_CONFIG.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Otwórz kalendarz TidyCal →
          </a>
        </div>
      </div>
    </div>

    <div class="cc-bottom-info">
      <div class="cc-info-item"><i class="ti ti-shield-check"></i>Bezpieczna rezerwacja</div>
      <div class="cc-info-item"><i class="ti ti-mail"></i>Potwierdzenie + przypomnienie mailem</div>
      <div class="cc-info-item"><i class="ti ti-calendar"></i>Wydarzenie automatycznie w kalendarzu</div>
    </div>
  </div>
</section>

<script>
  import { TIDYCAL_CONFIG } from '../config/tidycal.js';

  // ============================================================
  // KLUCZOWA NAPRAWA: dozwolone godziny startu lekcji (co 45 min)
  // ============================================================
  const DOZWOLONE_GODZINY = [
    '12:00', '12:45', '13:30', '14:15', '15:00',
    '15:45', '16:30', '17:15', '18:00', '18:45'
  ];

  const TIMEZONE = 'Europe/Warsaw';
  const POLSKIE_MIESIACE = ['Styczeń','Luty','Marzec','Kwiecień','Maj','Czerwiec','Lipiec','Sierpień','Wrzesień','Październik','Listopad','Grudzień'];
  const POLSKIE_MIESIACE_GEN = ['stycznia','lutego','marca','kwietnia','maja','czerwca','lipca','sierpnia','września','października','listopada','grudnia'];
  const POLSKIE_DNI = ['Niedziela','Poniedziałek','Wtorek','Środa','Czwartek','Piątek','Sobota'];

  let currentMonth = new Date();
  currentMonth.setDate(1);
  let selectedDay = null;
  let selectedSlot = null;
  let slotsByDay = {};
  let slotsByDayPerType = {};
  let bookingTypes = [];
  let currentBookingSlug = null;

  const loader = document.querySelector('[data-cc-loader]');
  const content = document.querySelector('[data-cc-content]');
  const errorBox = document.querySelector('[data-cc-error]');
  const gridEl = document.querySelector('[data-cc-grid]');
  const monthTitleEl = document.querySelector('[data-cc-month-title]');
  const prevBtn = document.querySelector('[data-cc-prev]');
  const nextBtn = document.querySelector('[data-cc-next]');
  const dayLabelEl = document.querySelector('[data-cc-day-label]');
  const timesListEl = document.querySelector('[data-cc-times-list]');
  const ctaWrap = document.querySelector('[data-cc-cta-wrap]');
  const ctaBtn = document.querySelector('[data-cc-cta-btn]');
  const selectedTextEl = document.querySelector('[data-cc-selected-text]');
  const selectedMetaEl = document.querySelector('[data-cc-selected-meta]');
  const retryEl = document.querySelector('[data-cc-retry]');
  const subtitleEl = document.querySelector('[data-cc-subtitle]');

  async function fetchSlots() {
    showLoader();
    try {
      // Cache buster: ?v=9 + timestamp żeby ominąć cache
      const cacheBust = `?v=9&t=${Date.now()}`;
      const response = await fetch(`${TIDYCAL_CONFIG.apiUrl}/api/upcoming-slots${cacheBust}`, {
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();

      bookingTypes = data.booking_types || [];
      slotsByDayPerType = {};
      for (const [btId, btData] of Object.entries(data.by_booking_type || {})) {
        const slug = bookingTypes.find(bt => String(bt.id) === btId)?.url_slug;
        if (!slug) continue;
        slotsByDayPerType[slug] = {};
        for (const slot of btData.slots || []) {
          const time = formatTime(slot.starts_at);
          // KLUCZOWE: filtrujemy tylko sloty z dozwolonych godzin
          if (!DOZWOLONE_GODZINY.includes(time)) continue;

          const day = slot.starts_at.split('T')[0];
          if (!slotsByDayPerType[slug][day]) slotsByDayPerType[slug][day] = [];
          slotsByDayPerType[slug][day].push({
            ...slot,
            booking_type_slug: slug,
            booking_type_title: btData.title,
            duration_minutes: btData.duration_minutes,
          });
        }
      }

      computeAggregatedSlots();
      hideLoader();
      content?.removeAttribute('hidden');
      renderCalendar();
    } catch (err) {
      console.error('[CustomCalendar] Błąd:', err);
      hideLoader();
      errorBox?.removeAttribute('hidden');
    }
  }

  function computeAggregatedSlots() {
    slotsByDay = {};
    // Jeśli wybrany konkretny booking type → tylko te sloty
    const source = currentBookingSlug && slotsByDayPerType[currentBookingSlug]
      ? { [currentBookingSlug]: slotsByDayPerType[currentBookingSlug] }
      : slotsByDayPerType;

    for (const [slug, daysMap] of Object.entries(source)) {
      for (const [day, slots] of Object.entries(daysMap)) {
        if (!slotsByDay[day]) slotsByDay[day] = [];
        slotsByDay[day].push(...slots);
      }
    }

    // Deduplikacja po czasie + slug, sortowanie
    for (const day in slotsByDay) {
      const seen = new Set();
      slotsByDay[day] = slotsByDay[day].filter(s => {
        const key = `${s.starts_at}_${s.booking_type_slug}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      }).sort((a, b) => new Date(a.starts_at) - new Date(b.starts_at));
    }
  }

  function renderCalendar() {
    if (!gridEl || !monthTitleEl) return;

    const year = currentMonth.getFullYear();
    const month = currentMonth.getMonth();
    monthTitleEl.textContent = `${POLSKIE_MIESIACE[month]} ${year}`;

    const firstDay = new Date(year, month, 1);
    let firstDayOfWeek = firstDay.getDay();
    firstDayOfWeek = firstDayOfWeek === 0 ? 6 : firstDayOfWeek - 1;
    const lastDay = new Date(year, month + 1, 0);
    const daysInMonth = lastDay.getDate();

    let html = '';
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const todayStr = formatDate(today);

    // Dni innych miesięcy → PUSTE pola (cleaner look)
    for (let i = 0; i < firstDayOfWeek; i++) {
      html += `<div class="cc-day cc-day-empty"></div>`;
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(year, month, day);
      const dateStr = formatDate(date);
      const isToday = dateStr === todayStr;
      const isPast = date < today && !isToday;
      const hasSlots = slotsByDay[dateStr] && slotsByDay[dateStr].length > 0;
      const isSelected = dateStr === selectedDay;

      let classes = ['cc-day'];
      if (isPast) classes.push('cc-day-past');
      if (isToday) classes.push('cc-day-today');
      if (hasSlots && !isPast) classes.push('cc-day-free');
      if (isSelected) classes.push('cc-day-selected');

      const clickable = hasSlots && !isPast;
      const attrs = clickable ? `data-cc-day="${dateStr}" role="button" tabindex="0"` : '';
      html += `<div class="${classes.join(' ')}" ${attrs}><span>${day}</span></div>`;
    }

    // Reszta tygodnia → puste pola (nie pokazujemy następnego miesiąca)
    const filledCells = firstDayOfWeek + daysInMonth;
    const remaining = (Math.ceil(filledCells / 7) * 7) - filledCells;
    for (let i = 0; i < remaining; i++) {
      html += `<div class="cc-day cc-day-empty"></div>`;
    }

    gridEl.innerHTML = html;

    gridEl.querySelectorAll('[data-cc-day]').forEach(el => {
      el.addEventListener('click', () => {
        const day = el.getAttribute('data-cc-day');
        if (day) selectDay(day);
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const day = el.getAttribute('data-cc-day');
          if (day) selectDay(day);
        }
      });
    });

    if (prevBtn) {
      const todayMonth = new Date();
      todayMonth.setDate(1);
      todayMonth.setHours(0,0,0,0);
      if (currentMonth.getTime() <= todayMonth.getTime()) {
        prevBtn.setAttribute('disabled', '');
      } else {
        prevBtn.removeAttribute('disabled');
      }
    }
  }

  function selectDay(dayStr) {
    selectedDay = dayStr;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  }

  function renderTimes() {
    if (!timesListEl || !dayLabelEl) return;

    if (!selectedDay) {
      dayLabelEl.textContent = 'Wybierz dzień z kalendarza';
      timesListEl.innerHTML = '<div class="cc-times-empty">👈 Kliknij wolny dzień w kalendarzu, żeby zobaczyć dostępne godziny</div>';
      return;
    }

    const date = parseDate(selectedDay);
    const dayName = POLSKIE_DNI[date.getDay()];
    const dayNum = date.getDate();
    const monthGen = POLSKIE_MIESIACE_GEN[date.getMonth()];
    dayLabelEl.textContent = `${dayName}, ${dayNum} ${monthGen}`;

    const slots = slotsByDay[selectedDay] || [];
    if (slots.length === 0) {
      timesListEl.innerHTML = '<div class="cc-times-empty">Brak wolnych terminów w tym dniu</div>';
      return;
    }

    // Grupuj po unikalnej godzinie
    const byTime = {};
    for (const slot of slots) {
      const time = formatTime(slot.starts_at);
      if (!byTime[time]) byTime[time] = [];
      byTime[time].push(slot);
    }

    let html = '';
    for (const time of Object.keys(byTime).sort()) {
      const slotKey = `${selectedDay}_${time}`;
      const isSelected = selectedSlot && selectedSlot._key === slotKey;
      const checkMark = isSelected ? ' <span class="cc-time-check">✓</span>' : '';
      html += `<button class="cc-time-btn ${isSelected ? 'cc-time-selected' : ''}" data-cc-time="${time}" data-cc-slot-key="${slotKey}" type="button">${time}${checkMark}</button>`;
    }

    timesListEl.innerHTML = html;

    timesListEl.querySelectorAll('[data-cc-time]').forEach(el => {
      el.addEventListener('click', () => {
        const time = el.getAttribute('data-cc-time');
        const key = el.getAttribute('data-cc-slot-key');
        if (time && key) selectTime(time, key);
      });
    });
  }

  function selectTime(time, slotKey) {
    if (!selectedDay) return;
    const slots = slotsByDay[selectedDay] || [];
    const matchingSlots = slots.filter(s => formatTime(s.starts_at) === time);
    if (matchingSlots.length === 0) return;

    // NAPRAWA: jeśli mamy wybrany booking type w BookingSelector,
    // wybierz slot tego TYPU (nie pierwszy lepszy)
    let slot;
    if (currentBookingSlug) {
      slot = matchingSlots.find(s => s.booking_type_slug === currentBookingSlug);
      if (!slot) slot = matchingSlots[0]; // fallback
    } else {
      slot = matchingSlots[0];
    }

    selectedSlot = { ...slot, _key: slotKey };
    renderTimes();
    showCTA();
  }

  function showCTA() {
    if (!selectedSlot || !ctaWrap || !ctaBtn) return;
    const date = parseDate(selectedDay);
    const dayName = POLSKIE_DNI[date.getDay()];
    const dayNum = date.getDate();
    const monthGen = POLSKIE_MIESIACE_GEN[date.getMonth()];
    const time = formatTime(selectedSlot.starts_at);

    selectedTextEl.textContent = `${dayName}, ${dayNum} ${monthGen} · ${time}`;
    selectedMetaEl.textContent = `${selectedSlot.booking_type_title} (${selectedSlot.duration_minutes} min)`;

    const startsAt = new Date(selectedSlot.starts_at);
    const dateParam = formatDate(startsAt);
    const timeParam = formatTime(selectedSlot.starts_at);
    const slug = selectedSlot.booking_type_slug;
    ctaBtn.href = `${TIDYCAL_CONFIG.bookingUrl}/${slug}?date=${dateParam}&time=${timeParam}`;
    ctaWrap.removeAttribute('hidden');
  }

  function formatDate(date) {
    const opts = { timeZone: TIMEZONE, year: 'numeric', month: '2-digit', day: '2-digit' };
    return new Intl.DateTimeFormat('sv-SE', opts).format(date);
  }
  function formatTime(isoString) {
    return new Intl.DateTimeFormat('pl-PL', { timeZone: TIMEZONE, hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date(isoString));
  }
  function parseDate(dayStr) {
    const [y, m, d] = dayStr.split('-').map(Number);
    return new Date(y, m - 1, d);
  }
  function showLoader() {
    loader?.removeAttribute('hidden');
    if (loader) loader.style.display = 'flex';
    content?.setAttribute('hidden', '');
    errorBox?.setAttribute('hidden', '');
  }
  function hideLoader() {
    loader?.setAttribute('hidden', '');
    if (loader) loader.style.display = 'none';
  }

  prevBtn?.addEventListener('click', () => {
    currentMonth.setMonth(currentMonth.getMonth() - 1);
    selectedDay = null;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  });

  nextBtn?.addEventListener('click', () => {
    currentMonth.setMonth(currentMonth.getMonth() + 1);
    selectedDay = null;
    selectedSlot = null;
    ctaWrap?.setAttribute('hidden', '');
    renderCalendar();
    renderTimes();
  });

  retryEl?.addEventListener('click', (e) => {
    e.preventDefault();
    errorBox?.setAttribute('hidden', '');
    fetchSlots();
  });

  // Event z BookingSelector — filtruj po wybranym booking type
  window.addEventListener('tidycal-select', (e) => {
    const slug = e.detail?.slug;
    if (slug) {
      currentBookingSlug = slug;
      computeAggregatedSlots();
      selectedDay = null;
      selectedSlot = null;
      ctaWrap?.setAttribute('hidden', '');
      renderCalendar();
      renderTimes();

      if (subtitleEl) {
        const bt = bookingTypes.find(b => b.url_slug === slug);
        if (bt) {
          subtitleEl.innerHTML = `Pokazuję dostępność dla: <strong>${bt.title}</strong>. Kliknij wolny dzień i wybierz godzinę.`;
        }
      }
    }
  });

  fetchSlots();
</script>

<style>
  .custom-calendar-section { padding: 40px 0; }
  .cc-title { font-size: 28px; font-weight: 600; letter-spacing: -0.5px; line-height: 1.15; margin-top: 6px; margin-bottom: 8px; }
  .cc-subtitle { font-size: 14px; color: rgba(235,238,255,0.65); line-height: 1.6; margin-bottom: 22px; max-width: 640px; }
  .cc-subtitle strong { color: #FFDE59; }
  .cc-widget { position: relative; min-height: 520px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,222,89,0.2); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.25); }
  .cc-loader { min-height: 520px; display: flex; flex-direction: column; align-items: center; justify-content: center; color: rgba(235,238,255,0.5); padding: 40px 20px; }
  .cc-loader[hidden] { display: none !important; }
  .cc-loader p { font-size: 13px; margin-top: 14px; }
  .cc-spinner { width: 40px; height: 40px; border: 3px solid rgba(255,222,89,0.2); border-top-color: #FFDE59; border-radius: 50%; animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .cc-error { display: flex; gap: 16px; align-items: flex-start; padding: 32px; }
  .cc-error[hidden] { display: none !important; }
  .cc-error i { color: #FFDE59; font-size: 28px; flex-shrink: 0; margin-top: 2px; }
  .cc-error strong { font-size: 16px; display: block; margin-bottom: 4px; }
  .cc-error p { font-size: 13px; color: rgba(235,238,255,0.65); margin-bottom: 12px; }
  .cc-error a[data-cc-retry] { color: #3FCECF; cursor: pointer; }
  .cc-content { display: grid; grid-template-columns: 1.4fr 1fr; gap: 0; min-height: 520px; }
  .cc-content[hidden] { display: none !important; }
  .cc-calendar { padding: 24px; border-right: 1px solid rgba(235,238,255,0.08); }
  .cc-cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
  .cc-cal-title { font-size: 17px; font-weight: 600; color: #EBEEFF; }
  .cc-cal-nav { background: transparent; border: 1px solid rgba(235,238,255,0.1); color: rgba(235,238,255,0.6); width: 32px; height: 32px; border-radius: 8px; font-size: 18px; cursor: pointer; transition: all 0.15s ease; font-family: inherit; display: flex; align-items: center; justify-content: center; }
  .cc-cal-nav:hover:not([disabled]) { background: rgba(255,255,255,0.06); color: #EBEEFF; border-color: rgba(235,238,255,0.2); }
  .cc-cal-nav[disabled] { opacity: 0.3; cursor: not-allowed; }
  .cc-cal-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-bottom: 8px; }
  .cc-cal-weekdays div { text-align: center; font-size: 11px; font-weight: 500; color: rgba(235,238,255,0.4); padding: 6px 0; }
  .cc-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }

  /* === DZIEŃ — bazowy === */
  .cc-day {
    aspect-ratio: 1 / 1;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 14px;
    color: rgba(235,238,255,0.5);
    transition: all 0.15s ease;
  }
  .cc-day span {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 82% !important;
    height: 82% !important;
    border-radius: 999px !important;
    transition: all 0.15s ease;
  }

  /* PUSTE pole (poza miesiącem) */
  .cc-day-empty { visibility: hidden; }

  /* Przeszłe dni */
  .cc-day-past span { color: rgba(235,238,255,0.25); }

  /* DZIŚ — turkusowy obrys */
  .cc-day-today span {
    border: 1.5px solid #3FCECF !important;
    color: #3FCECF !important;
    font-weight: 600 !important;
  }

  /* === WOLNE DNI — granat kafelek + żółty tekst === */
  .cc-day-free { cursor: pointer; }
  .cc-day-free span {
    background: rgba(5, 10, 36, 0.85) !important;
    color: #FFDE59 !important;
    font-weight: 600 !important;
    border: 1px solid rgba(255, 222, 89, 0.4) !important;
  }
  .cc-day-free:hover span {
    background: rgba(255, 222, 89, 0.15) !important;
    border-color: rgba(255, 222, 89, 0.7) !important;
    transform: scale(1.08);
  }

  /* === WYBRANY DZIEŃ — pełny żółty === */
  .cc-day-selected span {
    background: #FFDE59 !important;
    color: #050A24 !important;
    font-weight: 700 !important;
    border-color: #FFDE59 !important;
  }

  /* DZIŚ + wolny */
  .cc-day-today.cc-day-free span { border: 1.5px solid #3FCECF !important; }

  /* Legenda */
  .cc-cal-legend { display: flex; gap: 18px; margin-top: 20px; flex-wrap: wrap; }
  .cc-cal-legend span { display: flex; align-items: center; gap: 6px; font-size: 11px; color: rgba(235,238,255,0.5); }
  .cc-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .cc-dot-today { background: transparent; border: 1.5px solid #3FCECF; }
  .cc-dot-free { background: #FFDE59; }

  /* === PRAWA: GODZINY === */
  .cc-times { padding: 24px; display: flex; flex-direction: column; background: rgba(5,10,36,0.4); }
  .cc-times-header { margin-bottom: 14px; }
