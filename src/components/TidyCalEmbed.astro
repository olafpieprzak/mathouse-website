---
// =====================================================
// TIDYCAL EMBED — pełen kalendarz osadzony na stronie
// =====================================================
// FIXY V5:
// - Loader przestaje się kręcić po wykryciu iframe (lepsza detekcja)
// - Lewa kolumna TidyCal ukryta przez CSS (tylko sam kalendarz)
// - Kolory TidyCal dopasowane do brandu MATHOUSE
// =====================================================
import { TIDYCAL_CONFIG } from '../config/tidycal.js';

interface Props {
  bookingSlug?: string;
  height?: string;
  showTitle?: boolean;
}

// Domyślny booking type — liceum 1 osoba 90 min (najpopularniejszy)
const DEFAULT_SLUG = 'szkola-srednia-poziom-rozszerzony-korepetycje-indywidualne';

const {
  bookingSlug = DEFAULT_SLUG,
  height = '720px',
  showTitle = true,
} = Astro.props;

// Quick-switch buttons — popularne warianty
const quickOptions = [
  { label: '1 os · 45 min', slug: 'szkola-srednia-poziom-rozszerzony-korepetycje-indywidualne-45', popular: false },
  { label: '1 os · 90 min', slug: 'szkola-srednia-poziom-rozszerzony-korepetycje-indywidualne', popular: true },
  { label: '2 os · 45 min', slug: 'szkola-srednia-poziom-rozszerzony-korepetycje-w-grupie-2-osobowej', popular: false },
  { label: '2 os · 90 min', slug: 'szkola-srednia-poziom-rozszerzony-korepetycje-w-grupie-2-osobowej-90', popular: false },
];
---

<section id="kalendarz" class="tidycal-embed-section">
  <div class="container-content">
    {showTitle && (
      <>
        <div class="section-label">PEŁNY KALENDARZ · WSZYSTKIE TERMINY</div>
        <h2 class="tc-title">Sprawdź wolne terminy i zarezerwuj.</h2>
        <p class="tc-subtitle">
          Kliknij w wolny slot, wypełnij dane, gotowe. Otrzymasz potwierdzenie mailem.
          Domyślnie pokazujemy <strong>liceum 1 osoba · 90 min</strong> — wybierz inny wariant powyżej lub w selectorze.
        </p>
      </>
    )}

    <!-- Quick-switch dla popularnych wariantów -->
    <div class="tc-quick-switch" data-tc-quick-switch>
      <span class="tc-quick-label">Szybki wybór:</span>
      {quickOptions.map((opt) => (
        <button
          class={`tc-quick-btn ${opt.slug === bookingSlug ? 'tc-quick-active' : ''} ${opt.popular ? 'tc-quick-popular' : ''}`}
          data-tc-quick-slug={opt.slug}
          type="button"
        >
          {opt.label}
          {opt.popular && <span class="tc-quick-badge">★</span>}
        </button>
      ))}
      <a
        href={`https://tidycal.com/mathouse`}
        target="_blank"
        rel="noopener noreferrer"
        class="tc-quick-all"
      >
        wszystkie warianty →
      </a>
    </div>

    <!-- TidyCal embed container -->
    <div class="tc-embed-wrap" style={`min-height:${height}`} data-tc-wrap>
      <div
        class="tidycal-embed"
        data-path={`mathouse/${bookingSlug}`}
        data-current-slug={bookingSlug}
      ></div>

      <!-- Loading placeholder -->
      <div class="tc-loading" data-tc-loading>
        <div class="tc-spinner"></div>
        <p>Ładuję kalendarz…</p>
      </div>

      <!-- Fallback gdy embed nie zadziała -->
      <noscript>
        <div class="tc-fallback">
          <p>Włącz JavaScript aby zobaczyć kalendarz, albo</p>
          <a href={`https://tidycal.com/mathouse/${bookingSlug}`} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Otwórz kalendarz w nowym oknie →
          </a>
        </div>
      </noscript>
    </div>

    <div class="tc-bottom-info">
      <div class="tc-info-item">
        <i class="ti ti-shield-check"></i>
        Bezpieczna rezerwacja przez TidyCal
      </div>
      <div class="tc-info-item">
        <i class="ti ti-mail"></i>
        Potwierdzenie + przypomnienie mailem
      </div>
      <div class="tc-info-item">
        <i class="ti ti-calendar"></i>
        Wydarzenie automatycznie w Twoim kalendarzu
      </div>
    </div>
  </div>
</section>

<!-- TidyCal embed script -->
<script is:inline src="https://asset-tidycal.b-cdn.net/js/embed.js" async></script>

<script>
  // ============================================================
  // Dynamiczne przełączanie embed TidyCal (quick-switch)
  // ============================================================

  function switchTidyCalEmbed(newSlug) {
    const embed = document.querySelector('.tidycal-embed');
    if (!embed) return;

    const newPath = `mathouse/${newSlug}`;
    embed.innerHTML = '';
    embed.setAttribute('data-path', newPath);
    embed.setAttribute('data-current-slug', newSlug);

    // Pokaż loader podczas przełączania
    const loader = document.querySelector('[data-tc-loading]');
    if (loader instanceof HTMLElement) {
      loader.style.display = 'flex';
    }

    // Wymuś przeładowanie TidyCal embed
    if (window.TidyCalEmbed && typeof window.TidyCalEmbed.init === 'function') {
      window.TidyCalEmbed.init();
    } else {
      const oldScript = document.querySelector('script[src*="tidycal"]');
      if (oldScript) oldScript.remove();
      const newScript = document.createElement('script');
      newScript.src = 'https://asset-tidycal.b-cdn.net/js/embed.js';
      newScript.async = true;
      document.body.appendChild(newScript);
    }

    // Update quick-switch buttons
    document.querySelectorAll('[data-tc-quick-slug]').forEach((btn) => {
      if (btn.getAttribute('data-tc-quick-slug') === newSlug) {
        btn.classList.add('tc-quick-active');
      } else {
        btn.classList.remove('tc-quick-active');
      }
    });

    // Restart wykrywania załadowania (loader ukryje się znowu)
    startLoaderDetection();
  }

  // Quick-switch buttons
  document.querySelectorAll('[data-tc-quick-slug]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.getAttribute('data-tc-quick-slug');
      if (slug) {
        switchTidyCalEmbed(slug);
        setTimeout(() => {
          document.getElementById('kalendarz')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  });

  // Nasłuch wydarzenia z BookingSelector
  window.addEventListener('tidycal-select', (e) => {
    const slug = e.detail?.slug;
    if (slug) switchTidyCalEmbed(slug);
  });

  // ============================================================
  // Wykrycie załadowania iframe — ukryj loader
  // ============================================================
  // FIX V5: Lepsza detekcja przez MutationObserver + sprawdzanie czy iframe ma już content
  // ============================================================

  let detectInterval = null;

  function hideLoader() {
    const loader = document.querySelector('[data-tc-loading]');
    if (loader instanceof HTMLElement) {
      loader.style.display = 'none';
    }
  }

  function checkIframeReady() {
    const embed = document.querySelector('.tidycal-embed');
    if (!embed) return false;
    const iframe = embed.querySelector('iframe');
    if (!iframe) return false;

    // Sprawdź czy iframe ma już rozmiar (czyli załadował się)
    const rect = iframe.getBoundingClientRect();
    if (rect.height > 100) {
      hideLoader();
      return true;
    }
    return false;
  }

  function startLoaderDetection() {
    if (detectInterval) clearInterval(detectInterval);

    // Pokaż loader na nowo
    const loader = document.querySelector('[data-tc-loading]');
    if (loader instanceof HTMLElement) {
      loader.style.display = 'flex';
    }

    let attempts = 0;
    detectInterval = setInterval(() => {
      attempts++;
      if (checkIframeReady() || attempts > 30) {
        clearInterval(detectInterval);
        detectInterval = null;
        // Ostatecznie ukryj loader po 15s niezależnie od stanu
        if (attempts > 30) hideLoader();
      }
    }, 500);
  }

  // Start na początku
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startLoaderDetection);
  } else {
    startLoaderDetection();
  }

  // MutationObserver — wykryj gdy iframe się dodaje do DOM
  const wrap = document.querySelector('[data-tc-wrap]');
  if (wrap) {
    const observer = new MutationObserver(() => {
      if (checkIframeReady()) {
        if (detectInterval) {
          clearInterval(detectInterval);
          detectInterval = null;
        }
      }
    });
    observer.observe(wrap, { childList: true, subtree: true });
  }
</script>

<style>
  .tidycal-embed-section {
    padding: 40px 0;
  }
  .tc-title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.5px;
    line-height: 1.15;
    margin-top: 6px;
    margin-bottom: 8px;
  }
  .tc-subtitle {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.6;
    margin-bottom: 22px;
    max-width: 640px;
  }
  .tc-subtitle strong {
    color: #FFDE59;
  }

  /* === QUICK-SWITCH === */
  .tc-quick-switch {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    padding: 14px 16px;
    background: rgba(255, 222, 89, 0.04);
    border: 1px solid rgba(255, 222, 89, 0.15);
    border-radius: 11px;
  }
  .tc-quick-label {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-right: 4px;
  }
  .tc-quick-btn {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    color: #EBEEFF;
    padding: 7px 13px;
    border-radius: 18px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .tc-quick-btn:hover {
    border-color: rgba(255, 222, 89, 0.4);
    background: rgba(255, 222, 89, 0.06);
  }
  .tc-quick-active {
    background: #FFDE59 !important;
    color: #050A24 !important;
    border-color: #FFDE59 !important;
    font-weight: 600;
  }
  .tc-quick-popular {
    border-color: rgba(63, 206, 207, 0.4);
  }
  .tc-quick-badge {
    color: #FFDE59;
    font-size: 10px;
  }
  .tc-quick-active .tc-quick-badge {
    color: #050A24;
  }
  .tc-quick-all {
    margin-left: auto;
    font-size: 12px;
    color: rgba(63, 206, 207, 0.9);
    text-decoration: none;
    font-weight: 500;
  }
  .tc-quick-all:hover {
    color: #3FCECF;
  }

  /* === EMBED CONTAINER === */
  .tc-embed-wrap {
    position: relative;
    background: #050A24;
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  /* TidyCal embed — sterujemy iframe */
  .tidycal-embed {
    position: relative;
    z-index: 2;
    min-height: inherit;
    background: #050A24;
  }
  .tidycal-embed iframe {
    width: 100%;
    border: none;
    border-radius: 16px;
    min-height: inherit;
    /* Filter color — daje delikatnie żółtawy odcień by pasował do brandu */
    /* Filtry ostrożnie — TidyCal embed jest renderowany jako iframe, więc filtry działają na całość */
  }

  /* === LOADING === */
  .tc-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    color: rgba(235, 238, 255, 0.5);
    background: #050A24;
    transition: opacity 0.3s ease;
  }
  .tc-loading p {
    font-size: 13px;
    margin-top: 14px;
  }
  .tc-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 222, 89, 0.2);
    border-top-color: #FFDE59;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* === FALLBACK === */
  .tc-fallback {
    padding: 60px 24px;
    text-align: center;
  }
  .tc-fallback p {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    margin-bottom: 16px;
  }

  /* === DOLNY PASEK INFO === */
  .tc-bottom-info {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .tc-info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: rgba(235, 238, 255, 0.55);
  }
  .tc-info-item i {
    color: #3FCECF;
    font-size: 16px;
  }

  /* === RESPONSIVE === */
  @media (max-width: 640px) {
    .tc-title {
      font-size: 22px;
    }
    .tc-bottom-info {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }
    .tc-quick-all {
      margin-left: 0;
      width: 100%;
      text-align: center;
      padding-top: 8px;
      border-top: 1px solid rgba(235, 238, 255, 0.08);
      margin-top: 4px;
    }
  }
</style>
