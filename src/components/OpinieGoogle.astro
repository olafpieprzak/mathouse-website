---
// =====================================================
// OPINIE GOOGLE — sekcja na stronie głównej
// =====================================================
// 6 placeholderów na opinie z Google "Mathouse - Olaf Pieprzak"
// Olaf wkleja ręcznie najlepsze opinie ze swojej wizytówki Google.
//
// JAK WKLEIĆ OPINIE:
//   1. Wejdź na swoją wizytówkę Google (https://www.google.com/search?q=Mathouse+Olaf+Pieprzak#mpd=~11644575886433657842/customers/reviews)
//   2. Kliknij "Opinie"
//   3. Wybierz 6 najlepszych, skopiuj treść + imię
//   4. Wklej poniżej w tablicy `opinie` - pole `text` i `autor`
//   5. Wszystkie opinie pozostaną widoczne na stronie głównej
//
// PLAN B (wideo): w przyszłości zamień sekcję na nagrania uczniów
// =====================================================

const opinie = [
  {
    text: 'Dzięki Olafowi zdałem maturę, byłem pewien że sytuacja bez wyjścia i że będzie poprawa w sierpniu. TAK SIĘ NIE STAŁO! Olaf dzięki swojej wiedzy, umiejętnościom i wyrozumiałości oraz podejściu sprawił że dziś jestem tu gdzie jestem a matura dla mnie to już przeszłość. CZŁOWIEK WART SWOJEJ CENY!!',
    autor: 'Bartłomiej Dziedzic',
    rok: '2024',
  },
  {
    text: 'Olaf to najlepszy korepetytor na jakiego trafiła moja córka dzięki niemu matematyka to już dla niej nie problem!Olaf potrafi idealnie dotrzeć do ucznia jest wyrozumiały i cierpliwy.Swoja wiedzę przekazuje idealnie dokładnie tłumacząc i pokazując łatwiejsze sposoby rozwiązywania zadań co sprawia że matematyka staje się banalna dla mojej córki .',
    autor: 'Bernadetta Skóra',
    rok: '2024',
  },
  {
    text: 'Polecam serdecznie! Trafiłam do Olafa kilka miesięcy przed Matura, wielu korepetytorów mówiło, że to już jest za późno na to abym zdała dobrze maturę z matematyki. Metody i nauczenia Olafa pozwoliły mi ją zdać na wysokim poziomie. Olaf nie jest jak typowy nauczyciel, znajdzie sposób, aby ci to wytłumaczyć i żebyś wiedział co gdzie i dlaczego. Atmosferę która tam panuje jest luźna, jakbyś powtarzał materiał do matury z kolegą. 😎❤️',
    autor: 'julia p',
    rok: '2024',
  },
  {
    text: 'Bardzo profesjonalne podejście do nauczania czy to pod bieżący materiał, maturę czy również pod konkursy, oczywiście z miłą i luźną atmosferą. Olaf zawsze znajdzie sposób aby dotrzeć do ucznia i wytłumaczyć mu zagadnienia w jak najprostszy i logiczny sposób. Serdecznie Polecam',
    autor: 'Kuszix',
    rok: '2024',
  },
  {
    text: 'Bardzo polecamm wszystkim którzy szukają pomocy z matematyki zarówno jeśli chodzi o podstawę czy rozszerzenie super metody rozwiązywania zadań i świetna atmosfera!',
    autor: 'Lena Popek',
    rok: '2024',
  },
  
{
    text: 'Bardzo dobry korepetytor gdyby nie on nie zdał bym matury. Wszystko tłumaczy bardzo prosto i spokojnie dodatkowo wielki plus za możliwość korepetycji online które nie odbiegają treścią od stacjonarnych. POLECAM!!!',
    autor: '
Igor Kręgiel',
    rok: '2024',
  },
];

const GOOGLE_URL = 'https://www.google.com/search?q=Mathouse+Olaf+Pieprzak';
---

<section class="opinie-section">
  <div class="container-content">
    <div class="opinie-head">
      <div class="opinie-rating">
        <div class="opinie-stars">★★★★★</div>
        <div class="opinie-rating-text">
          <strong>Opinie uczniów z Google</strong>
          <span>Co mówią o moich korepetycjach i kursach</span>
        </div>
      </div>
      <a href={GOOGLE_URL} target="_blank" rel="noopener noreferrer" class="opinie-google-link">
        Zobacz wszystkie opinie na Google →
      </a>
    </div>

    <div class="opinie-grid">
      {opinie.map((o) => (
        <div class="opinie-card">
          <div class="opinie-card-stars">★★★★★</div>
          <blockquote class="opinie-text">"{o.text}"</blockquote>
          <div class="opinie-autor">
            <span class="opinie-avatar">{o.autor.charAt(0)}</span>
            <div>
              <div class="opinie-imie">{o.autor}</div>
              <div class="opinie-meta">via Google · {o.rok}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="opinie-cta">
      <a href={GOOGLE_URL} target="_blank" rel="noopener noreferrer" class="btn-teal">
        ⭐ Przeczytaj wszystkie opinie na Google
      </a>
    </div>
  </div>
</section>

<style>
  .opinie-section {
    padding: 60px 0;
    background: rgba(63, 206, 207, 0.04);
    border-top: 1px solid rgba(63, 206, 207, 0.12);
    border-bottom: 1px solid rgba(63, 206, 207, 0.12);
  }
  .opinie-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .opinie-rating {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .opinie-stars {
    font-size: 26px;
    color: #FFDE59;
    letter-spacing: 2px;
  }
  .opinie-rating-text strong {
    display: block;
    font-size: 20px;
    color: #EBEEFF;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .opinie-rating-text span {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.6);
  }
  .opinie-google-link {
    color: #3FCECF;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 14px;
    border: 1px solid rgba(63, 206, 207, 0.3);
    border-radius: 8px;
    transition: all 0.15s ease;
  }
  .opinie-google-link:hover {
    background: rgba(63, 206, 207, 0.1);
    border-color: #3FCECF;
  }

  .opinie-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .opinie-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .opinie-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 222, 89, 0.3);
  }
  .opinie-card-stars {
    font-size: 14px;
    color: #FFDE59;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
  }
  .opinie-text {
    font-size: 13.5px;
    color: rgba(235, 238, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 18px;
    flex: 1;
    font-style: italic;
  }
  .opinie-autor {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 14px;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
  }
  .opinie-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FFDE59, #3FCECF);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #050A24;
    font-weight: 800;
    font-size: 15px;
    flex-shrink: 0;
  }
  .opinie-imie {
    font-size: 13px;
    color: #EBEEFF;
    font-weight: 700;
  }
  .opinie-meta {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 2px;
  }
  .opinie-cta {
    text-align: center;
    margin-top: 28px;
  }
  .opinie-cta .btn-teal {
    display: inline-block;
    padding: 13px 24px;
    background: #3FCECF;
    color: #050A24;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .opinie-cta .btn-teal:hover { background: #5CDADB; }

  @media (max-width: 900px) {
    .opinie-grid { grid-template-columns: repeat(2, 1fr); }
    .opinie-head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 600px) {
    .opinie-grid { grid-template-columns: 1fr; }
  }
</style>
