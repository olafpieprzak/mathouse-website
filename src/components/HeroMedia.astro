---
// =====================================================
// HeroMedia - uniwersalny komponent na zdjęcie/wideo w hero
// =====================================================
// Props:
//   slot: klucz w mediaConfig (np. 'heroGlowna', 'heroKorepetycje', 'heroKursy')
//   captionOverride: opcjonalnie nadpisuje caption z konfigu (dla heroKursy
//                    żeby podać "pierwsza lekcja gratis · Logarytmy 1.5")
// =====================================================
import { mediaConfig, getYouTubeEmbedUrl } from '../data/media.js';

const { slot, captionOverride } = Astro.props;
const config = mediaConfig[slot];

if (!config) {
  throw new Error(`HeroMedia: nieznany slot "${slot}". Dostępne: ${Object.keys(mediaConfig).join(', ')}`);
}

const isVideo = config.mode === 'video' && config.videoUrl;
const embedUrl = isVideo ? getYouTubeEmbedUrl(config.videoUrl) : null;
const caption = captionOverride || config.caption || '';
---

<div class="hero-media-wrap">
  <div class="hero-media-bg" aria-hidden="true"></div>
  <div class="hero-media-frame">
    {isVideo && embedUrl ? (
      <!-- TRYB WIDEO: embed YouTube w ramce -->
      <iframe
        src={embedUrl}
        title={config.alt}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
        loading="lazy"
        class="hero-media-iframe"
      ></iframe>
    ) : (
      <!-- TRYB ZDJĘCIE: statyczne zdjęcie -->
      <img
        src={config.image}
        alt={config.alt}
        class="hero-media-img"
        loading="lazy"
      />
    )}

    {config.badge && (
      <span class="hero-media-badge">{config.badge}</span>
    )}
    {caption && (
      <span class="hero-media-caption">{caption}</span>
    )}
  </div>
</div>

<style>
  .hero-media-wrap {
    position: relative;
    width: 100%;
  }
  .hero-media-bg {
    position: absolute;
    inset: 0;
    background: #3FCECF;
    border-radius: 16px;
    transform: rotate(-3deg);
    z-index: 0;
  }
  .hero-media-frame {
    position: relative;
    background: #050A24;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(235, 238, 255, 0.1);
    z-index: 1;
  }
  .hero-media-img,
  .hero-media-iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: none;
  }
  .hero-media-badge {
    position: absolute;
    top: 14px;
    right: 16px;
    background: rgba(255, 222, 89, 0.95);
    color: #050A24;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    z-index: 2;
  }
  .hero-media-caption {
    position: absolute;
    bottom: 14px;
    left: 18px;
    right: 18px;
    color: #EBEEFF;
    font-size: 12px;
    font-weight: 500;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
    z-index: 2;
  }
</style>
