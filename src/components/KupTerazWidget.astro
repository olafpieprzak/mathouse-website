---
// =====================================================
// KupTerazWidget — embed widget sklepu kurs.mathouse.pl
// =====================================================
// Wariant 2-kolumnowy: lewa kolumna z tekstem CTA + prawa kolumna z widgetem
// na desktopie. Mobile: pełna szerokość, układ jeden pod drugim.
// =====================================================

const { embedId, productName = 'kurs', price = 197, priceOld = null, priceMin30Days = null } = Astro.props;
---

<section id="kup-teraz" class="kup-teraz-section">
  <div class="container-content kup-teraz-grid">
    <!-- LEWA KOLUMNA — tekst CTA -->
    <div class="kup-teraz-left">
      <div class="section-label">🛒 ZAMAWIASZ TERAZ</div>
      <h2 class="kup-teraz-title">
        Kup <span class="text-yellow">{productName}</span><br />bez wychodzenia ze strony.
      </h2>
      <ul class="kup-teraz-features">
        <li><span class="kt-tick">✓</span> Dostęp <strong>natychmiast</strong> po opłaceniu</li>
        <li><span class="kt-tick">✓</span> Dostęp <strong>na zawsze</strong> — bez subskrypcji</li>
        <li><span class="kt-tick">✓</span> Płatność <strong>BLIK · kartą · PayU · raty</strong></li>
        <li><span class="kt-tick">✓</span> Faktura VAT na żądanie</li>
      </ul>
      <div class="kup-teraz-price">
        <span class="kt-price-now">{price} zł</span>
        {priceOld && <span class="kt-price-old">{priceOld} zł</span>}
      </div>
      {priceOld && (
        <p class="kt-price-omnibus">Najniższa cena z 30 dni przed obniżką: {priceMin30Days || price} zł</p>
      )}
    </div>

    <!-- PRAWA KOLUMNA — widget Web To Learn -->
    <div class="kup-teraz-right">
      <div class="kup-teraz-frame">
        <style is:inline>
          .wtl-responsive-iframe { width: 1px; min-width: 100%; }
        </style>
        <iframe
          class="wtl-responsive-iframe"
          src={`https://kurs.mathouse.pl/assets/js/s.php?id=${embedId}`}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title={`Zakup: ${productName}`}
        ></iframe>
      </div>
    </div>
  </div>

  <script src="https://kurs.mathouse.pl/assets/js/iframe-resizer-embed.js" is:inline></script>
  <script is:inline>
    (function() {
      function tryInit() {
        if (typeof iframeResize === 'function') {
          iframeResize({ log: false, checkOrigin: false }, '.wtl-responsive-iframe');
        } else if (typeof iFrameResize === 'function') {
          iFrameResize({ log: false, checkOrigin: false }, '.wtl-responsive-iframe');
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryInit);
      } else {
        tryInit();
      }
    })();
  </script>
</section>

<style>
  .kup-teraz-section {
    padding: 50px 0 60px;
    background: linear-gradient(180deg, rgba(255, 222, 89, 0.04) 0%, rgba(63, 206, 207, 0.04) 100%);
    border-top: 2px solid rgba(255, 222, 89, 0.25);
    scroll-margin-top: 80px;
  }

  /* === LAYOUT 2-KOLUMNOWY (DESKTOP) === */
  .kup-teraz-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 32px;
    align-items: start;
  }

  /* === LEWA KOLUMNA === */
  .kup-teraz-left {
    padding-top: 8px;
  }
  .text-yellow { color: #FFDE59; }
  .kup-teraz-title {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.6px;
    margin: 8px 0 18px;
    color: #EBEEFF;
  }
  .kup-teraz-features {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .kup-teraz-features li {
    font-size: 13.5px;
    color: rgba(235, 238, 255, 0.8);
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .kup-teraz-features strong { color: #EBEEFF; font-weight: 700; }
  .kt-tick {
    color: #2ECC71;
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .kup-teraz-price {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(235, 238, 255, 0.1);
  }
  .kt-price-now {
    font-size: 28px;
    font-weight: 800;
    color: #FFDE59;
    letter-spacing: -0.5px;
  }
  .kt-price-old {
    font-size: 16px;
    color: rgba(235, 238, 255, 0.4);
    text-decoration: line-through;
  }
  .kt-price-omnibus {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.45);
    margin-top: 6px;
    font-style: italic;
  }

  /* === PRAWA KOLUMNA - widget === */
  .kup-teraz-frame {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(235, 238, 255, 0.15);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.3);
    min-height: 480px;
  }
  .kup-teraz-frame iframe {
    width: 100%;
    border: none;
    display: block;
  }

  /* === MOBILE - stack jeden pod drugim, widget pełna szerokość === */
  @media (max-width: 900px) {
    .kup-teraz-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .kup-teraz-title { font-size: 24px; }
    .kup-teraz-section { padding: 36px 0 44px; }
  }
</style>
