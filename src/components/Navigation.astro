<script is:inline>
  (function() {
    function initMobileMenu() {
      const toggle = document.querySelector('[data-nav-toggle]');
      const closeBtn = document.querySelector('[data-nav-close]');
      const mobile = document.querySelector('[data-nav-mobile]');

      if (!toggle || !mobile) {
        console.warn('[Navigation] Brak elementów menu mobilnego');
        return;
      }

      // Mark as initialized żeby nie inicjalizować 2x
      if (toggle.dataset.initialized === 'true') return;
      toggle.dataset.initialized = 'true';

      function openMenu() {
        mobile.classList.add('is-open');
        toggle.classList.add('open');
        document.body.style.overflow = 'hidden';
        console.log('[Navigation] Menu OTWARTE');
      }

      function closeMenu() {
        mobile.classList.remove('is-open');
        toggle.classList.remove('open');
        document.body.style.overflow = '';
        console.log('[Navigation] Menu ZAMKNIĘTE');
      }

      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = mobile.classList.contains('is-open');
        if (isOpen) closeMenu();
        else openMenu();
      });

      if (closeBtn) {
        closeBtn.addEventListener('click', function(e) {
          e.preventDefault();
          closeMenu();
        });
      }

      // Zamknij po kliknięciu w link (nie summary)
      const links = mobile.querySelectorAll('a.mobile-item, a.mobile-sublink, a.mobile-cta');
      links.forEach(function(link) {
        link.addEventListener('click', function() {
          closeMenu();
        });
      });

      // ESC key zamyka menu
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobile.classList.contains('is-open')) {
          closeMenu();
        }
      });
    }

    // Init na różnych stadiach - na pewno zadziała
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileMenu);
    } else {
      initMobileMenu();
    }
  })();
</script>

<style>
  /* === TOP BAR === */
  .top-bar {
    background: rgba(2, 6, 23, 0.95);
    border-bottom: 1px solid rgba(255, 222, 89, 0.08);
    padding: 8px 0;
    font-size: 12px;
  }
  .top-bar-inner {
