  .nav-login:hover { color: #FFDE59; border-color: rgba(255, 222, 89, 0.3); }
  .nav-cta { font-size: 13px; padding: 10px 18px; }

  /* HAMBURGER */
  .nav-hamburger {
    display: none;
    background: transparent;
    border: 1px solid rgba(235, 238, 255, 0.15);
    width: 38px;
    height: 38px;
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .nav-hamburger span {
    display: block;
    width: 16px;
    height: 2px;
    background: #EBEEFF;
    transition: all 0.15s ease;
  }
