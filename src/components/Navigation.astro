    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    width: 36px;
    height: 36px;
    background: #FFDE59;
    color: #050A24;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 20px;
    font-family: 'Instrument Serif', serif;
  }
  .logo-text {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: #EBEEFF;
