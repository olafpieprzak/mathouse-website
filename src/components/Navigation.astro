  /* NAV LINKS */
  .nav-links { display: flex; gap: 4px; align-items: center; flex: 1; justify-content: center; }
  .nav-link {
    display: flex; align-items: center; gap: 4px;
    padding: 10px 14px;
    color: rgba(235, 238, 255, 0.75);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .nav-link:hover { color: #FFDE59; background: rgba(255, 222, 89, 0.05); }
  .nav-link.active { color: #FFDE59; background: rgba(255, 222, 89, 0.08); }
  .nav-link svg { transition: transform 0.2s ease; }
  .nav-dropdown:hover .nav-link svg { transform: rotate(180deg); }

  /* DROPDOWN */
  .nav-dropdown { position: relative; }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 280px;
    background: rgba(5, 10, 36, 0.98);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 14px;
    padding: 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 200;
  }
  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .nav-dropdown::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    height: 8px;
  }
  .dropdown-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px;
    text-decoration: none;
    color: #EBEEFF;
    border-radius: 9px;
    transition: all 0.15s ease;
