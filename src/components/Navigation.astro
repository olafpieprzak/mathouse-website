    gap: 16px;
  }
  .top-bar-socials { display: flex; gap: 4px; align-items: center; }
  .top-bar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    color: rgba(235, 238, 255, 0.55);
