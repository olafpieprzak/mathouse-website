<script is:inline>
  // Toggle podpunktów w kafelku działu - nie nawigujemy do kursu, tylko rozwijamy
  function toggleDzialPodpunkty(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const card = btn.closest('.dzial-card');
    if (!card) return;
    const expanded = card.classList.toggle('expanded');
    if (expanded) {
      const hidden = card.querySelectorAll('.dzial-podpunkt-extra').length;
      btn.textContent = '− zwiń (' + hidden + ' więcej widocznych)';
    } else {
      const hidden = card.querySelectorAll('.dzial-podpunkt-extra').length;
      btn.textContent = '+ pokaż jeszcze ' + hidden;
    }
  }
</script>
