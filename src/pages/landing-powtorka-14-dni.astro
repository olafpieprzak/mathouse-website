  ]},
];

const korzysci = [
  { icon: '✅', tytul: 'Kompletna powtórka całego materiału', opis: 'Krok po kroku przechodzimy przez wszystkie 14 działów matury podstawowej.' },
  { icon: '🎯', tytul: 'Spokój i jasny plan', opis: 'Przygotowanie do egzaminu bez chaosu. Każdy dzień to konkretny dział.' },
  { icon: '📹', tytul: 'Dostęp do nagrań', opis: 'Każdą lekcję nagrywam — wracasz do niej w dowolnym momencie, pauzujesz, powtarzasz.' },
  { icon: '📈', tytul: 'Szanse na wyższy wynik', opis: 'Poznajesz typowe pułapki maturalne i wiesz jak ich unikać.' },
  { icon: '😌', tytul: 'Mniej stresu, więcej pewności', opis: 'Wchodzisz na egzamin spokojny — masz kontrolę nad materiałem.' },
  { icon: '🚀', tytul: 'Postępy widoczne od razu', opis: 'Dział po dziale widzisz realny progres. Dostajesz też materiały do samodzielnej pracy.' },
  { icon: '💬', tytul: 'Nauka na żywo z pytaniami', opis: 'Natychmiastowe wyjaśnianie trudnych zagadnień. Pytasz o wszystko.' },
  { icon: '🎓', tytul: 'Doświadczenie 13+ lat', opis: 'Ponad 1000 uczniów za mną. Wiem gdzie tracisz punkty i jak to zmienić.' },
];
---

<Layout
  title="14-dniowa powtórka do matury z matematyki (poziom podstawowy)"
  description="14 dni, cały materiał maturalny z matematyki, zajęcia online na żywo + nagrania. Cena 197 zł. Gwarancja satysfakcji!"
  noindex={false}
>
  <main class="lp-page">

    <!-- HERO -->
    <section class="lp-hero">
      <div class="container-content">
        <div class="lp-hero-grid">
          <div class="lp-hero-text">
            <div class="lp-hero-badge">📚 14 DNI · CAŁY MATERIAŁ</div>
            <h1 class="lp-hero-title">
              Przygotuj się do matury z matematyki<br />
              <span class="lp-hero-accent">w 14 dni.</span>
            </h1>
            <p class="lp-hero-sub">
              Pełna powtórka materiału + gwarancja satysfakcji.<br />
              <strong>Bez chaosu. Bez zgadywania. Bez stresu.</strong>
            </p>

            <div class="lp-hero-price">
              <div class="lp-price-amount">197 zł</div>
              <div class="lp-price-note">za 14 dni nauki</div>
            </div>

            <a href={page.purchaseUrl} class="btn-primary lp-cta-btn">
              ZAPISUJĘ SIĘ! →
            </a>
            <p class="lp-cta-note">⏰ Start 15 lutego · ograniczone miejsca</p>
          </div>

          <div class="lp-hero-visual">
            <div class="lp-hero-card">
              <div class="lp-hero-card-num">14</div>
              <div class="lp-hero-card-label">DZIAŁÓW</div>
              <div class="lp-hero-card-bottom">
                <div class="lp-hero-card-stat">
                  <strong>1000+</strong>
                  <span>uczniów</span>
                </div>
                <div class="lp-hero-card-stat">
                  <strong>13 lat</strong>
                  <span>doświadczenia</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="lp-problem">
      <div class="container-content">
        <div class="lp-problem-grid">
          <div class="lp-problem-text">
            <h2 class="lp-section-title">Do matury zostało mniej niż miesiąc,<br /><span class="text-yellow">a Ty nadal czujesz, że jesteś w tyle?</span></h2>
            <ul class="lp-problem-list">
              <li>Zaczynasz czuć panikę bo nie wiesz jak się za to zabrać</li>
              <li>Ilość rzeczy do ogarnięcia Cię przytłacza</li>
              <li>Nie potrzebujesz kolejnych przypominajek ani motywatorów</li>
              <li>Potrzebujesz <strong>jasnego planu</strong> dzięki któremu każdego dnia widzisz realny progres</li>
            </ul>
          </div>
          <div class="lp-problem-image">
            <div class="lp-problem-emoji">😰</div>
          </div>
        </div>
      </div>
    </section>

    <!-- JAK WYGLĄDA POWTÓRKA -->
    <section class="lp-jak">
      <div class="container-content">
        <div class="section-label">JAK TO DZIAŁA</div>
        <h2 class="lp-section-title">Jak wygląda powtórka?</h2>
        <div class="lp-jak-grid">
          <div class="lp-jak-card">
            <div class="lp-jak-icon">📅</div>
            <h3>14 dni, cały materiał</h3>
            <p>Każdy dzień = jeden dział matematyki podstawowej. Krok po kroku.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">🎥</div>
            <h3>Zajęcia online na żywo</h3>
            <p>Codziennie spotykamy się przez Google Meet. Ty wybierasz: aktywnie czy tylko słuchasz.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">📼</div>
            <h3>Nagrania z każdej lekcji</h3>
            <p>Możesz nadrabiać, wracać, powtarzać do skutku. Dostęp przez cały okres kursu.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">📝</div>
            <h3>Zadania maturalne</h3>
            <p>Od jasnego wytłumaczenia teorii do konkretnych zadań egzaminacyjnych.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">💬</div>
            <h3>Możliwość pytań</h3>
            <p>Pytasz na żywo lub mailem — odpowiadam każdemu, bez wyjątku.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">👨‍🏫</div>
            <h3>Prowadzi Olaf Pieprzak</h3>
            <p>13 lat doświadczenia. 1000+ uczniów. Praktyk, który wie gdzie tracisz punkty.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CO ZYSKASZ -->
    <section class="lp-korzysci">
      <div class="container-content">
        <div class="section-label">CO ZYSKASZ?</div>
        <h2 class="lp-section-title">8 powodów, dla których to się opłaca.</h2>
        <div class="lp-korzysci-grid">
          {korzysci.map((k) => (
            <div class="lp-korzysc">
              <div class="lp-korzysc-icon">{k.icon}</div>
              <div>
                <h3 class="lp-korzysc-title">{k.tytul}</h3>
                <p class="lp-korzysc-desc">{k.opis}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- GWARANCJA -->
    <section class="lp-gwarancja">
      <div class="container-content">
        <div class="lp-gwarancja-box">
          <div class="lp-gwarancja-icon">🛡️</div>
          <div class="lp-gwarancja-content">
            <div class="lp-gwarancja-badge">GWARANCJA SATYSFAKCJI</div>
            <h2 class="lp-gwarancja-title">Zwrot 100% pieniędzy. Bez gadania.</h2>
            <p class="lp-gwarancja-text">Jeśli:</p>
            <ul class="lp-gwarancja-list">
              <li>obejrzysz wszystkie nagrania</li>
              <li>rozwiążesz wszystkie zadania i to udokumentujesz (zdjęcie rozwiązań wystarczy)</li>
              <li>a mimo tego nie zdasz matury…</li>
            </ul>
            <div class="lp-gwarancja-final">
              ➡️ <strong>Zwracam Ci 100% pieniędzy.</strong> Bez kruczków. Bez wymówek.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PLAN DNI -->
    <section class="lp-plan">
      <div class="container-content">
        <div class="section-label">PLAN DZIEŃ PO DNIU</div>
        <h2 class="lp-section-title">14 dni · 14 działów · cały materiał</h2>
        <p class="lp-plan-intro">
          Każdy dzień = jeden dział = 4 etapy:<br />
          <strong>1. Teoria</strong> → <strong>2. Praktyka</strong> → <strong>3. Zadania maturalne</strong> → <strong>4. Zadania do samodzielnej pracy</strong>
        </p>

        <div class="lp-plan-list">
          {planDni.map((d) => (
            <details class="lp-plan-item">
              <summary>
                <span class="lp-plan-day">DZIEŃ {d.dzien}</span>
                <span class="lp-plan-tytul">{d.tytul}</span>
                <span class="lp-plan-arrow">▼</span>
              </summary>
              <ul class="lp-plan-zakres">
                {d.zakres.map((z) => <li>{z}</li>)}
              </ul>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- O MNIE -->
    <section class="lp-omnie">
      <div class="container-content">
        <div class="lp-omnie-grid">
          <div class="lp-omnie-image">
            <div class="lp-omnie-emoji">👨‍🏫</div>
            <div class="lp-omnie-stats">
              <div class="lp-omnie-stat"><strong>1000+</strong><span>uczniów</span></div>
              <div class="lp-omnie-stat"><strong>13 lat</strong><span>nauczania</span></div>
            </div>
          </div>
          <div class="lp-omnie-text">
            <div class="section-label">OLAF PIEPRZAK</div>
            <h2 class="lp-section-title">Ogarniemy to! Możesz mi zaufać.</h2>
            <p>
              Uczę matematyki <strong>od 2012 roku</strong> i przez ten czas pomogłem już ponad 1000 uczniom.
              Wszystko zaczęło się od pytań znajomych: "Olaf, mógłbyś mi wytłumaczyć matmę?" i tak zostało do dziś.
            </p>
            <p>
              Stworzyłem <strong>MATHOUSE</strong> bo brakowało miejsca gdzie matematyka byłaby wytłumaczona w prosty,
              czasem wręcz prymitywny sposób. Bez skomplikowanego języka, bez teoretyzowania. Konkretnie i na przykładach.
              Tak, żeby <strong>każdy mógł to zrozumieć</strong>.
            </p>
            <p>
              Podczas powtórki pokażę Ci dokładnie te same metody i triki, których uczę na swoich kursach,
              żebyś mógł je od razu zastosować na sprawdzianach, w codziennej nauce i na maturze.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="lp-final">
      <div class="container-content">
        <div class="lp-final-box">
          <div class="section-label">DOŁĄCZ TERAZ</div>
          <h2 class="lp-final-title">14-dniowa powtórka do matury z matematyki<br /><span class="text-yellow">(poziom podstawowy)</span></h2>

          <div class="lp-final-features">
            <div class="lp-final-feature">✅ Zajęcia na żywo przez 14 dni</div>
            <div class="lp-final-feature">✅ Dostęp do wszystkich nagrań</div>
            <div class="lp-final-feature">✅ Możliwość zadawania pytań</div>
            <div class="lp-final-feature">✅ Materiały do samodzielnej pracy</div>
            <div class="lp-final-feature">🎁 40 zł zwrotu za każdy zapis z Twojego polecenia</div>
            <div class="lp-final-feature">🛡️ Gwarancja satysfakcji 100%</div>
          </div>

          <div class="lp-final-price">
            <div class="lp-final-price-label">CENA</div>
            <div class="lp-final-price-amount">197 zł</div>
            <div class="lp-final-price-compare">to cena ~2h korepetycji. A dostajesz pełen kurs maturalny.</div>
          </div>

          <a href={page.purchaseUrl} class="btn-primary lp-cta-btn lp-cta-final">
            ZAPISUJĘ SIĘ TERAZ →
          </a>

          <p class="lp-final-bottom">
            W 14 dni przejdziemy <strong>cały materiał od A do Z</strong>.<br />
            Od chaosu do kontroli nad materiałem.
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .lp-page { color: #EBEEFF; }
  .text-yellow { color: #FFDE59; }

  /* HERO */
  .lp-hero {
    padding: 60px 0 80px;
    background: linear-gradient(180deg, rgba(255,222,89,0.04) 0%, transparent 100%);
  }
  .lp-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .lp-hero-badge {
    display: inline-block;
    background: rgba(63, 206, 207, 0.1);
    border: 1px solid rgba(63, 206, 207, 0.3);
    color: #3FCECF;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }
  .lp-hero-title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin-bottom: 20px;
  }
  .lp-hero-accent { color: #FFDE59; }
  .lp-hero-sub {
    font-size: 18px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.55;
    margin-bottom: 32px;
  }
  .lp-hero-price {
    display: inline-block;
    background: rgba(255, 222, 89, 0.1);
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 14px;
    padding: 16px 22px;
    margin-bottom: 24px;
  }
  .lp-price-amount {
    font-size: 36px;
    font-weight: 700;
    color: #FFDE59;
    line-height: 1;
  }
  .lp-price-note {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.6);
    margin-top: 4px;
  }
  .lp-cta-btn {
    display: inline-block;
    font-size: 16px;
    padding: 16px 32px;
  }
  .lp-cta-note {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 14px;
  }

  /* Hero visual */
  .lp-hero-card {
    background: linear-gradient(135deg, rgba(255,222,89,0.15) 0%, rgba(63,206,207,0.1) 100%);
    border: 1px solid rgba(255,222,89,0.3);
    border-radius: 24px;
    padding: 36px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .lp-hero-card-num {
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    color: #FFDE59;
    font-family: 'Instrument Serif', serif;
  }
  .lp-hero-card-label {
    font-size: 14px;
    letter-spacing: 4px;
    color: rgba(235, 238, 255, 0.7);
    margin-top: 4px;
    margin-bottom: 32px;
  }
  .lp-hero-card-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    padding-top: 24px;
    border-top: 1px solid rgba(235, 238, 255, 0.1);
  }
  .lp-hero-card-stat strong {
    display: block;
    font-size: 22px;
    color: #3FCECF;
    margin-bottom: 2px;
  }
  .lp-hero-card-stat span {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1px;
  }

  /* PROBLEM */
  .lp-problem {
    padding: 60px 0;
    background: rgba(255, 255, 255, 0.02);
  }
  .lp-problem-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: center;
  }
