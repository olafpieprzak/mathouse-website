  { dzien: 5, tytul: 'Funkcja + funkcja liniowa', zakres: [
    'Dziedzina', 'Zbiór wartości', 'Monotoniczność',
    'Wartość największa i najmniejsza', 'Zadania praktyczne',
    'Znaczenie współczynników', 'Rysowanie wykresu',
