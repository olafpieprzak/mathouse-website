import Layout from '../layouts/Layout.astro';
import { isLandingEnabled, getLandingPage } from '../config/landingPages.js';

const SLUG = 'landing-powtorka-14-dni';
const page = getLandingPage(SLUG);
const enabled = isLandingEnabled(SLUG);

// Jeśli wyłączona — zwracamy 404
if (!enabled) {
  return Astro.redirect('/404');
