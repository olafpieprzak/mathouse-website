---
// =====================================================
// STRONA KALKULATORY (placeholder — wyłączona)
// =====================================================
import Layout from '../layouts/Layout.astro';

const kalkulatoryWkrótce = [
  { icon: 'x²', name: 'Równania wielomianowe' },
  { icon: '%', name: 'Kalkulator kredytowy' },
  { icon: 'ƒ', name: 'Funkcja liniowa' },
  { icon: '△', name: 'Geometria' },
  { icon: '∑', name: 'Ciągi' },
  { icon: '📊', name: 'Statystyka' },
];
---

<Layout
  title="Kalkulatory matematyczne — wkrótce"
  description="Darmowe kalkulatory matematyczne online: równania wielomianowe, kredytowy, funkcja liniowa, geometria, ciągi, statystyka. W przygotowaniu."
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Kalkulatory</span>
    </div>
  </div>

  <section class="placeholder">
    <div class="container-content placeholder-inner">
      <div class="placeholder-icon-big">
        <i class="ti ti-calculator"></i>
      </div>

      <span class="tag-yellow">🚧 STRONA W PRZYGOTOWANIU</span>

      <h1 class="placeholder-title">
        Kalkulatory <span class="text-yellow">w drodze</span>
      </h1>

      <p class="placeholder-desc">
        Buduję teraz darmowe kalkulatory matematyczne. Pierwsze będą:
        <strong>kalkulator kredytowy</strong> i <strong>rozwiązywanie równań wielomianowych</strong>.
        Dodawane będą stopniowo — jeden po drugim, gdy każdy zostanie dopracowany.
      </p>

      <form class="notify-form" action="https://formspree.io/f/PLACEHOLDER" method="POST">
        <input type="email" name="email" placeholder="twoj@email.pl" required class="notify-input" />
        <button type="submit" class="btn-primary notify-btn">Powiadom mnie →</button>
      </form>

      <p class="notify-note">Dam Ci znać, gdy pierwszy kalkulator będzie gotowy.</p>

      <div class="kalk-soon-grid">
        {kalkulatoryWkrótce.map((k) => (
          <div class="kalk-soon-tile">
            <span class="kalk-soon-icon">{k.icon}</span>
            <div class="kalk-soon-name">{k.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  .tag-yellow {
    display: inline-block;
    background: rgba(255, 222, 89, 0.15);
    color: #FFDE59;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    border: 1px solid rgba(255, 222, 89, 0.3);
  }

  .placeholder {
    padding: 80px 0;
    min-height: 60vh;
  }
  .placeholder-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .placeholder-icon-big {
    width: 90px;
    height: 90px;
    background: rgba(255, 222, 89, 0.1);
    border: 1px dashed rgba(255, 222, 89, 0.4);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
  }
  .placeholder-icon-big i {
    font-size: 40px;
    color: #FFDE59;
  }
  .placeholder-title {
    font-size: 42px;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -1.2px;
    margin: 18px 0 14px;
  }
  .placeholder-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    max-width: 520px;
    margin: 0 auto 24px;
    line-height: 1.7;
  }
  .placeholder-desc strong {
    color: #EBEEFF;
  }

  .notify-form {
    display: flex;
    gap: 8px;
    align-items: center;
    max-width: 420px;
    width: 100%;
    margin-top: 8px;
  }
  .notify-input {
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(235, 238, 255, 0.15);
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    color: #EBEEFF;
    font-family: 'Montserrat', sans-serif;
  }
  .notify-input:focus {
    outline: none;
    border-color: rgba(255, 222, 89, 0.4);
  }
  .notify-btn {
    white-space: nowrap;
    border: none;
    cursor: pointer;
    font-family: 'Montserrat', sans-serif;
  }
  .notify-note {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 14px;
    max-width: 420px;
  }

  .kalk-soon-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    max-width: 600px;
    width: 100%;
  }
  .kalk-soon-tile {
    background: rgba(255, 255, 255, 0.04);
    border: 1px dashed rgba(235, 238, 255, 0.1);
    border-radius: 10px;
    padding: 14px;
    text-align: center;
    opacity: 0.6;
  }
  .kalk-soon-icon {
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    color: rgba(235, 238, 255, 0.5);
    display: block;
  }
  .kalk-soon-name {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.65);
    margin-top: 8px;
  }

  @media (max-width: 640px) {
    .placeholder {
      padding: 48px 0;
    }
    .placeholder-title {
      font-size: 32px;
    }
    .notify-form {
      flex-direction: column;
    }
    .notify-input,
    .notify-btn {
      width: 100%;
      text-align: center;
    }
    .kalk-soon-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
