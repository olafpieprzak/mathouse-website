---
// =====================================================
// STRONA KALKULATORY
// =====================================================
import Layout from '../layouts/Layout.astro';

// Pierwszy kalkulator aktywny: równania wielomianowe
// Pozostałe — placeholdery, dorobimy z czasem
const kalkulatory = [
  {
    icon: 'x²',
    name: 'Równania wielomianowe',
    desc: 'Stopnie 2-12, metoda Hornera + delta, pierwiastki rzeczywiste i zespolone',
    href: '/kalkulatory/rownanie-wielomianowe',
    live: true,
    badge: 'NOWE',
  },
  { icon: '%',  name: 'Kalkulator kredytowy',   desc: 'Rata, oprocentowanie, nadpłaty, kapitał, harmonogram', href: null, live: false },
  { icon: 'ƒ',  name: 'Funkcja liniowa',        desc: 'Wzór z dwóch punktów, miejsce zerowe, prostopadłość',   href: null, live: false },
  { icon: '△',  name: 'Geometria',              desc: 'Pola, obwody, twierdzenie Pitagorasa, kąty trójkąta',    href: null, live: false },
  { icon: '∑',  name: 'Ciągi',                  desc: 'Arytmetyczne, geometryczne, n-ty wyraz, suma',           href: null, live: false },
  { icon: '📊', name: 'Statystyka',             desc: 'Średnia, mediana, dominanta, wariancja, odchylenie',     href: null, live: false },
];
const liczbaLive = kalkulatory.filter(k => k.live).length;
---

<Layout
  title="Kalkulatory matematyczne online — MATHOUSE"
  description="Darmowe kalkulatory matematyczne online: równania wielomianowe (stopień 2-12), kalkulator kredytowy, funkcja liniowa, geometria, ciągi, statystyka. Pierwsze już dostępne!"
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Kalkulatory</span>
    </div>
  </div>

  <section class="kalk-page">
    <div class="container-content">

      <div class="kalk-hero-text">
        <div class="section-label">⚙️ KALKULATORY MATHOUSE</div>
        <h1 class="kalk-page-title">
          Darmowe kalkulatory<br /><span class="text-yellow">matematyczne online.</span>
        </h1>
        <p class="kalk-page-sub">
          Liczę za Ciebie — krok po kroku, z pełnym rozwiązaniem.
          Pierwszy kalkulator (<strong>równania wielomianowe</strong>) jest już aktywny.
          Reszta dochodzi stopniowo. <strong>{liczbaLive} aktywny · {kalkulatory.length - liczbaLive} w przygotowaniu</strong>.
        </p>
      </div>

      <div class="kalk-grid">
        {kalkulatory.map((k) => (
          k.live ? (
            <a href={k.href} class="kalk-tile kalk-tile-live">
              {k.badge && <span class="kalk-tile-badge">{k.badge}</span>}
              <div class="kalk-tile-icon">{k.icon}</div>
              <div class="kalk-tile-name">{k.name}</div>
              <div class="kalk-tile-desc">{k.desc}</div>
              <div class="kalk-tile-cta">Otwórz kalkulator →</div>
            </a>
          ) : (
            <div class="kalk-tile kalk-tile-soon">
              <span class="kalk-tile-badge-soon">⏳ Wkrótce</span>
              <div class="kalk-tile-icon">{k.icon}</div>
              <div class="kalk-tile-name">{k.name}</div>
              <div class="kalk-tile-desc">{k.desc}</div>
            </div>
          )
        ))}
      </div>

      <div class="kalk-notify-box">
        <div>
          <strong>Powiadom mnie, gdy będą gotowe kolejne kalkulatory:</strong>
          <p class="kalk-notify-sub">Zero spamu. Tylko info o nowych narzędziach.</p>
        </div>
        <form class="notify-form" action="https://formspree.io/f/PLACEHOLDER" method="POST">
          <input type="email" name="email" placeholder="twoj@email.pl" required class="notify-input" />
          <button type="submit" class="btn-primary notify-btn">Powiadom mnie →</button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  .kalk-page { padding: 48px 0 80px; }

  .kalk-hero-text {
    text-align: center;
    margin-bottom: 44px;
  }
  .kalk-page-title {
    font-size: 44px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin: 12px 0 16px;
  }
  .kalk-page-sub {
    font-size: 15px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.65;
    max-width: 640px;
    margin: 0 auto;
  }
  .kalk-page-sub strong { color: #EBEEFF; }

  .kalk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 14px;
    margin-bottom: 48px;
  }
  .kalk-tile {
    position: relative;
    display: block;
    padding: 24px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: all 0.18s ease;
  }
  .kalk-tile-live {
    background: rgba(255, 222, 89, 0.06);
    border-color: rgba(255, 222, 89, 0.35);
    cursor: pointer;
  }
  .kalk-tile-live:hover {
    border-color: #FFDE59;
    background: rgba(255, 222, 89, 0.12);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(255, 222, 89, 0.2);
  }
  .kalk-tile-soon {
    opacity: 0.6;
  }
  .kalk-tile-badge {
    position: absolute;
    top: 12px;
    right: 14px;
    background: #FFDE59;
    color: #050A24;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .kalk-tile-badge-soon {
    position: absolute;
    top: 12px;
    right: 14px;
    background: rgba(235, 238, 255, 0.1);
    color: rgba(235, 238, 255, 0.7);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 600;
  }
  .kalk-tile-icon {
    font-size: 36px;
    margin-bottom: 14px;
    line-height: 1;
    color: #3FCECF;
    font-weight: 700;
  }
  .kalk-tile-live .kalk-tile-icon {
    color: #FFDE59;
  }
  .kalk-tile-name {
    font-size: 17px;
    font-weight: 700;
    color: #EBEEFF;
    margin-bottom: 6px;
  }
  .kalk-tile-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.6);
    line-height: 1.5;
    margin-bottom: 14px;
  }
  .kalk-tile-cta {
    font-size: 12px;
    color: #FFDE59;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .kalk-notify-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .kalk-notify-box strong {
    font-size: 16px;
    color: #EBEEFF;
    font-weight: 700;
  }
  .kalk-notify-sub {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.6);
    margin-top: 4px;
  }
  .notify-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .notify-input {
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid rgba(235, 238, 255, 0.15);
    background: rgba(5, 10, 36, 0.5);
    color: #EBEEFF;
    font-size: 13px;
    min-width: 220px;
    font-family: inherit;
  }
  .notify-input::placeholder { color: rgba(235, 238, 255, 0.4); }
  .notify-btn { font-size: 13px; padding: 12px 20px; }

  @media (max-width: 640px) {
    .kalk-page-title { font-size: 30px; }
    .kalk-notify-box { flex-direction: column; align-items: stretch; }
    .notify-form { flex-direction: column; }
    .notify-input { min-width: 0; width: 100%; }
  }
</style>
