---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Pobierz wszystkie artykuły (pomiń drafty)
const wszystkieArtykuly = await getCollection('blog', ({ data }) => !data.draft);

// Sortuj od najnowszych
const artykuly = wszystkieArtykuly.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const featured = artykuly.find(a => a.data.featured);
const reszta = featured ? artykuly.filter(a => a.id !== featured.id) : artykuly;

const KATEGORIE = {
  'matma-biznes': { label: 'Matma w biznesie', color: '#FFDE59' },
  'inwestowanie': { label: 'Inwestowanie', color: '#2ECC71' },
  'rozwoj-osobisty': { label: 'Rozwój osobisty', color: '#3FCECF' },
  'matma-praktyczna': { label: 'Matma praktyczna', color: '#FF9F43' },
  'matura': { label: 'Matura', color: '#E74C3C' },
  'inne': { label: 'Inne', color: '#888' },
};

function formatDate(date) {
  return new Date(date).toLocaleDateString('pl-PL', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}
---

<Layout
  title="Matma w praktyce — blog MATHOUSE"
  description="Matematyka w biznesie, inwestowaniu i rozwoju osobistym. Praktyczne zastosowania matematyki, których nie nauczą Cię w szkole. Olaf Pieprzak, MATHOUSE."
>
  <main class="blog-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">←&nbsp;Strona główna</a> / <span>Matma w praktyce</span>
      </div>

      <!-- HERO -->
      <section class="blog-hero">
        <div class="section-label">📐 BLOG MATHOUSE</div>
        <h1 class="blog-title">
          Matma w <span class="text-yellow">praktyce</span>.
        </h1>
        <p class="blog-desc">
          Matematyka w biznesie, inwestowaniu i rozwoju osobistym. Pokazuję jak
          wzory ze szkoły działają w prawdziwym świecie — i jak wykorzystać je
          do podejmowania lepszych decyzji.
        </p>
        <div class="blog-meta-bar">
          <span class="blog-meta-stat"><strong>{artykuly.length}</strong> {artykuly.length === 1 ? 'artykuł' : artykuly.length < 5 ? 'artykuły' : 'artykułów'}</span>
          <span class="blog-meta-sep">·</span>
          <span class="blog-meta-stat">Nowe materiały co tydzień</span>
        </div>
      </section>

      {featured && (
        <!-- ARTYKUŁ WYRÓŻNIONY -->
        <section class="blog-featured">
          <a href={`/wiedza/${featured.slug}`} class="featured-card">
            <div class="featured-emoji">{featured.data.coverEmoji || '📐'}</div>
            <div class="featured-content">
              <span class="featured-badge">⭐ POLECANE</span>
              <span class="featured-category" style={`color: ${KATEGORIE[featured.data.category]?.color || '#888'}`}>
                {KATEGORIE[featured.data.category]?.label || 'Inne'}
              </span>
              <h2 class="featured-title">{featured.data.title}</h2>
              <p class="featured-desc">{featured.data.description}</p>
              <div class="featured-meta">
                <span>{formatDate(featured.data.date)}</span>
                {featured.data.readTime && <><span>·</span><span>{featured.data.readTime} min czytania</span></>}
                <span>·</span>
                <span>{featured.data.author}</span>
              </div>
              <span class="featured-cta">Czytaj artykuł →</span>
            </div>
          </a>
        </section>
      )}

      {reszta.length > 0 && (
        <section class="blog-grid-section">
          <h2 class="section-title-blog">Wszystkie artykuły</h2>
          <div class="blog-grid">
            {reszta.map((a) => {
              const kat = KATEGORIE[a.data.category] || KATEGORIE.inne;
              return (
                <a href={`/wiedza/${a.slug}`} class="blog-card">
                  <div class="blog-card-emoji">{a.data.coverEmoji || '📐'}</div>
                  <span class="blog-card-category" style={`color: ${kat.color}`}>
                    {kat.label}
                  </span>
                  <h3 class="blog-card-title">{a.data.title}</h3>
                  <p class="blog-card-desc">{a.data.description}</p>
                  <div class="blog-card-meta">
                    <span>{formatDate(a.data.date)}</span>
                    {a.data.readTime && <><span>·</span><span>{a.data.readTime} min</span></>}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {artykuly.length === 0 && (
        <section class="blog-empty">
          <div class="blog-empty-icon">📝</div>
          <h2>Pierwsze artykuły już wkrótce</h2>
          <p>Pracuję nad treściami. Wróć za chwilę albo zostaw email — dam znać gdy ruszę.</p>
          <a href="/kontakt" class="btn-primary">📩 Powiadom mnie</a>
        </section>
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-page { padding: 20px 0 80px; }
  .breadcrumb { padding: 14px 0 24px; font-size: 11px; color: rgba(235, 238, 255, 0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  .blog-hero { padding: 28px 0 40px; max-width: 760px; }
  .section-label {
    font-size: 11px;
    color: #3FCECF;
    letter-spacing: 1px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .blog-title {
    font-size: 48px;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -1.4px;
    margin-bottom: 16px;
  }
  .blog-desc {
    font-size: 16px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.65;
    margin-bottom: 18px;
  }
  .blog-meta-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 13px;
    color: rgba(235, 238, 255, 0.55);
  }
  .blog-meta-stat strong { color: #FFDE59; font-weight: 700; }
  .blog-meta-sep { color: rgba(235, 238, 255, 0.3); }

  /* ARTYKUŁ WYRÓŻNIONY */
  .blog-featured { margin: 32px 0 48px; }
  .featured-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 28px;
    padding: 32px;
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.04));
    border: 1px solid rgba(255, 222, 89, 0.25);
    border-radius: 18px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }
  .featured-card:hover {
    border-color: rgba(255, 222, 89, 0.5);
    transform: translateY(-3px);
  }
  .featured-emoji {
    font-size: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 222, 89, 0.06);
    border-radius: 14px;
    aspect-ratio: 1;
  }
  .featured-content { display: flex; flex-direction: column; }
  .featured-badge {
    display: inline-block;
    background: #FFDE59;
    color: #050A24;
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 6px;
    letter-spacing: 0.5px;
    width: fit-content;
    margin-bottom: 12px;
  }
  .featured-category {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .featured-title {
    font-size: 26px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 10px;
    color: #EBEEFF;
  }
  .featured-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .featured-meta {
    display: flex;
    gap: 8px;
    font-size: 12px;
    color: rgba(235, 238, 255, 0.5);
    margin-bottom: 16px;
  }
  .featured-cta {
    color: #FFDE59;
    font-weight: 700;
    font-size: 14px;
    margin-top: auto;
  }

  /* GRID ARTYKUŁÓW */
  .blog-grid-section { margin-top: 16px; }
  .section-title-blog {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #EBEEFF;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 22px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: all 0.18s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 222, 89, 0.3);
    background: rgba(255, 222, 89, 0.03);
  }
  .blog-card-emoji {
    font-size: 42px;
    margin-bottom: 14px;
    line-height: 1;
  }
  .blog-card-category {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .blog-card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: #EBEEFF;
  }
  .blog-card-desc {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
    margin-bottom: 14px;
    flex: 1;
  }
  .blog-card-meta {
    display: flex;
    gap: 6px;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.45);
  }

  .blog-empty {
    text-align: center;
    padding: 80px 20px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
  }
  .blog-empty-icon { font-size: 64px; margin-bottom: 16px; }
  .blog-empty h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
  .blog-empty p { font-size: 14px; color: rgba(235, 238, 255, 0.65); margin-bottom: 22px; }

  @media (max-width: 900px) {
    .blog-title { font-size: 36px; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-emoji { aspect-ratio: 3/2; font-size: 72px; }
    .blog-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
