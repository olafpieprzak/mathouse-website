---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const artykuly = await getCollection('blog', ({ data }) => !data.draft);
  return artykuly.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const KATEGORIE = {
  'matma-biznes': { label: 'Matma w biznesie', color: '#FFDE59' },
  'inwestowanie': { label: 'Inwestowanie', color: '#2ECC71' },
  'rozwoj-osobisty': { label: 'Rozwój osobisty', color: '#3FCECF' },
  'matma-praktyczna': { label: 'Matma praktyczna', color: '#FF9F43' },
  'matura': { label: 'Matura', color: '#E74C3C' },
  'inne': { label: 'Inne', color: '#888' },
};

const kat = KATEGORIE[post.data.category] || KATEGORIE.inne;

function formatDate(date) {
  return new Date(date).toLocaleDateString('pl-PL', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

// Pobierz inne artykuły dla sekcji "Czytaj też"
const wszystkie = await getCollection('blog', ({ data }) => !data.draft);
const inne = wszystkie
  .filter(a => a.slug !== post.slug)
  .sort((a,b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);
---

<Layout
  title={`${post.data.title} — MATHOUSE`}
  description={post.data.description}
>
  <!-- KaTeX CSS - wzory matematyczne (~24 KB, ładuje się tylko na artykułach) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" slot="head" />

  <main class="article-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">←&nbsp;Strona główna</a> /
        <a href="/wiedza">Matma w praktyce</a> /
        <span>{post.data.title}</span>
      </div>

      <article class="article">
        <header class="article-header">
          <div class="article-emoji-wrap">
            <div class="article-emoji">{post.data.coverEmoji || '📐'}</div>
          </div>
          <span class="article-category" style={`color: ${kat.color}; border-color: ${kat.color}40;`}>
            {kat.label}
          </span>
          <h1 class="article-title">{post.data.title}</h1>
          <p class="article-lead">{post.data.description}</p>
          <div class="article-meta">
            <span class="meta-author">👤 {post.data.author}</span>
            <span class="meta-sep">·</span>
            <span>📅 {formatDate(post.data.date)}</span>
            {post.data.readTime && <>
              <span class="meta-sep">·</span>
              <span>⏱️ {post.data.readTime} min czytania</span>
            </>}
          </div>
        </header>

        <div class="article-content">
          <Content />
        </div>

        <footer class="article-footer">
          <div class="article-cta">
            <h3 class="article-cta-title">Podobało się?</h3>
            <p class="article-cta-text">
              Jeśli ten artykuł Ci pomógł, sprawdź też moje <strong>kursy wideo z matematyki</strong> —
              tłumaczę matmę tak, żebyś nareszcie zrozumiał, dlaczego liczby działają tak jak działają.
            </p>
            <div class="article-cta-buttons">
              <a href="/kursy" class="btn-primary">Zobacz kursy →</a>
              <a href="/darmowa-lekcja" class="btn-teal">▶ Darmowa lekcja</a>
            </div>
          </div>
        </footer>
      </article>

      {inne.length > 0 && (
        <section class="article-related">
          <h2 class="related-title">Czytaj też</h2>
          <div class="related-grid">
            {inne.map((a) => {
              const k = KATEGORIE[a.data.category] || KATEGORIE.inne;
              return (
                <a href={`/wiedza/${a.slug}`} class="related-card">
                  <div class="related-emoji">{a.data.coverEmoji || '📐'}</div>
                  <span class="related-category" style={`color: ${k.color}`}>{k.label}</span>
                  <h3 class="related-card-title">{a.data.title}</h3>
                  <span class="related-cta">Czytaj →</span>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>

<style>
  .article-page { padding: 20px 0 80px; }
  .breadcrumb { padding: 14px 0 24px; font-size: 11px; color: rgba(235, 238, 255, 0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb > span { color: #FFDE59; }

  .article { max-width: 720px; margin: 0 auto; }

  .article-header {
    text-align: center;
    padding: 20px 0 40px;
    border-bottom: 1px solid rgba(235, 238, 255, 0.08);
    margin-bottom: 40px;
  }
  .article-emoji-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }
  .article-emoji {
    font-size: 80px;
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.1), rgba(63, 206, 207, 0.05));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 24px;
    width: 140px;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .article-category {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid;
    margin-bottom: 16px;
  }
  .article-title {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 16px;
    color: #EBEEFF;
  }
  .article-lead {
    font-size: 17px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.6;
    max-width: 620px;
    margin: 0 auto 24px;
  }
  .article-meta {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 13px;
    color: rgba(235, 238, 255, 0.55);
  }
  .meta-author { color: #FFDE59; font-weight: 600; }
  .meta-sep { color: rgba(235, 238, 255, 0.3); }

  /* TYPOGRAFIA ARTYKUŁU */
  .article-content { font-size: 16px; line-height: 1.75; color: rgba(235, 238, 255, 0.85); }
  .article-content :global(h2) {
    font-size: 24px;
    font-weight: 700;
    margin: 40px 0 14px;
    color: #FFDE59;
    line-height: 1.3;
  }
  .article-content :global(h3) {
    font-size: 19px;
    font-weight: 700;
    margin: 28px 0 10px;
    color: #EBEEFF;
  }
  .article-content :global(p) { margin-bottom: 18px; }
  .article-content :global(strong) { color: #EBEEFF; font-weight: 700; }
  .article-content :global(em) { color: rgba(235, 238, 255, 0.95); }
  .article-content :global(ul), .article-content :global(ol) {
    margin: 0 0 18px;
    padding-left: 26px;
  }
  .article-content :global(li) { margin-bottom: 8px; }
  .article-content :global(blockquote) {
    margin: 22px 0;
    padding: 16px 20px;
    background: rgba(255, 222, 89, 0.06);
    border-left: 4px solid #FFDE59;
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: rgba(235, 238, 255, 0.9);
  }
  .article-content :global(code) {
    background: rgba(63, 206, 207, 0.12);
    color: #3FCECF;
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.92em;
  }
  .article-content :global(a) {
    color: #3FCECF;
    text-decoration: underline;
    text-decoration-color: rgba(63, 206, 207, 0.4);
  }
  .article-content :global(a:hover) {
    color: #FFDE59;
    text-decoration-color: #FFDE59;
  }
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    margin: 36px 0;
  }
  /* MathJax / wzory LaTeX - prosty fallback */
  .article-content :global(.math) {
    display: block;
    text-align: center;
    padding: 14px;
    background: rgba(63, 206, 207, 0.06);
    border-radius: 8px;
    margin: 20px 0;
    font-family: 'Courier New', monospace;
    font-size: 17px;
    color: #FFDE59;
  }

  /* CTA pod artykułem */
  .article-footer { margin-top: 56px; }
  .article-cta {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.1), rgba(63, 206, 207, 0.05));
    border: 1px solid rgba(255, 222, 89, 0.25);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .article-cta-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #FFDE59;
  }
  .article-cta-text {
    font-size: 15px;
    color: rgba(235, 238, 255, 0.78);
    line-height: 1.6;
    margin-bottom: 22px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }
  .article-cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RELATED */
  .article-related {
    max-width: 1100px;
    margin: 80px auto 0;
  }
  .related-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
    text-align: center;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .related-card {
    padding: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: all 0.18s ease;
  }
  .related-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 222, 89, 0.3);
  }
  .related-emoji { font-size: 32px; margin-bottom: 10px; }
  .related-category {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .related-card-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: #EBEEFF;
    flex: 1;
  }
  .related-cta {
    font-size: 12px;
    color: #FFDE59;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .article-title { font-size: 30px; }
    .article-emoji { width: 110px; height: 110px; font-size: 60px; }
    .related-grid { grid-template-columns: 1fr; }
    .article-cta { padding: 28px 20px; }
  }
</style>
