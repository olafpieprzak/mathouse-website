---
// =====================================================
// POJEDYNCZY KURS — Logarytmy (przykład)
// =====================================================
// Aby dodać kolejny kurs, skopiuj ten plik i zmień:
// 1. nazwa pliku (np. funkcja-liniowa.astro)
// 2. title, dane kursu, listę lekcji
// =====================================================
import Layout from '../../layouts/Layout.astro';

const kurs = {
  num: '1.5',
  klasa: 'klasa 1 liceum',
  name: 'Logarytmy',
  desc: 'Cały dział logarytmów w jednym kursie wideo. Od definicji po trudne zadania maturalne. Tłumaczę aż zrozumiesz.',
  price: 197,
  priceOld: 399,
  duration: '~4 godz wideo',
  freeLectureTitle: '"Czym jest logarytm"',
  freeLectureLength: '8:32',
};

const lekcje = [
  { num: '01', name: 'Czym jest logarytm', time: '8:32', free: true },
  { num: '02', name: 'Własności logarytmów', time: '12:18' },
  { num: '03', name: 'Zmiana podstawy', time: '9:45' },
  { num: '04', name: 'Równania logarytmiczne', time: '18:30' },
  { num: '05', name: 'Nierówności logarytmiczne', time: '15:22' },
  { num: '06–08', name: 'Zadania maturalne (3 lekcje)', time: '~45 min' },
];
---

<Layout
  title={`${kurs.num} ${kurs.name} — kurs wideo`}
  description={`Kurs wideo z logarytmów do klasy 1 liceum. ${lekcje.length} lekcji wideo, ${kurs.duration}, dostęp na zawsze. Pierwsza lekcja gratis. Cena: ${kurs.price} zł.`}
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <a href="/kursy">Kursy</a> / <span>{kurs.num} {kurs.name}</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="kurs-hero">
    <div class="container-content kurs-hero-grid">
      <div>
        <div class="section-label">DZIAŁ {kurs.num} · {kurs.klasa.toUpperCase()}</div>
        <h1 class="kurs-title">{kurs.name}<span class="text-yellow">.</span></h1>
        <p class="kurs-desc">
          {kurs.desc.split('Tłumaczę aż zrozumiesz.')[0]}
          <strong>Tłumaczę aż zrozumiesz.</strong>
        </p>

        <div class="kurs-meta">
          <div>
            <div class="kurs-meta-label">Cena</div>
            <div class="kurs-price-row">
              <span class="kurs-price">{kurs.price} zł</span>
              <span class="kurs-price-old">{kurs.priceOld} zł</span>
            </div>
          </div>
          <div class="kurs-meta-sep"></div>
          <div>
            <div class="kurs-meta-label">Długość</div>
            <div class="kurs-meta-val">{kurs.duration}</div>
          </div>
          <div class="kurs-meta-sep"></div>
          <div>
            <div class="kurs-meta-label">Dostęp</div>
            <div class="kurs-meta-val">bezterminowy</div>
          </div>
        </div>

        <div class="kurs-cta">
          <a href="#kup" class="btn-primary">Kup kurs · {kurs.price} zł</a>
          <a href="#wideo-gratis" class="btn-teal">▶ Obejrzyj lekcję gratis</a>
        </div>
        <p class="kurs-tip">
          💡 Lub kup pakiet klasy 1 (wszystkie 12 działów) za <strong class="text-yellow">597 zł</strong>
        </p>
      </div>

      <div id="wideo-gratis" class="kurs-video">
        <div class="kurs-video-bg"></div>
        <div class="kurs-video-frame">
          <button class="kurs-play">▶</button>
          <span class="kurs-video-badge">LEKCJA GRATIS</span>
          <span class="kurs-video-time">{kurs.freeLectureTitle} · {kurs.freeLectureLength}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CO ZNAJDZIESZ -->
  <section class="kurs-lekcje">
    <div class="container-content kurs-lekcje-grid">
      <div>
        <div class="section-label">CO ZNAJDZIESZ W KURSIE</div>
        <h2 class="lekcje-title">{lekcje.length} lekcji wideo + zadania + ściąga.</h2>
      </div>
      <div class="lekcje-list">
        {lekcje.map((l) => (
          <div class="lekcja-row">
            <span>
              <span class="lekcja-num">{l.num} ·</span> {l.name}
              {l.free && <span class="lekcja-free">GRATIS</span>}
            </span>
            <span class="lekcja-time">{l.time}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- UPSELL: pakiet -->
  <section id="kup" class="kurs-upsell">
    <div class="container-content kurs-upsell-inner">
      <div>
        <div class="upsell-eyebrow">⭐ ALTERNATYWA</div>
        <h3 class="upsell-h">Weź cały pakiet klasy 1 — wszystkie 12 działów za 597 zł.</h3>
        <p class="upsell-d">Zamiast 12 × 197 zł = 2364 zł, oszczędzasz <strong>1767 zł</strong>.</p>
      </div>
      <a href="/kursy" class="upsell-cta">Pokaż pakiet →</a>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  /* HERO */
  .kurs-hero {
    padding: 48px 0;
  }
  .kurs-hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
    align-items: center;
  }
  .kurs-title {
    font-size: 50px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -1.8px;
    margin-bottom: 16px;
  }
  .kurs-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.65;
    margin-bottom: 20px;
    max-width: 420px;
  }
  .kurs-desc strong {
    color: #EBEEFF;
  }
  .kurs-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .kurs-meta-label {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
  }
  .kurs-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .kurs-price {
    font-size: 22px;
    font-weight: 600;
    color: #FFDE59;
  }
  .kurs-price-old {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.5);
    text-decoration: line-through;
  }
  .kurs-meta-val {
    font-size: 15px;
    font-weight: 600;
  }
  .kurs-meta-sep {
    width: 1px;
    background: rgba(235, 238, 255, 0.1);
  }
  .kurs-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .btn-teal {
    display: inline-block;
    border: 1px solid rgba(63, 206, 207, 0.5);
    color: #3FCECF;
    padding: 11px 22px;
    border-radius: 7px;
    font-size: 13px;
    text-decoration: none;
  }
  .kurs-tip {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 14px;
  }

  /* Wideo */
  .kurs-video {
    position: relative;
  }
  .kurs-video-bg {
    position: absolute;
    inset: 0;
    background: #3FCECF;
    border-radius: 16px;
    transform: rotate(-3deg);
  }
  .kurs-video-frame {
    position: relative;
    background: #000;
    border-radius: 16px;
    aspect-ratio: 16/10;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(235, 238, 255, 0.1);
  }
  .kurs-play {
    width: 68px;
    height: 68px;
    background: #FFDE59;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #050A24;
    font-size: 24px;
    border: none;
    cursor: pointer;
  }
  .kurs-video-badge {
    position: absolute;
    top: 14px;
    right: 16px;
    background: rgba(255, 222, 89, 0.95);
    color: #050A24;
    padding: 5px 11px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
  }
  .kurs-video-time {
    position: absolute;
    bottom: 14px;
    left: 18px;
    color: #EBEEFF;
    font-size: 12px;
  }

  /* LEKCJE */
  .kurs-lekcje {
    padding: 32px 0;
    background: rgba(63, 206, 207, 0.05);
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    border-bottom: 1px solid rgba(235, 238, 255, 0.1);
  }
  .kurs-lekcje-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 36px;
  }
  .lekcje-title {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .lekcje-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .lekcja-row {
    display: flex;
    justify-content: space-between;
    padding: 11px 14px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    font-size: 13px;
  }
  .lekcja-num {
    color: rgba(235, 238, 255, 0.5);
  }
  .lekcja-time {
    color: rgba(235, 238, 255, 0.5);
  }
  .lekcja-free {
    color: #3FCECF;
    font-size: 10px;
    background: rgba(63, 206, 207, 0.15);
    padding: 2px 8px;
    border-radius: 5px;
    margin-left: 6px;
  }

  /* UPSELL */
  .kurs-upsell {
    background: #FFDE59;
    color: #050A24;
    padding: 30px 0;
  }
  .kurs-upsell-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .upsell-eyebrow {
    font-size: 11px;
    letter-spacing: 2px;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .upsell-h {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
  }
  .upsell-d {
    font-size: 12px;
    opacity: 0.7;
    margin-top: 4px;
  }
  .upsell-cta {
    background: #050A24;
    color: #FFDE59;
    padding: 13px 24px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .kurs-hero-grid,
    .kurs-lekcje-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
  @media (max-width: 640px) {
    .kurs-title {
      font-size: 36px;
    }
    .lekcje-title {
      font-size: 20px;
    }
    .kurs-upsell-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .upsell-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
