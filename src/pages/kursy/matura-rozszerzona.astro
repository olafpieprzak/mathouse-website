---
import Layout from '../../layouts/Layout.astro';

const obszary = [
  'Funkcja kwadratowa — rozszerzenie',
  'Wielomiany — rozszerzenie',
  'Geometria zaawansowana',
  'Trygonometria — rozszerzenie',
  'Dowody matematyczne',
  'Ciągi rekurencyjne',
  'Rachunek różniczkowy — wstęp',
  'Granice funkcji',
];
---

<Layout title="Matura rozszerzona — kursy matematyki" description="Przygotowanie do matury rozszerzonej z matematyki. Zaawansowane działy + powtórka podstawy. Wkrótce.">
  <main class="hub-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <span>Matura rozszerzona</span>
      </div>

      <section class="hub-hero">
        <div class="section-label">🔬 MATURA ROZSZERZONA</div>
        <h1 class="hub-title">Matura rozszerzona<br /><span class="text-yellow">z matematyki</span></h1>
        <p class="hub-sub">
          Wszystko z podstawy + dodatki rozszerzenia. <strong>Wkrótce</strong> — buduję materiały.
        </p>
        <div class="hub-actions">
          <a href="/kursy/matura-podstawowa" class="btn-secondary">📕 Najpierw podstawa</a>
          <a href="/arkusze#matura-rozszerzona" class="btn-secondary">📄 Arkusze CKE</a>
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ W PRZYGOTOWANIU</span>
            <h2 class="klasa-title">Zaawansowane działy</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {obszary.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="hub-final">
        <div class="hub-final-box">
          <h2>Potrzebujesz pomocy z rozszerzeniem?</h2>
          <p>Wybierz najlepszą opcję dla siebie:</p>
          <div class="hub-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hub-page { color: #EBEEFF; padding: 0 0 60px; }
  .text-yellow { color: #FFDE59; }
  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  .hub-hero { padding: 30px 0 50px; }
  .hub-title { font-size: 42px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; }
  .hub-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; max-width: 580px; line-height: 1.55; }
  .hub-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .klasa-section { margin-bottom: 36px; }
  .klasa-tag { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 10px; font-weight: 700; letter-spacing: 1px; margin-bottom: 6px; }
  .tag-soon { background: rgba(235, 238, 255, 0.06); color: rgba(235, 238, 255, 0.5); }
  .klasa-title { font-size: 22px; font-weight: 700; margin: 0; }
  .klasa-header { margin-bottom: 16px; }

  .dzialy-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .dzial-card {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    padding: 16px;
    min-height: 80px;
    opacity: 0.55;
    display: flex;
    align-items: center;
  }
  .dzial-name {
    font-size: 13px;
    font-weight: 600;
    color: #EBEEFF;
    line-height: 1.4;
  }

  .hub-final-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .hub-final-box h2 { font-size: 24px; font-weight: 700; margin: 0 0 8px; }
  .hub-final-box p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin: 0 0 20px; }
  .hub-final-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hub-title { font-size: 30px; }
    .dzialy-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .dzialy-grid { grid-template-columns: 1fr; }
  }
</style>
