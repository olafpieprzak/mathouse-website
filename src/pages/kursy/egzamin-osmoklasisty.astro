---
import Layout from '../../layouts/Layout.astro';

const dzialyOK = [
  '1. Liczby naturalne i całkowite',
  '2. Ułamki zwykłe i dziesiętne',
  '3. Procenty',
  '4. Wyrażenia algebraiczne',
  '5. Równania pierwszego stopnia',
  '6. Proporcjonalność',
  '7. Geometria płaska',
  '8. Geometria przestrzenna',
  '9. Statystyka i prawdopodobieństwo',
];
---

<Layout title="Egzamin 8-klasisty — kursy matematyki" description="Przygotowanie do egzaminu 8-klasisty z matematyki. Wszystkie działy CKE krok po kroku. Wkrótce dostępne.">
  <main class="hub-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <span>Egzamin 8-klasisty</span>
      </div>

      <section class="hub-hero">
        <div class="section-label">⭐ PRIORYTET · EGZAMIN 8-KLASISTY</div>
        <h1 class="hub-title">Egzamin 8-klasisty<br /><span class="text-yellow">z matematyki</span></h1>
        <p class="hub-sub">
          Wszystkie działy CKE w jednym miejscu. Idealne przygotowanie przed liceum.<br />
          <strong>Materiał wkrótce</strong> — buduję kursy w pierwszej kolejności.
        </p>
        <div class="hub-actions">
          <a href="/mapa-nauki" class="btn-secondary">🗺️ Mapa nauki</a>
          <a href="/arkusze#egzamin-osmoklasisty" class="btn-secondary">📄 Arkusze CKE</a>
          <a href="/korepetycje" class="btn-secondary">👨‍🏫 Korepetycje</a>
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-priority">⭐ PRIORYTET · WKRÓTCE</span>
            <h2 class="klasa-title">9 działów egzaminu CKE</h2>
          </div>
          <p class="klasa-desc">Zakres wymagań CKE dla egzaminu 8-klasisty — dział po dziale.</p>
        </div>
        <div class="dzialy-grid">
          {dzialyOK.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- INFORMER -->
      <section class="info-box-section">
        <div class="info-box">
          <div class="info-icon">💡</div>
          <div>
            <h3>Tymczasem...</h3>
            <p>Materiał jest w przygotowaniu. <strong>Korzystaj z arkuszy CKE</strong> już teraz — wszystkie dostępne za darmo na stronie.</p>
            <a href="/arkusze#egzamin-osmoklasisty" class="btn-primary">📄 Arkusze egzaminacyjne →</a>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="hub-final">
        <div class="hub-final-box">
          <h2>Potrzebujesz pomocy z matematyką?</h2>
          <p>Wybierz najlepszą opcję dla 8-klasisty:</p>
          <div class="hub-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hub-page { color: #EBEEFF; padding: 0 0 60px; }
  .text-yellow { color: #FFDE59; }
  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  .hub-hero { padding: 30px 0 50px; }
  .hub-title { font-size: 42px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; }
  .hub-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; max-width: 580px; line-height: 1.55; }
  .hub-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .klasa-section { margin-bottom: 36px; }
  .klasa-header { margin-bottom: 16px; }
  .klasa-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .tag-priority {
    background: rgba(255, 222, 89, 0.15);
    color: #FFDE59;
  }
  .tag-soon { background: rgba(235, 238, 255, 0.06); color: rgba(235, 238, 255, 0.5); }
  .klasa-title { font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
  .klasa-desc { font-size: 13px; color: rgba(235, 238, 255, 0.65); margin: 4px 0 0; }

  .dzialy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .dzial-card {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 80px;
    opacity: 0.55;
  }
  .dzial-name {
    font-size: 13px;
    font-weight: 600;
    color: #EBEEFF;
    line-height: 1.4;
  }

  /* INFO BOX */
  .info-box-section { margin-bottom: 36px; }
  .info-box {
    background: rgba(63, 206, 207, 0.08);
    border: 1px solid rgba(63, 206, 207, 0.25);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .info-icon { font-size: 32px; flex-shrink: 0; }
  .info-box h3 { font-size: 18px; font-weight: 700; margin: 0 0 6px; }
  .info-box p { font-size: 14px; color: rgba(235, 238, 255, 0.75); margin: 0 0 14px; line-height: 1.55; }

  .hub-final-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .hub-final-box h2 { font-size: 24px; font-weight: 700; margin: 0 0 8px; }
  .hub-final-box p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin: 0 0 20px; }
  .hub-final-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hub-title { font-size: 30px; }
    .dzialy-grid { grid-template-columns: repeat(2, 1fr); }
    .info-box { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .dzialy-grid { grid-template-columns: 1fr; }
  }
</style>
