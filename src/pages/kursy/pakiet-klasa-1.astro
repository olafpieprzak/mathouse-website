---
// =====================================================
// PAKIET PODSTAWOWY KLASA 1 — wszystkie 12 działów
// URL: /kursy/pakiet-klasa-1
// Cena: 597 zł (było 697 zł)
// =====================================================
import Layout from '../../layouts/Layout.astro';
import KupTerazWidget from '../../components/KupTerazWidget.astro';
import { produkty } from '../../data/produkty.js';
import { dzialy } from '../../data/dzialy.js';

const product = produkty.pakietKlasa1;
const PRICE = product.price; // 597
const PRICE_OLD = product.priceOld; // 697
const EMBED_ID = product.sklepEmbedId;
const SHOP_URL = product.sklepUrl;
const HAS_CHECKOUT = !!(EMBED_ID || SHOP_URL);

const klasa1 = dzialy.filter(d => d.klasaNum === 1);
const totalPodlekcje = klasa1.reduce((sum, d) => {
  if (d.lekcjeSklep) return sum + d.lekcjeSklep.reduce((s, l) => s + l.count, 0);
  return sum;
}, 0);
const oszczednosc = PRICE_OLD - PRICE;
const cenaOsobno = klasa1.length * 197; // gdyby kupować osobno
const oszczednoscVsOsobno = cenaOsobno - PRICE;
---

<Layout
  title={`Pakiet podstawowy klasa 1 — wszystkie 12 działów · ${PRICE} zł`}
  description={`Wszystkie 12 działów klasy 1 liceum w jednym pakiecie — ${totalPodlekcje}+ podlekcji wideo. Od zbiorów liczbowych po trygonometrię. ${PRICE} zł zamiast ${PRICE_OLD} zł. Dostęp na zawsze.`}
>
  <div class="kurs-breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> /
      <a href="/kursy">Kursy</a> /
      <span>Pakiet klasa 1</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="kurs-hero">
    <div class="container-content kurs-hero-grid">
      <div class="kurs-hero-left">
        <div class="section-label">⭐ NAJLEPSZA WARTOŚĆ · PAKIET</div>
        <h1 class="kurs-title">
          Pakiet podstawowy<br /><span class="text-yellow">klasa 1 liceum</span>
        </h1>
        <p class="kurs-desc">
          Wszystkie <strong>12 działów</strong> klasy 1 w jednym pakiecie — od zbiorów liczbowych
          przez funkcje aż po trygonometrię. Łącznie <strong>{totalPodlekcje}+ podlekcji wideo</strong>
          z teorią i rozwiązaniami krok po kroku. Dostęp na zawsze.
        </p>
        <div class="kurs-price-row">
          <span class="kurs-price">{PRICE} zł</span>
          {PRICE_OLD && <span class="kurs-price-old">{PRICE_OLD} zł</span>}
          <span class="kurs-price-save">oszczędzasz {oszczednosc} zł</span>
        </div>
        <p class="kurs-price-note">
          Kupując działy osobno zapłaciłbyś {cenaOsobno} zł — w pakiecie oszczędzasz {oszczednoscVsOsobno} zł.
        </p>
        <div class="kurs-cta">
          {HAS_CHECKOUT ? (
            <a href="#kup-teraz" class="btn-primary">🛒 Kup pakiet · {PRICE} zł</a>
          ) : (
            <a href="/kontakt" class="btn-primary">📩 Powiadom mnie</a>
          )}
          <a href="/kursy" class="btn-teal">← Wróć do kursów</a>
        </div>
      </div>
      <div class="kurs-hero-right">
        <div class="hero-card">
          <div class="hero-card-icon">📦</div>
          <div class="hero-card-stat">
            <div class="hero-card-num">12</div>
            <div class="hero-card-lbl">działów</div>
          </div>
          <div class="hero-card-stat">
            <div class="hero-card-num">{totalPodlekcje}+</div>
            <div class="hero-card-lbl">podlekcji wideo</div>
          </div>
          <div class="hero-card-stat">
            <div class="hero-card-num">∞</div>
            <div class="hero-card-lbl">dostęp na zawsze</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {HAS_CHECKOUT && (
    <a href="#kup-teraz" class="mini-cta mini-cta-yellow">
      <div class="container-content mini-cta-inner">
        <span class="mini-cta-emoji">📦</span>
        <span class="mini-cta-text">
          <strong>Cały rok pierwszy w jednym pakiecie</strong>
          <em>{PRICE} zł zamiast {PRICE_OLD} zł · dostęp na zawsze.</em>
        </span>
        <span class="mini-cta-btn">🛒 Kup pakiet · {PRICE} zł ↓</span>
      </div>
    </a>
  )}

  <!-- CO WCHODZI W PAKIET -->
  <section class="kurs-co">
    <div class="container-content">
      <div class="section-label">📚 CO WCHODZI W PAKIET</div>
      <h2 class="section-title">Wszystkie 12 działów klasy 1.</h2>
      <p class="kurs-co-sub">
        Każdy dział to pełny kurs wideo z teorią, przykładami i rozwiązanymi zadaniami.
        Klikasz w dział, żeby zobaczyć szczegóły.
      </p>
      <div class="dzialy-pakiet-grid">
        {klasa1.map((d) => (
          <a href={`/kursy/${d.slug}`} class="dzial-pakiet-tile">
            <div class="dzial-pakiet-num">{d.num}</div>
            <div class="dzial-pakiet-info">
              <div class="dzial-pakiet-name">{d.short || d.name}</div>
              {d.lekcjeSklep && (
                <div class="dzial-pakiet-meta">
                  {d.lekcjeSklep.reduce((s,l)=>s+l.count, 0)} podlekcji
                </div>
              )}
            </div>
            <span class="dzial-pakiet-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {HAS_CHECKOUT && (
    <a href="#kup-teraz" class="mini-cta mini-cta-teal">
      <div class="container-content mini-cta-inner">
        <span class="mini-cta-emoji">🎓</span>
        <span class="mini-cta-text">
          <strong>Gotowy ogarnąć całą klasę 1?</strong>
          <em>Płatność BLIK / kartą / przelew · dostęp natychmiast.</em>
        </span>
        <span class="mini-cta-btn">🛒 Zamawiam pakiet · {PRICE} zł ↓</span>
      </div>
    </a>
  )}

  <!-- DLACZEGO PAKIET -->
  <section class="kurs-dla-kogo">
    <div class="container-content">
      <div class="section-label">💡 DLACZEGO PAKIET</div>
      <h2 class="section-title">Dlaczego warto wziąć cały pakiet?</h2>
      <div class="dla-kogo-grid">
        <div class="dla-kogo-card">
          <div class="dla-kogo-ico">💰</div>
          <div class="dla-kogo-text">
            <strong>Taniej niż osobno</strong>
            <span>Działy pojedynczo to {cenaOsobno} zł. W pakiecie {PRICE} zł — oszczędzasz {oszczednoscVsOsobno} zł.</span>
          </div>
        </div>
        <div class="dla-kogo-card">
          <div class="dla-kogo-ico">🗺️</div>
          <div class="dla-kogo-text">
            <strong>Cały rok w kolejności</strong>
            <span>Działy ułożone od 1.1 do 1.12 — idziesz po kolei, nic Cię nie zaskoczy na lekcji.</span>
          </div>
        </div>
        <div class="dla-kogo-card">
          <div class="dla-kogo-ico">∞</div>
          <div class="dla-kogo-text">
            <strong>Dostęp na zawsze</strong>
            <span>Raz kupujesz — masz dożywotnio. Wracasz do materiału przed klasówką, maturą, kiedy chcesz.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WIDGET PŁATNOŚCI -->
  {HAS_CHECKOUT && EMBED_ID && (
    <KupTerazWidget embedId={EMBED_ID} productName="Pakiet podstawowy klasa 1" price={PRICE} priceOld={PRICE_OLD} />
  )}

  {!EMBED_ID && SHOP_URL && (
    <section id="kup-teraz" class="kup-fallback">
      <div class="container-content">
        <h2 class="kup-fallback-title">Gotowy na zakup?</h2>
        <p class="kup-fallback-sub">Kliknij poniżej, żeby przejść do sklepu i sfinalizować zamówienie.</p>
        <a href={SHOP_URL} target="_blank" rel="noopener" class="btn-primary kup-fallback-btn">
          🛒 Przejdź do sklepu · {PRICE} zł →
        </a>
      </div>
    </section>
  )}

  {!HAS_CHECKOUT && (
    <section id="kup-teraz" class="kup-fallback">
      <div class="container-content">
        <h2 class="kup-fallback-title">Pakiet — wkrótce w sprzedaży online</h2>
        <p class="kup-fallback-sub">Zostaw mi swój email — dam znać gdy płatność online ruszy.</p>
        <a href="/kontakt" class="btn-primary kup-fallback-btn">📩 Powiadom mnie →</a>
      </div>
    </section>
  )}
</Layout>

<style>
  .kurs-breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .kurs-breadcrumb a { color: inherit; text-decoration: none; }
  .kurs-breadcrumb a:hover { color: #FFDE59; }
  .kurs-breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  .kurs-hero { padding: 40px 0 30px; }
  .kurs-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 30px;
    align-items: center;
  }
  .kurs-title {
    font-size: 42px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1.2px;
    margin: 12px 0 16px;
  }
  .kurs-desc {
    font-size: 15px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.65;
    max-width: 600px;
    margin: 0 0 22px;
  }
  .kurs-desc strong { color: #EBEEFF; }

  .kurs-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .kurs-price {
    font-size: 32px;
    font-weight: 800;
    color: #FFDE59;
    letter-spacing: -0.5px;
  }
  .kurs-price-old {
    font-size: 18px;
    color: rgba(235, 238, 255, 0.45);
    text-decoration: line-through;
  }
  .kurs-price-save {
    font-size: 11px;
    color: #2ECC71;
    background: rgba(46, 204, 113, 0.12);
    padding: 4px 10px;
    border-radius: 6px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .kurs-price-note {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.55);
    margin-bottom: 18px;
  }
  .kurs-cta { display: flex; gap: 10px; flex-wrap: wrap; }

  .kurs-hero-right { display: flex; justify-content: center; }
  .hero-card {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.12), rgba(63, 206, 207, 0.05));
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 18px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    min-width: 240px;
  }
  .hero-card-icon { font-size: 56px; line-height: 1; }
  .hero-card-stat {
    text-align: center;
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    padding-top: 12px;
    width: 100%;
  }
  .hero-card-stat:first-of-type { border-top: none; padding-top: 0; }
  .hero-card-num {
    font-size: 26px;
    font-weight: 800;
    color: #FFDE59;
    line-height: 1;
  }
  .hero-card-lbl {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 4px;
  }

  .kurs-dla-kogo, .kurs-co { padding: 44px 0; }
  .section-label {
    font-size: 11px;
    color: #3FCECF;
    letter-spacing: 1px;
    margin-bottom: 8px;
    font-weight: 700;
  }
  .section-title {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin-bottom: 18px;
  }

  .kurs-co-sub {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.6);
    margin-bottom: 22px;
    max-width: 720px;
    line-height: 1.6;
  }
  .dzialy-pakiet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .dzial-pakiet-tile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: all 0.18s ease;
  }
  .dzial-pakiet-tile:hover {
    border-color: rgba(255, 222, 89, 0.4);
    background: rgba(255, 222, 89, 0.04);
    transform: translateY(-2px);
  }
  .dzial-pakiet-num {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 9px;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .dzial-pakiet-info { flex: 1; min-width: 0; }
  .dzial-pakiet-name {
    font-size: 13px;
    font-weight: 700;
    color: #EBEEFF;
    line-height: 1.3;
  }
  .dzial-pakiet-meta {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 2px;
  }
  .dzial-pakiet-arrow {
    color: #FFDE59;
    font-weight: 700;
    flex-shrink: 0;
  }

  .dla-kogo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .dla-kogo-card {
    display: flex;
    gap: 14px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 12px;
  }
  .dla-kogo-ico { font-size: 32px; line-height: 1; flex-shrink: 0; }
  .dla-kogo-text strong {
    font-size: 14px;
    color: #EBEEFF;
    display: block;
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .dla-kogo-text span {
    font-size: 12.5px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
  }

  /* MINI-CTA */
  .mini-cta {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .mini-cta:hover { transform: translateY(-1px); }
  .mini-cta-yellow {
    background: linear-gradient(90deg, #FFDE59 0%, #FFE680 100%);
    color: #050A24;
  }
  .mini-cta-teal {
    background: linear-gradient(90deg, #3FCECF 0%, #5CDADB 100%);
    color: #050A24;
  }
  .mini-cta-inner {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 0;
    flex-wrap: wrap;
  }
  .mini-cta-emoji { font-size: 32px; line-height: 1; flex-shrink: 0; }
  .mini-cta-text {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mini-cta-text strong { font-size: 16px; font-weight: 700; color: #050A24; }
  .mini-cta-text em {
    font-size: 12.5px;
    font-style: normal;
    color: rgba(5, 10, 36, 0.7);
  }
  .mini-cta-btn {
    background: #050A24;
    color: #FFDE59;
    padding: 11px 22px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
  }
  .mini-cta-teal .mini-cta-btn { color: #3FCECF; }

  .kup-fallback {
    padding: 60px 0;
    background: rgba(255, 222, 89, 0.06);
    border-top: 1px solid rgba(255, 222, 89, 0.2);
    text-align: center;
  }
  .kup-fallback-title { font-size: 28px; font-weight: 700; margin-bottom: 10px; }
  .kup-fallback-sub { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin-bottom: 22px; }
  .kup-fallback-btn { display: inline-block; }

  @media (max-width: 900px) {
    .kurs-hero-grid { grid-template-columns: 1fr; }
    .kurs-title { font-size: 32px; }
    .dzialy-pakiet-grid { grid-template-columns: repeat(2, 1fr); }
    .dla-kogo-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .dzialy-pakiet-grid { grid-template-columns: 1fr; }
    .mini-cta-btn { width: 100%; text-align: center; }
  }
</style>
