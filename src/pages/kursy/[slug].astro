---
// =====================================================
// DYNAMICZNY SZABLON KURSU — generuje stronę dla każdego działu
// z dzialy.js. Identyczna struktura jak logarytmy.astro,
// plus sekcje "Teoria" i "Przykłady" dla pełniejszej treści.
// =====================================================
import Layout from '../../layouts/Layout.astro';
import HeroMedia from '../../components/HeroMedia.astro';
import KupTerazWidget from '../../components/KupTerazWidget.astro';
import { dzialy, getDzialBySlug } from '../../data/dzialy.js';

export function getStaticPaths() {
  return dzialy.map((d) => ({
    params: { slug: d.slug },
    props: { kurs: d },
  }));
}

const { kurs } = Astro.props;

// Lekcje generujemy z podpunktów + 3 lekcje zadaniowe
const lekcje = [
  ...kurs.podpunkty.map((p, i) => ({
    num: String(i + 1).padStart(2, '0'),
    name: p,
    time: i === 0 ? '8:32' : `${10 + i * 2}:00`,
    free: i === 0,
  })),
  {
    num: String(kurs.podpunkty.length + 1).padStart(2, '0') + '–' + String(kurs.podpunkty.length + 3).padStart(2, '0'),
    name: 'Zadania maturalne (3 lekcje)',
    time: '~45 min',
  },
];

const pakietCena = kurs.klasaNum === 1 ? 597 : 597;
const pakietLiczba = kurs.klasaNum === 1 ? 12 : kurs.klasaNum === 2 ? 8 : 6;
---

<Layout
  title={`${kurs.num} ${kurs.name} — kurs wideo`}
  description={`Kurs wideo z działu "${kurs.name}" do ${kurs.klasa}. ${lekcje.length} lekcji wideo, ${kurs.duration}, dostęp na zawsze. Pierwsza lekcja gratis. Cena: ${kurs.price} zł.`}
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> /
      <a href="/kursy">Kursy</a> /
      <a href="/mapa-nauki">Mapa nauki</a> /
      <span>{kurs.num} {kurs.name}</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="kurs-hero">
    <div class="container-content kurs-hero-grid">
      <div>
        <div class="section-label">DZIAŁ {kurs.num} · {kurs.klasa.toUpperCase()}</div>
        <h1 class="kurs-title">{kurs.name}<span class="text-yellow">.</span></h1>
        <p class="kurs-desc">
          {kurs.desc} {kurs.status === 'live' && <strong>Tłumaczę aż zrozumiesz.</strong>}
        </p>

        <div class="kurs-meta">
          <div>
            <div class="kurs-meta-label">Cena</div>
            <div class="kurs-price-row">
              <span class="kurs-price">{kurs.price} zł</span>
              <span class="kurs-price-old">{kurs.priceOld} zł</span>
            </div>
          </div>
          <div class="kurs-meta-sep"></div>
          <div>
            <div class="kurs-meta-label">Długość</div>
            <div class="kurs-meta-val">{kurs.duration}</div>
          </div>
          <div class="kurs-meta-sep"></div>
          <div>
            <div class="kurs-meta-label">Dostęp</div>
            <div class="kurs-meta-val">bezterminowy</div>
          </div>
        </div>

        <div class="kurs-cta">
          {kurs.status === 'live' ? (
            <>
              {kurs.sklepEmbedId ? (
                <a href="#kup-teraz" class="btn-primary">🛒 Kup teraz · {kurs.price} zł</a>
              ) : (
                <a href={kurs.sklepUrl || '#kup'} class="btn-primary" target={kurs.sklepUrl ? '_blank' : '_self'} rel={kurs.sklepUrl ? 'noopener' : ''}>
                  {kurs.sklepUrl ? `🛒 Kup w sklepie · ${kurs.price} zł` : `Kup kurs · ${kurs.price} zł`}
                </a>
              )}
              <a href="#wideo-gratis" class="btn-teal">▶ Obejrzyj lekcję gratis</a>
            </>
          ) : (
            <>
              <a href="/kontakt" class="btn-primary">📩 Zapisz się na powiadomienie</a>
              <a href="/korepetycje" class="btn-teal">👨‍🏫 Skorzystaj z korepetycji</a>
            </>
          )}
        </div>
        <p class="kurs-tip">
          {kurs.status === 'live' ? (
            <>💡 Lub kup pakiet {kurs.klasa} (wszystkie {pakietLiczba} działów) za <strong class="text-yellow">{pakietCena} zł</strong></>
          ) : (
            <>⏳ Kurs będzie dostępny wkrótce. Tymczasem skorzystaj z korepetycji indywidualnych.</>
          )}
        </p>
      </div>

      <div id="wideo-gratis">
        <HeroMedia
          slot="heroKursy"
          captionOverride={`"${kurs.podpunkty[0]}" · ~8 min`}
        />
      </div>
    </div>
  </section>

  <!-- TEORIA W PIGUŁCE -->
  <section class="kurs-teoria">
    <div class="container-content">
      <div class="section-label">📚 TEORIA W PIGUŁCE</div>
      <h2 class="teoria-title">Co musisz wiedzieć z tego działu.</h2>
      <div class="teoria-grid">
        {kurs.teoria.map((t, i) => (
          <div class="teoria-card">
            <div class="teoria-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="teoria-text">{t}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {kurs.sklepEmbedId && (
    <a href="#kup-teraz" class="mini-cta mini-cta-yellow">
      <div class="container-content mini-cta-inner">
        <span class="mini-cta-emoji">⚡</span>
        <span class="mini-cta-text">
          <strong>Chcesz pełną teorię z wideo?</strong>
          <em>Kurs zawiera {kurs.lekcjeSklep ? kurs.lekcjeSklep.reduce((s,l)=>s+l.count,0) : '300+'} podlekcji wideo z PDF-ami.</em>
        </span>
        <span class="mini-cta-btn">🛒 Kup teraz · {kurs.price} zł ↓</span>
      </div>
    </a>
  )}

  <!-- PRZYKŁADY -->
  <section class="kurs-przyklady">
    <div class="container-content">
      <div class="section-label">✏️ PRZYKŁADOWE ZADANIA</div>
      <h2 class="przyklady-title">Zobacz, jak rozwiązujemy typowe zadania.</h2>
      <div class="przyklady-list">
        {kurs.przyklady.map((p, i) => (
          <div class="przyklad-card">
            <div class="przyklad-label">Zadanie {i + 1}</div>
            <div class="przyklad-zadanie">{p.zadanie}</div>
            <div class="przyklad-rozw-label">Rozwiązanie:</div>
            <div class="przyklad-rozw">{p.rozwiazanie}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {kurs.sklepEmbedId && (
    <a href="#kup-teraz" class="mini-cta mini-cta-teal">
      <div class="container-content mini-cta-inner">
        <span class="mini-cta-emoji">🎯</span>
        <span class="mini-cta-text">
          <strong>Chcesz rozwiązać setki takich zadań?</strong>
          <em>Każde zadanie z kursu mam rozwiązane wideo — krok po kroku.</em>
        </span>
        <span class="mini-cta-btn">▶ Odbierz lekcje teraz ↓</span>
      </div>
    </a>
  )}

  <!-- CO ZNAJDZIESZ -->
  <section class="kurs-lekcje">
    <div class="container-content">
      {kurs.lekcjeSklep ? (
        <!-- WERSJA ROZBUDOWANA - dla działów z pełnymi danymi ze sklepu -->
        <>
          <div class="lekcje-head">
            <div class="section-label">CO ZNAJDZIESZ W KURSIE</div>
            <h2 class="lekcje-title">
              <span class="text-yellow">{kurs.lekcjeSklep.reduce((sum, l) => sum + l.count, 0)}</span> podlekcji
              w {kurs.lekcjeSklep.length} sekcjach.
            </h2>
            <p class="lekcje-sub">Każda lekcja zawiera <strong>trzy typy materiałów</strong>:</p>
          </div>

          <!-- 3 typy materiałów - co dostajesz przy każdej lekcji -->
          <div class="typy-materialow">
            {kurs.typyMaterialow.map((t) => (
              <div class="typ-card">
                <div class="typ-ico">{t.icon}</div>
                <div>
                  <div class="typ-name">{t.name}</div>
                  <div class="typ-desc">{t.desc}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Pełna lista 8 sekcji ze sklepu -->
          <div class="section-label" style="margin-top:36px;">📚 PEŁNY PROGRAM KURSU</div>
          <div class="lekcje-sklep-list">
            {kurs.lekcjeSklep.map((l, i) => (
              <div class="lekcja-sklep">
                <div class="lekcja-sklep-num">{l.num}</div>
                <div class="lekcja-sklep-body">
                  <div class="lekcja-sklep-title">{l.title}</div>
                  <div class="lekcja-sklep-count">
                    <span class="lekcja-sklep-badge">{l.count} podlekcji</span>
                    {i === 0 && <span class="lekcja-sklep-free">▶ PIERWSZA GRATIS</span>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </>
      ) : (
        <!-- WERSJA STANDARDOWA - dla działów które nie mają lekcjeSklep -->
        <div class="kurs-lekcje-grid">
          <div>
            <div class="section-label">CO ZNAJDZIESZ W KURSIE</div>
            <h2 class="lekcje-title">{lekcje.length} lekcji wideo + zadania + ściąga.</h2>
          </div>
          <div class="lekcje-list">
            {lekcje.map((l) => (
              <div class="lekcja-row">
                <span>
                  <span class="lekcja-num">{l.num} ·</span> {l.name}
                  {l.free && <span class="lekcja-free">GRATIS</span>}
                </span>
                <span class="lekcja-time">{l.time}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  {kurs.sklepEmbedId && (
    <a href="#kup-teraz" class="mini-cta mini-cta-yellow">
      <div class="container-content mini-cta-inner">
        <span class="mini-cta-emoji">🚀</span>
        <span class="mini-cta-text">
          <strong>Gotowy na cały kurs?</strong>
          <em>Płatność BLIK / kartą / przelew · dostęp natychmiast po opłaceniu.</em>
        </span>
        <span class="mini-cta-btn">🛒 Zamawiam teraz · {kurs.price} zł ↓</span>
      </div>
    </a>
  )}

  <!-- UPSELL: pakiet -->
  <section id="kup" class="kurs-upsell">
    <div class="container-content kurs-upsell-inner">
      <div>
        <div class="upsell-eyebrow">⭐ ALTERNATYWA</div>
        <h3 class="upsell-h">Weź cały pakiet {kurs.klasa} — wszystkie {pakietLiczba} działów za {pakietCena} zł.</h3>
        <p class="upsell-d">Zamiast {pakietLiczba} × {kurs.price} zł = {pakietLiczba * kurs.price} zł, oszczędzasz <strong>{pakietLiczba * kurs.price - pakietCena} zł</strong>.</p>
      </div>
      <a href="/kursy" class="upsell-cta">Pokaż pakiet →</a>
    </div>
  </section>

  <!-- WIDGET PŁATNOŚCI Web To Learn - finalny moment zakupu -->
  {kurs.sklepEmbedId && (
    <KupTerazWidget embedId={kurs.sklepEmbedId} productName={kurs.name.toLowerCase()} price={kurs.price} priceOld={kurs.priceOld} />
  )}

  <!-- NAWIGACJA: poprzedni / następny dział -->
  <section class="kurs-nav">
    <div class="container-content kurs-nav-inner">
      <a href="/mapa-nauki" class="kurs-nav-back">← Wróć do mapy nauki</a>
      <a href="/kursy" class="kurs-nav-all">Zobacz wszystkie kursy →</a>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  /* HERO */
  .kurs-hero { padding: 48px 0; }
  .kurs-hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
    align-items: center;
  }
  .kurs-title {
    font-size: 50px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -1.8px;
    margin-bottom: 16px;
  }
  .kurs-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.65;
    margin-bottom: 20px;
    max-width: 420px;
  }
  .kurs-desc strong { color: #EBEEFF; }
  .kurs-meta { display: flex; gap: 16px; margin-bottom: 22px; flex-wrap: wrap; }
  .kurs-meta-label { font-size: 11px; color: rgba(235, 238, 255, 0.5); }
  .kurs-price-row { display: flex; align-items: baseline; gap: 8px; }
  .kurs-price { font-size: 22px; font-weight: 600; color: #FFDE59; }
  .kurs-price-old { font-size: 13px; color: rgba(235, 238, 255, 0.5); text-decoration: line-through; }
  .kurs-meta-val { font-size: 15px; font-weight: 600; }
  .kurs-meta-sep { width: 1px; background: rgba(235, 238, 255, 0.1); }
  .kurs-cta { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-teal {
    display: inline-block;
    border: 1px solid rgba(63, 206, 207, 0.5);
    color: #3FCECF;
    padding: 11px 22px;
    border-radius: 7px;
    font-size: 13px;
    text-decoration: none;
  }
  .kurs-tip { font-size: 11px; color: rgba(235, 238, 255, 0.5); margin-top: 14px; }

  /* Wideo */
  .kurs-video { position: relative; }
  .kurs-video-bg {
    position: absolute; inset: 0;
    background: #3FCECF;
    border-radius: 16px;
    transform: rotate(-3deg);
  }
  .kurs-video-frame {
    position: relative; background: #000;
    border-radius: 16px;
    aspect-ratio: 16/10;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(235, 238, 255, 0.1);
  }
  .kurs-play {
    width: 68px; height: 68px;
    background: #FFDE59;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #050A24; font-size: 24px;
    border: none; cursor: pointer;
  }
  .kurs-video-badge {
    position: absolute; top: 14px; right: 16px;
    background: rgba(255, 222, 89, 0.95);
    color: #050A24;
    padding: 5px 11px; border-radius: 20px;
    font-size: 10px; font-weight: 600;
  }
  .kurs-video-time {
    position: absolute; bottom: 14px; left: 18px;
    color: #EBEEFF; font-size: 12px;
  }

  /* TEORIA */
  .kurs-teoria {
    padding: 48px 0;
    background: rgba(255, 222, 89, 0.03);
    border-top: 1px solid rgba(235, 238, 255, 0.06);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .teoria-title {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin: 8px 0 28px;
  }
  .teoria-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
  }
  .teoria-card {
    display: flex;
    gap: 14px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    align-items: flex-start;
  }
  .teoria-num {
    font-family: 'Instrument Serif', serif;
    color: #FFDE59;
    font-size: 22px;
    font-weight: 600;
    line-height: 1;
    flex-shrink: 0;
  }
  .teoria-text {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(235, 238, 255, 0.85);
  }

  /* PRZYKŁADY */
  .kurs-przyklady { padding: 48px 0; }
  .przyklady-title {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin: 8px 0 28px;
  }
  .przyklady-list { display: flex; flex-direction: column; gap: 14px; }
  .przyklad-card {
    padding: 22px;
    background: rgba(63, 206, 207, 0.05);
    border: 1px solid rgba(63, 206, 207, 0.2);
    border-radius: 12px;
  }
  .przyklad-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: #3FCECF;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .przyklad-zadanie {
    font-size: 15px;
    line-height: 1.55;
    color: #EBEEFF;
    font-weight: 500;
    margin-bottom: 14px;
  }
  .przyklad-rozw-label {
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(235, 238, 255, 0.6);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .przyklad-rozw {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(235, 238, 255, 0.85);
  }

  /* LEKCJE */
  .kurs-lekcje {
    padding: 32px 0;
    background: rgba(63, 206, 207, 0.05);
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    border-bottom: 1px solid rgba(235, 238, 255, 0.1);
  }
  .kurs-lekcje-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 36px;
  }
  .lekcje-title {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .lekcje-list { display: flex; flex-direction: column; gap: 6px; }
  .lekcja-row {
    display: flex;
    justify-content: space-between;
    padding: 11px 14px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    font-size: 13px;
    gap: 10px;
  }
  .lekcja-num { color: rgba(235, 238, 255, 0.5); }
  .lekcja-time { color: rgba(235, 238, 255, 0.5); white-space: nowrap; }
  .lekcja-free {
    color: #3FCECF;
    font-size: 10px;
    background: rgba(63, 206, 207, 0.15);
    padding: 2px 8px;
    border-radius: 5px;
    margin-left: 6px;
  }

  /* ROZBUDOWANE LEKCJE ZE SKLEPU */
  .lekcje-head { margin-bottom: 24px; }
  .lekcje-sub {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    margin-top: 8px;
  }
  .lekcje-sub strong { color: #FFDE59; }

  /* 3 typy materiałów */
  .typy-materialow {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-bottom: 8px;
  }
  .typ-card {
    display: flex;
    gap: 14px;
    padding: 16px 18px;
    background: rgba(255, 222, 89, 0.06);
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 12px;
    align-items: center;
  }
  .typ-ico {
    font-size: 28px;
    line-height: 1;
    flex-shrink: 0;
  }
  .typ-name {
    font-size: 14px;
    font-weight: 700;
    color: #EBEEFF;
    margin-bottom: 2px;
  }
  .typ-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.4;
  }

  /* Lista 8 sekcji ze sklepu */
  .lekcje-sklep-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 14px;
  }
  .lekcja-sklep {
    display: flex;
    gap: 14px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 10px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .lekcja-sklep:hover {
    border-color: rgba(255, 222, 89, 0.3);
    background: rgba(255, 222, 89, 0.04);
  }
  .lekcja-sklep-num {
    font-size: 13px;
    font-weight: 700;
    color: #3FCECF;
    background: rgba(63, 206, 207, 0.15);
    padding: 6px 10px;
    border-radius: 7px;
    flex-shrink: 0;
    height: fit-content;
    min-width: 42px;
    text-align: center;
  }
  .lekcja-sklep-body {
    flex: 1;
    min-width: 0;
  }
  .lekcja-sklep-title {
    font-size: 13.5px;
    font-weight: 600;
    color: #EBEEFF;
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .lekcja-sklep-count {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .lekcja-sklep-badge {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.6);
    background: rgba(255, 255, 255, 0.05);
    padding: 3px 8px;
    border-radius: 5px;
  }
  .lekcja-sklep-free {
    font-size: 10px;
    color: #050A24;
    background: #FFDE59;
    padding: 3px 8px;
    border-radius: 5px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  /* MINI-CTA BANERY — pojawiają się między sekcjami i scrollują do widgetu zakupowego */
  .mini-cta {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }
  .mini-cta:hover {
    transform: translateY(-1px);
    box-shadow: inset 0 0 0 100vmax rgba(0, 0, 0, 0.05);
