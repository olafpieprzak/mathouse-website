---
import Layout from '../../layouts/Layout.astro';

const klasa1 = [
  { num: '1.1', tytul: 'Zbiory liczbowe', url: 'https://kurs.mathouse.pl/s/zbiory-liczbowe.html', live: true },
  { num: '1.2', tytul: 'Równania i nierówności 1°', url: 'https://kurs.mathouse.pl/s/rownania-i-nierownosci-1-stopnia.html', live: true },
  { num: '1.3', tytul: 'Procenty · Błąd · Przybliżenie', url: 'https://kurs.mathouse.pl/s/procenty-punkt-procentowy.html', live: true },
  { num: '1.4', tytul: 'Potęgi', url: 'https://kurs.mathouse.pl/s/potegi.html', live: true },
  { num: '1.5', tytul: 'Logarytmy', url: 'https://kurs.mathouse.pl/s/logarytmy.html', live: true },
  { num: '1.6', tytul: 'Wyrażenia algebraiczne', url: 'https://kurs.mathouse.pl/s/wyrazenia-algebraiczne.html', live: true },
  { num: '1.7', tytul: 'Wzory skróconego mnożenia', url: 'https://kurs.mathouse.pl/s/wzory-skroconego-mnozenie.html', live: true },
  { num: '1.8', tytul: 'Funkcje', url: 'https://kurs.mathouse.pl/s/funkcja.html', live: true },
  { num: '1.9', tytul: 'Funkcja liniowa', url: 'https://kurs.mathouse.pl/s/funkcja-liniowa.html', live: true },
  { num: '1.10', tytul: 'Układy równań', url: 'https://kurs.mathouse.pl/s/uklady-rownan.html', live: true },
  { num: '1.11', tytul: 'Geometria płaska 1', url: 'https://kurs.mathouse.pl/s/11-geometria-plaska-cz1-klasa-1.html', live: true },
  { num: '1.12', tytul: 'Trygonometria 1', url: 'https://kurs.mathouse.pl/s/trygonometria-cz1.html', live: true },
];

const klasa2 = ['Przekształcenia wykresów', 'Wartość bezwzględna', 'Funkcja kwadratowa', 'Geometria — okręgi', 'Trygonometria zaawansowana', 'Geometria analityczna', 'Trójkąty, pola, koła', 'Wielomiany'];
const klasa3 = ['Ułamki algebraiczne', 'Ciągi (arytmetyczny, geometryczny)', 'Kombinatoryka', 'Czworokąty', 'Pole czworokąta', 'Geometria analityczna cz. 2'];
const klasa4 = ['Funkcja wykładnicza', 'Funkcja logarytmiczna', 'Statystyka', 'Rachunek prawdopodobieństwa', 'Geometria przestrzenna', 'Bryły obrotowe'];
---

<Layout title="Liceum (podstawa) — wszystkie kursy" description="Kursy matematyki dla liceum podstawowego: 4 lata, 32 działy. Klasa 1 dostępna, kolejne wkrótce.">
  <main class="hub-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <span>Liceum (podstawa)</span>
      </div>

      <section class="hub-hero">
        <div class="section-label">📘 LICEUM · KURS PODSTAWOWY</div>
        <h1 class="hub-title">Matematyka liceum<br /><span class="text-yellow">krok po kroku</span></h1>
        <p class="hub-sub">4 lata · 32 działy · cała matematyka szkoły średniej. Idź klasą po klasie.</p>
        <div class="hub-actions">
          <a href="/mapa-nauki" class="btn-secondary">🗺️ Mapa nauki</a>
          <a href="/korepetycje" class="btn-secondary">👨‍🏫 Korepetycje</a>
        </div>
      </section>

      <!-- KLASA 1 — LIVE -->
      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-live">✅ GOTOWA · 12 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 1</h2>
          </div>
          <p class="klasa-desc">Pełen rok pierwszy — wszystkie działy dostępne na platformie.</p>
        </div>
        <div class="dzialy-grid">
          {klasa1.map((d) => (
            <a href={d.url} target="_blank" rel="noopener noreferrer" class="dzial-card dzial-card-live">
              <div class="dzial-num-badge">{d.num}</div>
              <div class="dzial-name">{d.tytul}</div>
              <div class="dzial-cta">Otwórz kurs →</div>
            </a>
          ))}
        </div>
      </section>

      <!-- KLASY 2-4 — WKRÓTCE -->
      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 8 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 2</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa2.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 6 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 3</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa3.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 6 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 4</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa4.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="hub-final">
        <div class="hub-final-box">
          <h2>Potrzebujesz pomocy?</h2>
          <p>Wybierz najlepszą opcję:</p>
          <div class="hub-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hub-page { color: #EBEEFF; padding: 0 0 60px; }
  .text-yellow { color: #FFDE59; }
  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  .hub-hero { padding: 30px 0 50px; }
  .hub-title { font-size: 42px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; }
  .hub-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; max-width: 540px; }
  .hub-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .klasa-section { margin-bottom: 36px; }
  .klasa-header { margin-bottom: 16px; }
  .klasa-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .tag-live { background: rgba(63, 206, 207, 0.15); color: #3FCECF; }
  .tag-soon { background: rgba(235, 238, 255, 0.06); color: rgba(235, 238, 255, 0.5); }
  .klasa-title { font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
  .klasa-desc { font-size: 13px; color: rgba(235, 238, 255, 0.65); margin: 4px 0 0; }

  .dzialy-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .dzial-card {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    min-height: 90px;
  }
  .dzial-card-live {
    border-color: rgba(255, 222, 89, 0.25);
    background: rgba(255, 222, 89, 0.04);
    cursor: pointer;
  }
  .dzial-card-live:hover {
    border-color: #FFDE59;
    transform: translateY(-2px);
    background: rgba(255, 222, 89, 0.1);
  }
  .dzial-card-soon {
    opacity: 0.55;
  }
  .dzial-num-badge {
    font-size: 10px;
    font-weight: 700;
    color: #3FCECF;
    background: rgba(63, 206, 207, 0.15);
    padding: 3px 7px;
    border-radius: 5px;
    align-self: flex-start;
  }
  .dzial-name {
    font-size: 13px;
    font-weight: 600;
    color: #EBEEFF;
    line-height: 1.4;
    flex: 1;
  }
  .dzial-cta {
    font-size: 11px;
    color: #FFDE59;
    font-weight: 700;
    margin-top: 4px;
  }

  .hub-final { margin-top: 40px; }
  .hub-final-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .hub-final-box h2 { font-size: 24px; font-weight: 700; margin: 0 0 8px; }
  .hub-final-box p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin: 0 0 20px; }
  .hub-final-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hub-title { font-size: 30px; }
    .dzialy-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .dzialy-grid { grid-template-columns: 1fr; }
  }
</style>
