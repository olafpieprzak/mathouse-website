---
import Layout from '../../layouts/Layout.astro';
import { dzialy } from '../../data/dzialy.js';

// Klasa 1 - bierzemy z centralnej bazy dzialy.js
const klasa1 = dzialy.filter(d => d.klasaNum === 1);

const klasa2 = ['Przekształcenia wykresów', 'Wartość bezwzględna', 'Funkcja kwadratowa', 'Geometria — okręgi', 'Trygonometria zaawansowana', 'Geometria analityczna', 'Trójkąty, pola, koła', 'Wielomiany'];
const klasa3 = ['Ułamki algebraiczne', 'Ciągi (arytmetyczny, geometryczny)', 'Kombinatoryka', 'Czworokąty', 'Pole czworokąta', 'Geometria analityczna cz. 2'];
const klasa4 = ['Funkcja wykładnicza', 'Funkcja logarytmiczna', 'Statystyka', 'Rachunek prawdopodobieństwa', 'Geometria przestrzenna', 'Bryły obrotowe'];
---

<Layout title="Liceum (podstawa) — wszystkie kursy" description="Kursy matematyki dla liceum podstawowego: 4 lata, 32 działy. Klasa 1 dostępna, kolejne wkrótce.">
  <main class="hub-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <span>Liceum (podstawa)</span>
      </div>

      <section class="hub-hero">
        <div class="section-label">📘 LICEUM · KURS PODSTAWOWY</div>
        <h1 class="hub-title">Matematyka liceum<br /><span class="text-yellow">krok po kroku</span></h1>
        <p class="hub-sub">4 lata · 32 działy · cała matematyka szkoły średniej. Idź klasą po klasie.</p>
        <div class="hub-actions">
          <a href="/mapa-nauki" class="btn-secondary">🗺️ Mapa nauki</a>
          <a href="/korepetycje" class="btn-secondary">👨‍🏫 Korepetycje</a>
        </div>
      </section>

      <!-- KLASA 1 — LIVE -->
      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-live">✅ GOTOWA · 12 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 1</h2>
          </div>
          <p class="klasa-desc">Pełen rok pierwszy — wszystkie działy dostępne na platformie.</p>
        </div>
        <div class="dzialy-grid-expanded">
          {klasa1.map((k) => (
            <a href={`/kursy/${k.slug}`} class="dzial-card-expanded">
              <div class="dzial-card-head">
                <div class="dzial-num-badge">{k.num}</div>
                <div class="dzial-card-meta">
                  <div class="dzial-name">{k.short || k.name}</div>
                  {k.lekcjeSklep && (
                    <div class="dzial-podlekcje">
                      {k.lekcjeSklep.reduce((s,l)=>s+l.count, 0)} podlekcji · {k.lekcjeSklep.length} sekcji
                    </div>
                  )}
                </div>
              </div>
              <div class="dzial-card-body">
                <div class="dzial-podtitle">📚 W tym dziale:</div>
                <ul class="dzial-podpunkty">
                  {k.podpunkty.slice(0, 3).map((p) => <li>{p}</li>)}
                  {k.podpunkty.slice(3).map((p) => <li class="dzial-podpunkt-extra">{p}</li>)}
                  {k.podpunkty.length > 3 && (
                    <li class="dzial-podpunkt-more">
                      <button type="button" class="dzial-more-btn" onclick="toggleDzialPodpunkty(event, this)">
                        + pokaż jeszcze {k.podpunkty.length - 3}
                      </button>
                    </li>
                  )}
                </ul>
              </div>
              <div class="dzial-card-foot">
                <div class="dzial-price-row">
                  <span class="dzial-price">{k.price} zł</span>
                  {k.priceOld && <span class="dzial-price-old">{k.priceOld} zł</span>}
                </div>
                <div class="dzial-cta">Zobacz kurs →</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- KLASY 2-4 — WKRÓTCE -->
      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 8 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 2</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa2.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 6 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 3</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa3.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-soon">⏳ WKRÓTCE · 6 DZIAŁÓW</span>
            <h2 class="klasa-title">Klasa 4</h2>
          </div>
        </div>
        <div class="dzialy-grid">
          {klasa4.map((d) => (
            <div class="dzial-card dzial-card-soon">
              <div class="dzial-name">{d}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="hub-final">
        <div class="hub-final-box">
          <h2>Potrzebujesz pomocy?</h2>
          <p>Wybierz najlepszą opcję:</p>
          <div class="hub-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hub-page { color: #EBEEFF; padding: 0 0 60px; }
  .text-yellow { color: #FFDE59; }
  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  .hub-hero { padding: 30px 0 50px; }
  .hub-title { font-size: 42px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; }
  .hub-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; max-width: 540px; }
  .hub-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .klasa-section { margin-bottom: 36px; }
  .klasa-header { margin-bottom: 16px; }
  .klasa-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .tag-live { background: rgba(63, 206, 207, 0.15); color: #3FCECF; }
  .tag-soon { background: rgba(235, 238, 255, 0.06); color: rgba(235, 238, 255, 0.5); }
  .klasa-title { font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
  .klasa-desc { font-size: 13px; color: rgba(235, 238, 255, 0.65); margin: 4px 0 0; }

  .dzialy-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .dzial-card {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    min-height: 90px;
  }
  .dzial-card-live {
    border-color: rgba(255, 222, 89, 0.25);
    background: rgba(255, 222, 89, 0.04);
    cursor: pointer;
  }
  .dzial-card-live:hover {
    border-color: #FFDE59;
    transform: translateY(-2px);
    background: rgba(255, 222, 89, 0.1);
  }
  .dzial-card-soon {
    opacity: 0.55;
  }
  .dzial-num-badge {
    font-size: 10px;
    font-weight: 700;
    color: #3FCECF;
    background: rgba(63, 206, 207, 0.15);
    padding: 3px 7px;
    border-radius: 5px;
    align-self: flex-start;
  }
  .dzial-name {
    font-size: 13px;
    font-weight: 600;
    color: #EBEEFF;
    line-height: 1.4;
    flex: 1;
  }
  .dzial-cta {
    font-size: 11px;
    color: #FFDE59;
    font-weight: 700;
    margin-top: 4px;
  }

  /* === ROZBUDOWANE KAFELKI DZIAŁÓW (spójne z /kursy) === */
  .dzialy-grid-expanded {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .dzial-card-expanded {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 14px;
    padding: 18px;
    text-decoration: none;
    color: inherit;
    transition: all 0.18s ease;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .dzial-card-expanded:hover {
    border-color: rgba(255, 222, 89, 0.45);
    background: rgba(255, 222, 89, 0.04);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
  }
  .dzial-card-expanded .dzial-card-head {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .dzial-card-expanded .dzial-num-badge {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 10px;
    border-radius: 7px;
    flex-shrink: 0;
    line-height: 1;
  }
  .dzial-card-expanded .dzial-card-meta { flex: 1; min-width: 0; }
  .dzial-card-expanded .dzial-name {
    font-size: 16px;
    font-weight: 700;
    color: #EBEEFF;
    margin: 0 0 4px;
    line-height: 1.25;
  }
  .dzial-card-expanded .dzial-podlekcje {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.55);
    font-weight: 500;
  }
  .dzial-card-expanded .dzial-card-body { flex: 1; min-height: 0; }
  .dzial-card-expanded .dzial-podtitle {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    font-weight: 600;
    letter-spacing: 0.3px;
    margin-bottom: 6px;
  }
  .dzial-card-expanded .dzial-podpunkty {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dzial-card-expanded .dzial-podpunkty li {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.45;
    padding-left: 12px;
    position: relative;
  }
  .dzial-card-expanded .dzial-podpunkty li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: #FFDE59;
    font-weight: 700;
  }
  .dzial-card-expanded .dzial-podpunkt-more {
    color: rgba(63, 206, 207, 0.7) !important;
    font-style: italic;
    font-size: 11px !important;
  }
  .dzial-card-expanded .dzial-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
  }
  .dzial-card-expanded .dzial-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .dzial-card-expanded .dzial-price {
    font-size: 16px;
    font-weight: 700;
    color: #FFDE59;
    margin: 0;
  }
  .dzial-card-expanded .dzial-price-old {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.4);
    text-decoration: line-through;
  }
  .dzial-card-expanded .dzial-cta {
    font-size: 11px;
    font-weight: 700;
    color: #FFDE59;
    letter-spacing: 0.3px;
    white-space: nowrap;
    margin-top: 0;
  }

  @media (max-width: 900px) {
    .dzialy-grid-expanded { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .dzialy-grid-expanded { grid-template-columns: 1fr; }
  }

  .hub-final { margin-top: 40px; }
  .hub-final-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .hub-final-box h2 { font-size: 24px; font-weight: 700; margin: 0 0 8px; }
  .hub-final-box p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin: 0 0 20px; }
  .hub-final-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hub-title { font-size: 30px; }
    .dzialy-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .dzialy-grid { grid-template-columns: 1fr; }
  }

  /* === COLLAPSIBLE PODPUNKTY === */
  .dzial-podpunkt-extra {
    display: none;
  }
  .dzial-card-expanded.expanded .dzial-podpunkt-extra {
    display: list-item;
  }
  .dzial-card-expanded .dzial-podpunkt-more {
    list-style: none !important;
    padding-left: 0 !important;
    margin-top: 4px;
  }
  .dzial-card-expanded .dzial-podpunkt-more::before {
    display: none !important;
  }
  .dzial-more-btn {
    background: rgba(63, 206, 207, 0.12);
    color: #3FCECF;
    border: 1px solid rgba(63, 206, 207, 0.3);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.2px;
    transition: all 0.15s ease;
  }
  .dzial-more-btn:hover {
    background: rgba(63, 206, 207, 0.2);
    border-color: rgba(63, 206, 207, 0.5);
  }
</style>

<script is:inline>
  function toggleDzialPodpunkty(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const card = btn.closest('.dzial-card-expanded');
    if (!card) return;
    const expanded = card.classList.toggle('expanded');
    if (expanded) {
      const hidden = card.querySelectorAll('.dzial-podpunkt-extra').length;
      btn.textContent = '− zwiń (' + hidden + ' więcej widocznych)';
    } else {
      const hidden = card.querySelectorAll('.dzial-podpunkt-extra').length;
      btn.textContent = '+ pokaż jeszcze ' + hidden;
    }
  }
</script>
