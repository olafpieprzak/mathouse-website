---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Matura podstawowa — kursy i powtórki" description="Przygotowanie do matury z matematyki podstawowej. 14-dniowa powtórka, sprint, arkusze CKE. Wszystko czego potrzebujesz.">
  <main class="hub-page">
    <div class="container-content">
      <div class="breadcrumb">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <span>Matura podstawowa</span>
      </div>

      <section class="hub-hero">
        <div class="section-label">📕 MATURA PODSTAWOWA</div>
        <h1 class="hub-title">Matura podstawowa<br /><span class="text-yellow">z matematyki</span></h1>
        <p class="hub-sub">Powtórka całego materiału + arkusze CKE + intensywne kursy przedmaturalne.</p>
      </section>

      <!-- DOSTĘPNE TERAZ -->
      <section class="klasa-section">
        <div class="klasa-header">
          <div>
            <span class="klasa-tag tag-live">✅ DOSTĘPNE TERAZ</span>
            <h2 class="klasa-title">Kursy maturalne</h2>
          </div>
        </div>
        <div class="dzialy-grid dzialy-grid-products">
          <a href="/landing-powtorka-14-dni" class="dzial-card dzial-card-product">
            <div class="product-price">197 zł</div>
            <div class="dzial-name">14-dniowa powtórka</div>
            <div class="dzial-desc">Cały materiał maturalny w 14 dni · zajęcia na żywo + nagrania</div>
            <div class="dzial-cta">Sprawdź szczegóły →</div>
          </a>
          <a href="/landing-maturalny-sprint" class="dzial-card dzial-card-product">
            <div class="product-price">67 zł</div>
            <div class="dzial-name">Maturalny sprint</div>
            <div class="dzial-desc">3 dni · 3 kluczowe działy · dostęp natychmiastowy</div>
            <div class="dzial-cta">Sprawdź szczegóły →</div>
          </a>
          <a href="/arkusze#matura-podstawowa" class="dzial-card dzial-card-product">
            <div class="product-price">Free</div>
            <div class="dzial-name">Arkusze CKE</div>
            <div class="dzial-desc">Wszystkie arkusze 2010-2026 · za darmo</div>
            <div class="dzial-cta">Pobierz arkusze →</div>
          </a>
        </div>
      </section>

      <section class="hub-final">
        <div class="hub-final-box">
          <h2>Potrzebujesz pomocy?</h2>
          <p>Wybierz najlepszą opcję dla siebie:</p>
          <div class="hub-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .hub-page { color: #EBEEFF; padding: 0 0 60px; }
  .text-yellow { color: #FFDE59; }
  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  .hub-hero { padding: 30px 0 50px; }
  .hub-title { font-size: 42px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; }
  .hub-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; max-width: 580px; line-height: 1.55; }

  .klasa-section { margin-bottom: 36px; }
  .klasa-tag { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 10px; font-weight: 700; letter-spacing: 1px; margin-bottom: 6px; }
  .tag-live { background: rgba(63, 206, 207, 0.15); color: #3FCECF; }
  .klasa-title { font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
  .klasa-header { margin-bottom: 16px; }

  .dzialy-grid-products {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .dzial-card {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 14px;
    padding: 22px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 200px;
  }
  .dzial-card-product {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.04));
    border-color: rgba(255, 222, 89, 0.3);
    cursor: pointer;
  }
  .dzial-card-product:hover {
    border-color: #FFDE59;
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(255, 222, 89, 0.15);
  }
  .product-price {
    font-size: 18px;
    font-weight: 700;
    color: #FFDE59;
    background: rgba(255, 222, 89, 0.15);
    padding: 6px 12px;
    border-radius: 6px;
    align-self: flex-start;
  }
  .dzial-name {
    font-size: 18px;
    font-weight: 700;
    color: #EBEEFF;
    line-height: 1.3;
  }
  .dzial-desc {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.5;
    flex: 1;
  }
  .dzial-cta {
    font-size: 13px;
    color: #FFDE59;
    font-weight: 700;
    margin-top: auto;
  }

  .hub-final-box {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.2);
    border-radius: 18px;
    padding: 36px;
    text-align: center;
  }
  .hub-final-box h2 { font-size: 24px; font-weight: 700; margin: 0 0 8px; }
  .hub-final-box p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin: 0 0 20px; }
  .hub-final-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hub-title { font-size: 30px; }
    .dzialy-grid-products { grid-template-columns: 1fr; }
  }
</style>
