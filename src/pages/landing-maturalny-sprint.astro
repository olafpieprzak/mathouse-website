---
// =====================================================
// LANDING PAGE: Maturalny sprint — 3 dni, 3 działy
// =====================================================
// URL: /landing-maturalny-sprint
// Toggle ON/OFF w: src/config/landingPages.js
// =====================================================
import Layout from '../layouts/Layout.astro';
import { isLandingEnabled, getLandingPage } from '../config/landingPages.js';
import KupTerazWidget from '../components/KupTerazWidget.astro';
import { produkty } from '../data/produkty.js';
const prod = produkty.maturalnySprint;

const SLUG = 'landing-maturalny-sprint';
const page = getLandingPage(SLUG);
const enabled = isLandingEnabled(SLUG);

if (!enabled) {
  return Astro.redirect('/404');
}

const planSprintu = [
  {
    dzien: 1,
    tytul: 'Pierwiastki · Procenty · Działania na liczbach',
    icon: '√',
    zakres: [
      'Pierwiastek arytmetyczny',
      'Pierwiastek sześcienny',
      'Działania na pierwiastkach',
      'Wyciąganie pierwiastków',
      'Włączanie czynnika pod pierwiastek',
      'Zamiana procentów na ułamki',
      'Procent z liczby',
      'Jakim procentem danej liczby jest druga liczba',
      'Podwyżki i obniżki',
      'Działania na liczbach'
    ]
  },
  {
    dzien: 2,
    tytul: 'Potęgi · Logarytmy · Funkcja wykładnicza i logarytmiczna',
    icon: '2ⁿ',
    zakres: [
      'Działania na potęgach',
      'Obliczanie logarytmu z liczby',
      'Dodawanie logarytmów',
      'Odejmowanie logarytmów',
      'Logarytm potęgi',
      'Wykres funkcji',
      'Zastosowanie praktyczne',
      'Monotoniczność / porównywanie liczb'
    ]
  },
  {
    dzien: 3,
    tytul: 'Wyrażenia algebraiczne · Wzory skróconego mnożenia',
    icon: '(a+b)²',
    zakres: [
      'Wyłączanie czynnika przed nawias',
      'Dodawanie, odejmowanie i mnożenie wyrażeń',
      'Kwadrat sumy',
      'Kwadrat różnicy',
      'Różnica kwadratów'
    ]
  },
];

const korzysci = [
  { icon: '🎯', tytul: 'Konkretny materiał bez lania wody', opis: 'Tylko to, co naprawdę zwiększy Twój wynik na maturze.' },
  { icon: '📋', tytul: 'Spokój i jasny plan', opis: 'Krok po kroku, dział po dziale. Wiesz dokładnie co i kiedy.' },
  { icon: '🎥', tytul: 'Dostęp do nagrań 24/7', opis: 'Wracasz do każdego filmiku kiedy chcesz. Pauzujesz i powtarzasz, aż zrozumiesz.' },
  { icon: '📈', tytul: 'Widoczny progres od pierwszego dnia', opis: 'Po każdym dniu czujesz, że ogarniasz kolejny kawałek materiału.' },
  { icon: '🎯', tytul: 'Najczęstsze działy na maturze', opis: 'Te 3 działy pojawiają się regularnie. Żadnego zgadywania co jest ważne.' },
  { icon: '📝', tytul: 'Zadania maturalne do każdego działu', opis: 'Dokładnie te typy zadań, które zobaczysz na egzaminie.' },
  { icon: '🎓', tytul: 'Wsparcie 13 lat doświadczenia', opis: '1000+ uczniów. Wiem gdzie tracisz punkty i jak to zmienić.' },
  { icon: '💰', tytul: 'Więcej punktów na maturze', opis: 'Przerabiamy działy, na których najłatwiej zdobyć łatwe punkty.' },
];
---

<Layout
  title="Maturalny sprint z matematyki — 3 dni, 3 działy (67 zł)"
  description="3 dni intensywnej powtórki przed maturą z matematyki. 3 kluczowe działy, dostęp od razu po zakupie. Nagrania 24/7."
>
  <main class="lp-page">

    <!-- HERO -->
    <section class="lp-hero">
      <div class="container-content">
        <div class="lp-hero-grid">
          <div class="lp-hero-text">
            <div class="lp-hero-badge">🏃 SPRINT · 3 DNI · 3 DZIAŁY</div>
            <h1 class="lp-hero-title">
              Zabezpiecz punkty z działów,<br />
              <span class="lp-hero-accent">które wracają co roku.</span>
            </h1>
            <p class="lp-hero-sub">
              Opanuj <strong>3 działy, które robią różnicę</strong> w wyniku.<br />
              3 dni. 3 działy. Konkretny plan nauki.
            </p>

            <div class="lp-hero-price">
              <div class="lp-price-amount">67 zł</div>
              <div class="lp-price-note">za 3 działy od A do Z</div>
            </div>

            <a href={page.purchaseUrl} class="btn-primary lp-cta-btn">
              KUPUJĘ I ZACZYNAM →
            </a>
            <p class="lp-cta-note">⚡ Dostęp od razu po zakupie · oglądasz ile chcesz</p>
          </div>

          <div class="lp-hero-visual">
            <div class="lp-hero-card">
              <div class="lp-hero-card-num">3</div>
              <div class="lp-hero-card-label">DNI · 3 DZIAŁY</div>
              <div class="lp-hero-card-bottom">
                <div class="lp-hero-card-stat">
                  <strong>67 zł</strong>
                  <span>jedna stawka</span>
                </div>
                <div class="lp-hero-card-stat">
                  <strong>24/7</strong>
                  <span>dostęp</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="lp-problem">
      <div class="container-content">
        <div class="lp-problem-grid">
          <div class="lp-problem-text">
            <h2 class="lp-section-title">Matura za chwilę,<br /><span class="text-yellow">a Ty czujesz że jesteś w tyle?</span></h2>
            <ul class="lp-problem-list">
              <li>Zaczynasz czuć panikę bo nie wiesz jak się za to zabrać</li>
              <li>Ilość rzeczy do ogarnięcia Cię przytłacza</li>
              <li>Żeby zdać maturę, <strong>nie musisz wiedzieć wszystkiego</strong></li>
              <li>W sprincie skupiamy się na <strong>3 działach</strong>, dzięki którym zgarniesz łatwe punkty</li>
            </ul>
          </div>
          <div class="lp-problem-image">
            <div class="lp-problem-emoji">⏰</div>
          </div>
        </div>
      </div>
    </section>

    <!-- JAK -->
    <section class="lp-jak">
      <div class="container-content">
        <div class="section-label">JAK TO DZIAŁA</div>
        <h2 class="lp-section-title">Jak wygląda sprint?</h2>
        <div class="lp-jak-grid">
          <div class="lp-jak-card">
            <div class="lp-jak-icon">📅</div>
            <h3>3 kluczowe działy</h3>
            <p>3 dni intensywnej powtórki najczęściej pojawiających się działów na maturze podstawowej.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">⚡</div>
            <h3>Dostęp natychmiast</h3>
            <p>Wszystkie nagrania dostępne od razu po zakupie. Oglądasz kiedy Ci pasuje.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">🔄</div>
            <h3>Wracasz ile chcesz</h3>
            <p>Materiał dostępny 24/7. Pauzujesz, powtarzasz, aż zrozumiesz.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">📝</div>
            <h3>Zadania maturalne</h3>
            <p>Od jasnego wytłumaczenia do konkretnych zadań egzaminacyjnych.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">👨‍🏫</div>
            <h3>Prowadzi Olaf Pieprzak</h3>
            <p>13 lat doświadczenia. Praktyk, który wie gdzie tracisz punkty i jak to zmienić.</p>
          </div>
          <div class="lp-jak-card">
            <div class="lp-jak-icon">💪</div>
            <h3>1000+ uczniów</h3>
            <p>Sprawdzony format — pokażę Ci dokładnie te same metody, których uczę na korepetycjach.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KORZYŚCI -->
    <section class="lp-korzysci">
      <div class="container-content">
        <div class="section-label">CO ZYSKASZ?</div>
        <h2 class="lp-section-title">8 powodów dla których to się opłaca.</h2>
        <div class="lp-korzysci-grid">
          {korzysci.map((k) => (
            <div class="lp-korzysc">
              <div class="lp-korzysc-icon">{k.icon}</div>
              <div>
                <h3 class="lp-korzysc-title">{k.tytul}</h3>
                <p class="lp-korzysc-desc">{k.opis}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PLAN SPRINTU -->
    <section class="lp-plan">
      <div class="container-content">
        <div class="section-label">PLAN SPRINTU</div>
        <h2 class="lp-section-title">3 dni · 3 działy · cały materiał</h2>
        <p class="lp-plan-intro">
          Każdy dzień = jeden dział = 4 etapy:<br />
          <strong>1. Teoria</strong> → <strong>2. Praktyka</strong> → <strong>3. Zadania maturalne</strong> → <strong>4. Zadania do samodzielnej pracy</strong>
        </p>

        <div class="lp-plan-list">
          {planSprintu.map((d) => (
            <details class="lp-plan-item" open>
              <summary>
                <span class="lp-plan-day">DZIEŃ {d.dzien}</span>
                <span class="lp-plan-tytul">{d.tytul}</span>
                <span class="lp-plan-icon">{d.icon}</span>
              </summary>
              <ul class="lp-plan-zakres">
                {d.zakres.map((z) => <li>{z}</li>)}
              </ul>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CZY 3 DNI WYSTARCZĄ? -->
    <section class="lp-faq">
      <div class="container-content">
        <div class="lp-faq-box">
          <h2 class="lp-section-title">Czy 3 dni naprawdę wystarczą,<br />żeby nadrobić matematykę?</h2>
          <p class="lp-faq-text"><strong class="text-yellow">Nie</strong> — żeby opanować cały materiał.</p>
          <p class="lp-faq-text"><strong class="text-yellow">Tak</strong> — żeby zgarnąć punkty z podstawowych działów, które zawsze są na maturze.</p>

          <p class="lp-faq-explain">
            Osoba, która ogarnie działania na liczbach, procenty, pierwiastki, potęgi, logarytmy i wyrażenia algebraiczne,
            ma przećwiczoną <strong>konkretną część arkusza</strong> i solidne fundamenty, na których opiera się duża część zadań.
          </p>

          <p class="lp-faq-explain">
            Nie obiecuję, że będziesz mistrzem matematyki po 3 dniach.<br />
            Ale obiecuję, że <strong>będziesz wiedzieć jak rozwiązywać konkretne typy zadań</strong> z tych działów,
            i przestaniesz tracić na nich punkty, które wcześniej uciekały przez brak schematu lub stres.
          </p>
        </div>
      </div>
    </section>

    <!-- O MNIE -->
    <section class="lp-omnie">
      <div class="container-content">
        <div class="lp-omnie-grid">
          <div class="lp-omnie-image">
            <div class="lp-omnie-emoji">👨‍🏫</div>
            <div class="lp-omnie-stats">
              <div class="lp-omnie-stat"><strong>1000+</strong><span>uczniów</span></div>
              <div class="lp-omnie-stat"><strong>13 lat</strong><span>nauczania</span></div>
            </div>
          </div>
          <div class="lp-omnie-text">
            <div class="section-label">OLAF PIEPRZAK</div>
            <h2 class="lp-section-title">Ogarniemy to! Możesz mi zaufać.</h2>
            <p>
              Uczę matematyki <strong>od 2012 roku</strong> i przez ten czas pomogłem już ponad 1000 uczniom.
              Wszystko zaczęło się od pytań znajomych: "Olaf, mógłbyś mi wytłumaczyć matmę?" i tak zostało do dziś.
            </p>
            <p>
              Stworzyłem <strong>MATHOUSE</strong> bo brakowało miejsca gdzie matematyka byłaby wytłumaczona w prosty,
              czasem wręcz prymitywny sposób. Bez skomplikowanego języka, bez teoretyzowania.
              Konkretnie i na przykładach.
            </p>
            <p>
              Podczas sprintu pokażę Ci dokładnie te same metody i triki, których uczę na swoich kursach.
              Żebyś mógł je od razu zastosować podczas przygotowań i na maturze.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="lp-final">
      <div class="container-content">
        <div class="lp-final-box">
          <div class="section-label">DOŁĄCZ DO SPRINTU</div>
          <h2 class="lp-final-title">Maturalny sprint z matematyki<br /><span class="text-yellow">3 dni, 3 działy</span></h2>

          <div class="lp-final-features">
            <div class="lp-final-feature">✅ 3 pełne działy maturalne</div>
            <div class="lp-final-feature">✅ Dostęp do nagrań 24/7</div>
            <div class="lp-final-feature">✅ Zadania maturalne do każdego działu</div>
            <div class="lp-final-feature">✅ Materiały do samodzielnej pracy</div>
            <div class="lp-final-feature">⚡ Dostęp natychmiast po zakupie</div>
            <div class="lp-final-feature">🔄 Wracasz do materiału ile razy chcesz</div>
          </div>

          <div class="lp-final-price">
            <div class="lp-final-price-label">CENA</div>
            <div class="lp-final-price-amount">67 zł</div>
            <div class="lp-final-price-compare">to mniej niż 1h korepetycji. A dostajesz 3 działy od A do Z.</div>
          </div>

          <a href={page.purchaseUrl} class="btn-primary lp-cta-btn lp-cta-final">
            KUPUJĘ SPRINT →
          </a>

          <p class="lp-final-bottom">
            <strong>Twoja przepustka do zdanej matury.</strong><br />
            3 dni wystarczą, żeby uporządkować kluczowy materiał i podejść do matury z większym spokojem.
          </p>
        </div>
      </div>
    </section>

    <!-- KOSZYK / WIDGET ZAKUPOWY -->
    {prod.sklepEmbedId ? (
      <KupTerazWidget embedId={prod.sklepEmbedId} productName="3-dniowy Maturalny Sprint" price={prod.price} priceOld={prod.priceOld} priceMin30Days={prod.priceMin30Days} />
    ) : (
      <section id="kup-teraz" class="lp-checkout-fallback">
        <div class="container-content">
          <h2 class="lp-cf-title">Gotowy zabezpieczyć punkty?</h2>
          <p class="lp-cf-sub">Dostęp od razu po zakupie. 3 działy, które wracają co roku.</p>
          {prod.sklepUrl ? (
            <a href={prod.sklepUrl} target="_blank" rel="noopener" class="btn-primary lp-cf-btn">🛒 Kup sprint · {prod.price} zł →</a>
          ) : (
            <a href="/kontakt" class="btn-primary lp-cf-btn">📩 Napisz do mnie po dostęp →</a>
          )}
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
  /* === Te same style jak w landing-powtorka-14-dni === */
  .lp-page { color: #EBEEFF; }
  .text-yellow { color: #FFDE59; }

  .lp-hero {
    padding: 60px 0 80px;
    background: linear-gradient(180deg, rgba(255,222,89,0.04) 0%, transparent 100%);
  }
  .lp-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .lp-hero-badge {
    display: inline-block;
    background: rgba(63, 206, 207, 0.1);
    border: 1px solid rgba(63, 206, 207, 0.3);
    color: #3FCECF;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }
  .lp-hero-title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin-bottom: 20px;
  }
  .lp-hero-accent { color: #FFDE59; }
  .lp-hero-sub {
    font-size: 18px;
    color: rgba(235, 238, 255, 0.75);
    line-height: 1.55;
    margin-bottom: 32px;
  }
  .lp-hero-price {
    display: inline-block;
    background: rgba(255, 222, 89, 0.1);
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 14px;
    padding: 16px 22px;
    margin-bottom: 24px;
  }
  .lp-price-amount {
    font-size: 36px;
    font-weight: 700;
    color: #FFDE59;
    line-height: 1;
  }
  .lp-price-note { font-size: 12px; color: rgba(235, 238, 255, 0.6); margin-top: 4px; }
  .lp-cta-btn { display: inline-block; font-size: 16px; padding: 16px 32px; }
  .lp-cta-note { font-size: 13px; color: rgba(235, 238, 255, 0.5); margin-top: 14px; }

  .lp-hero-card {
    background: linear-gradient(135deg, rgba(255,222,89,0.15) 0%, rgba(63,206,207,0.1) 100%);
    border: 1px solid rgba(255,222,89,0.3);
    border-radius: 24px;
    padding: 36px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .lp-hero-card-num {
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    color: #FFDE59;
    font-family: 'Instrument Serif', serif;
  }
  .lp-hero-card-label { font-size: 14px; letter-spacing: 4px; color: rgba(235, 238, 255, 0.7); margin-top: 4px; margin-bottom: 32px; }
  .lp-hero-card-bottom { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding-top: 24px; border-top: 1px solid rgba(235, 238, 255, 0.1); }
  .lp-hero-card-stat strong { display: block; font-size: 22px; color: #3FCECF; margin-bottom: 2px; }
  .lp-hero-card-stat span { font-size: 11px; color: rgba(235, 238, 255, 0.5); letter-spacing: 1px; }

  .lp-problem { padding: 60px 0; background: rgba(255, 255, 255, 0.02); }
  .lp-problem-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 60px; align-items: center; }
  .lp-section-title { font-size: 36px; font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin: 8px 0 24px; }
  .lp-problem-list { list-style: none; padding: 0; margin: 0; }
  .lp-problem-list li { font-size: 16px; color: rgba(235, 238, 255, 0.75); line-height: 1.6; padding: 12px 0 12px 28px; position: relative; }
  .lp-problem-list li:before { content: '→'; color: #FFDE59; position: absolute; left: 0; font-weight: 700; }
  .lp-problem-emoji { font-size: 140px; text-align: center; opacity: 0.7; }

  .lp-jak { padding: 80px 0; }
  .lp-jak-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 32px; }
  .lp-jak-card { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(235, 238, 255, 0.08); border-radius: 14px; padding: 24px; transition: all 0.2s ease; }
  .lp-jak-card:hover { border-color: rgba(63, 206, 207, 0.3); transform: translateY(-2px); }
  .lp-jak-icon { font-size: 36px; margin-bottom: 14px; }
  .lp-jak-card h3 { font-size: 17px; font-weight: 600; margin: 0 0 8px; }
  .lp-jak-card p { font-size: 13px; color: rgba(235, 238, 255, 0.65); line-height: 1.6; margin: 0; }

  .lp-korzysci { padding: 80px 0; background: rgba(255, 255, 255, 0.02); }
  .lp-korzysci-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; margin-top: 32px; }
  .lp-korzysc { display: flex; gap: 16px; align-items: flex-start; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(235, 238, 255, 0.08); border-radius: 14px; padding: 20px; }
  .lp-korzysc-icon { font-size: 24px; flex-shrink: 0; }
  .lp-korzysc-title { font-size: 15px; font-weight: 600; margin: 0 0 6px; }
  .lp-korzysc-desc { font-size: 13px; color: rgba(235, 238, 255, 0.65); line-height: 1.55; margin: 0; }

  /* PLAN */
  .lp-plan { padding: 80px 0; background: rgba(255, 255, 255, 0.02); }
  .lp-plan-intro { font-size: 15px; color: rgba(235, 238, 255, 0.65); line-height: 1.7; margin-bottom: 32px; }
  .lp-plan-intro strong { color: #FFDE59; }
  .lp-plan-list { display: flex; flex-direction: column; gap: 12px; }
  .lp-plan-item { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(235, 238, 255, 0.08); border-radius: 12px; overflow: hidden; }
  .lp-plan-item summary {
    padding: 18px 22px;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: center;
    list-style: none;
    transition: all 0.15s ease;
  }
  .lp-plan-item summary::-webkit-details-marker { display: none; }
  .lp-plan-item summary:hover { background: rgba(255, 222, 89, 0.05); }
  .lp-plan-day { background: rgba(255, 222, 89, 0.15); color: #FFDE59; padding: 6px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; min-width: 70px; text-align: center; }
  .lp-plan-tytul { font-size: 16px; font-weight: 600; color: #EBEEFF; }
  .lp-plan-icon { font-family: 'Instrument Serif', serif; font-style: italic; color: #3FCECF; font-size: 20px; }
