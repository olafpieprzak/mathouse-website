<!-- =============== LOGIKA KALKULATORA (1:1 z oryginału) =============== -->
<script is:inline>
const ALPHA = ['a','b','c','d','e','f','g','h','i','j','k'];

let degree = 4;
let rootMode = 'real';
let solveMethod = 'horner';
let useNWW = false;

let _pendingQuadCoeffs = null;
let _pendingFoundRoots = null;
let _pendingHtmlBefore = '';

function setMode(m) {
  rootMode = m;
  document.getElementById('btn-real').classList.toggle('active', m==='real');
  document.getElementById('btn-complex').classList.toggle('active', m==='complex');
  document.getElementById('mode-hint').textContent =
    m==='real' ? 'Tylko pierwiastki rzeczywiste' : 'Wszystkie pierwiastki (łącznie z zespolonymi)';
  clearResults();
}

function setNWW(val) {
  useNWW = val;
  document.getElementById('btn-nww-yes').classList.toggle('active', val);
  document.getElementById('btn-nww-no').classList.toggle('active', !val);
  document.getElementById('nww-hint').textContent = val
    ? 'Kandydaci wyznaczani z wielomianu o współczynnikach całkowitych'
    : 'Szukaj pierwiastków bez zamiany na liczby całkowite';
  clearResults();
}

function setMethod(m) {
  solveMethod = m;
  document.getElementById('btn-delta').classList.toggle('active', m==='delta');
  document.getElementById('btn-horner').classList.toggle('active', m==='horner');
  document.getElementById('method-hint').textContent =
    m==='delta' ? 'Wyróżnik (delta) + wzory kwadratowe' : 'Metoda Hornera';
  clearResults();
}

function updateMethodToggle() {
  const tog = document.getElementById('method-toggle');
  tog.style.display = degree === 2 ? 'flex' : 'none';
}

function setDegreeN(btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('n-degree-panel').style.display = 'block';
  const picks = document.querySelectorAll('.deg-pick');
  const anyActive = Array.from(picks).some(p => p.classList.contains('active'));
  if (!anyActive) pickN(6);
  updateMethodToggle();
}

function pickN(n) {
  document.querySelectorAll('.deg-pick').forEach(b => b.classList.remove('active'));
  const btn = Array.from(document.querySelectorAll('.deg-pick')).find(b => b.textContent == n);
  if (btn) btn.classList.add('active');
  degree = n;
  buildGrid();
  clearResults();
  updateMethodToggle();
}

function setDegree(n, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('n-degree-panel').style.display = 'none';
  document.querySelectorAll('.deg-pick').forEach(b => b.classList.remove('active'));
  degree = n;
  buildGrid();
  clearResults();
  updateMethodToggle();
}

function buildGrid() {
  const grid = document.getElementById('coeff-grid');
  grid.innerHTML = '';
  const total = degree + 1;

  for (let i = 0; i < total; i++) {
    const power = degree - i;
    const letter = ALPHA[i] || ('a' + i);

    let powerLabel;
    if (power === 0) powerLabel = '(wyraz wolny)';
    else if (power === 1) powerLabel = '· x';
    else powerLabel = '· x' + toSup(power);

    const cell = document.createElement('div');
    cell.className = 'coeff-cell';
    const examples = ['3','−2','1/2','−3/4','5','−1/3','2/5','7','−4','1/5','−2/3'];
    const examplePh = examples[i % examples.length];
    cell.innerHTML = `
      <div class="coeff-letter">
        <span class="letter-main">${letter}</span>
        <span class="letter-power">${powerLabel}</span>
      </div>
      <input type="text" class="coeff-input" id="coeff_${power}" placeholder="${examplePh}">
    `;
    grid.appendChild(cell);

    if (i < total - 1) {
      const sep = document.createElement('div');
      sep.className = 'coeff-sep';
      sep.id = 'sep_' + i;
      sep.textContent = '+';
      grid.appendChild(sep);
    }

    cell.querySelector('input').addEventListener('input', (e) => {
      validateCoeffInput(e.target);
      updateSeps();
      updateEquation();
    });
  }

  const eqSep = document.createElement('div');
  eqSep.className = 'coeff-sep';
  eqSep.style.cssText = 'font-size:1.3rem;color:#050A24;font-weight:700;padding-bottom:8px;min-width:26px;text-align:center;';
  eqSep.textContent = '=';
  grid.appendChild(eqSep);

  const rhsCell = document.createElement('div');
  rhsCell.className = 'coeff-cell';
  rhsCell.innerHTML = `
    <div class="coeff-letter">
      <span class="letter-main" style="font-style:normal;color:#050A24;">?</span>
      <span class="letter-power">(prawa strona)</span>
    </div>
    <input type="text" class="coeff-input" id="coeff_rhs" placeholder="np. 17/5">
  `;
  grid.appendChild(rhsCell);
  rhsCell.querySelector('input').addEventListener('input', updateEquation);

  updateEquation();
  updateMethodToggle();
}

function toSup(n) {
  const m = {'0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹'};
  return String(n).split('').map(c => m[c] || c).join('');
}

function updateSeps() {
  const total = degree + 1;
  for (let i = 0; i < total - 1; i++) {
    const nextPower = degree - (i + 1);
    const inp = document.getElementById('coeff_' + nextPower);
    const sep = document.getElementById('sep_' + i);
    if (!sep || !inp) continue;
    const v = parseFloat(inp.value) || 0;
    sep.textContent = v < 0 ? '−' : '+';
    sep.style.color = v < 0 ? '#c0392b' : '#bbb';
  }
}

function getRHS() {
  const el = document.getElementById('coeff_rhs');
  return el ? parseFrac(el.value) : 0;
}

function validateCoeffInput(inp) {
  const val = inp.value.trim();
  if (!val || val === '-') { inp.style.borderColor = ''; return; }
  const parsed = parseFrac(val);
  if (isNaN(parsed)) {
    inp.style.borderColor = '#E74C3C';
    inp.title = 'Niepoprawny format. Wpisz liczbę lub ułamek np. 17/5';
  } else {
    inp.style.borderColor = '#2ECC71';
    inp.title = '';
  }
}

function parseFrac(str) {
  if (!str || str.trim() === '') return 0;
  str = str.trim().replace(',', '.');
  if (str.includes('/')) {
    const parts = str.split('/');
    if (parts.length === 2) {
      const num = parseFloat(parts[0]);
      const den = parseFloat(parts[1]);
      if (!isNaN(num) && !isNaN(den) && den !== 0) return num / den;
    }
    return 0;
  }
  return parseFloat(str) || 0;
}

function getCoeffs() {
  return Array.from({length: degree+1}, (_,i) => {
    const el = document.getElementById('coeff_' + (degree-i));
    return el ? parseFrac(el.value) : 0;
  });
}

function getCoeffsForSolve() {
  const c = getCoeffs();
  const rhs = getRHS();
  const result = [...c];
  result[result.length - 1] -= rhs;
  return result;
}

function fmtN(v) {
  if (Number.isInteger(v)) return String(v);
  return parseFloat(v.toFixed(8)).toString();
}

function toFrac(v, maxDen=1000) {
  if (v === 0) return '0';
  const neg = v < 0;
  v = Math.abs(v);
  if (Number.isInteger(v) || Math.abs(v - Math.round(v)) < 1e-9) {
    return (neg ? '-' : '') + Math.round(v);
  }
  let bestP = 1, bestQ = 1, bestErr = Infinity;
  for (let q = 2; q <= maxDen; q++) {
    const p = Math.round(v * q);
    const err = Math.abs(v - p/q);
    if (err < bestErr && err < 1e-9) {
      bestErr = err; bestP = p; bestQ = q;
    }
    if (err < 1e-9) break;
  }
  if (bestErr < 1e-9 && bestQ > 1) {
    const g = gcdFrac(bestP, bestQ);
    return (neg ? '-' : '') + (bestP/g) + '/' + (bestQ/g);
  }
  if (Number.isInteger(v)) return (neg?'-':'') + v;
  return (neg?'-':'') + parseFloat(v.toFixed(6)).toString();
}

function gcdFrac(a, b) { a=Math.abs(a); b=Math.abs(b); while(b){[a,b]=[b,a%b];} return a||1; }

function fracHtml(v) {
  if (v === 0) return '<span class="mnum">0</span>';
  const neg = v < 0;
  const abs = Math.abs(v);
  if (Number.isInteger(abs) || Math.abs(abs - Math.round(abs)) < 1e-9) {
    return `<span class="mnum">${Math.round(abs)}</span>`;
  }
  let bestP = 1, bestQ = 1, bestErr = Infinity;
  for (let q = 2; q <= 1000; q++) {
    const p = Math.round(abs * q);
    const err = Math.abs(abs - p/q);
    if (err < bestErr && err < 1e-9) { bestErr = err; bestP = p; bestQ = q; }
    if (err < 1e-9) break;
  }
  if (bestErr < 1e-9 && bestQ > 1) {
    const g = gcdFrac(bestP, bestQ);
    const p = bestP/g, q = bestQ/g;
    return `<span class="mfrac">${neg?'<span class="mfrac-neg">&minus;</span>':''}<span class="mfrac-inner"><span class="mfrac-num">${p}</span><span class="mfrac-bar"></span><span class="mfrac-den">${q}</span></span></span>`;
  }
  return `<span class="mnum">${(neg?'-':'') + parseFloat(abs.toFixed(6))}</span>`;
}

function renderMath(coeffs, rhs) {
  let html = '<span class="math-display">';
  let first = true;
  for (let i = 0; i <= degree; i++) {
    const power = degree - i;
    const v = coeffs[i];
    if (v === 0) continue;
    const absV = Math.abs(v);
    const isInt = Number.isInteger(absV) || Math.abs(absV - Math.round(absV)) < 1e-9;
    if (!first) {
      html += `<span class="mop">${v < 0 ? '&minus;' : '+'}</span>`;
    } else if (v < 0) {
      html += `<span class="mop" style="padding-right:3px">&minus;</span>`;
    }
    html += '<span class="mterm">';
    if (power === 0) {
      html += fracHtml(absV);
    } else {
      const skip = isInt && Math.round(absV) === 1;
      if (!skip) {
        html += `<span style="display:inline-flex;align-items:center;vertical-align:middle;">${fracHtml(absV)}</span>`;
      }
      if (power > 1) {
        html += `<span style="display:inline-flex;align-items:flex-start;vertical-align:middle;"><span class="mvar">x</span><span class="msup">${power}</span></span>`;
      } else {
        html += '<span class="mvar">x</span>';
      }
    }
    html += '</span>';
    first = false;
  }
  html += `<span class="meq">=</span>${fracHtml(rhs)}`;
  html += '</span>';
  return html;
}

function updateEquation() {
  updateSeps();
  const disp = document.getElementById('eq-display');
  const coeffs = getCoeffs();
  const rhs = getRHS();
  const allZero = coeffs.every(v => v === 0);
  if (allZero) {
    disp.innerHTML = '<span class="eq-zero">Równanie pojawi się tutaj...</span>';
    return;
  }
  disp.innerHTML = renderMath(coeffs, rhs);

  const hasNonInt = coeffs.some(v => v !== 0 && !(Number.isInteger(v) || Math.abs(v - Math.round(v)) < 1e-9))
                  || (rhs !== 0 && !(Number.isInteger(rhs) || Math.abs(rhs - Math.round(rhs)) < 1e-9));
  const nwwToggle = document.getElementById('nww-toggle');
  if (nwwToggle) nwwToggle.style.display = hasNonInt ? 'flex' : 'none';
}

function cadd(a,b){return[a[0]+b[0],a[1]+b[1]];}
function csub(a,b){return[a[0]-b[0],a[1]-b[1]];}
function cmul(a,b){return[a[0]*b[0]-a[1]*b[1],a[0]*b[1]+a[1]*b[0]];}
function cdiv(a,b){const d=b[0]*b[0]+b[1]*b[1];return[(a[0]*b[0]+a[1]*b[1])/d,(a[1]*b[0]-a[0]*b[1])/d];}
function cabs(a){return Math.sqrt(a[0]*a[0]+a[1]*a[1]);}
function ceval(c,z){let r=[0,0];for(let v of c)r=cadd(cmul(r,z),[v,0]);return r;}
function cderiv(c,z){const n=c.length-1;let r=[0,0];for(let i=0;i<n;i++)r=cadd(cmul(r,z),[c[i]*(n-i),0]);return r;}

function aberth(coeffs,n){
  const R=1+Math.max(...coeffs.slice(0,n).map((c,i)=>i>0?Math.pow(Math.abs(c/coeffs[0]),1/i):0).filter(isFinite));
  let z=Array.from({length:n},(_,k)=>{const a=2*Math.PI*k/n+0.3;return[R*Math.cos(a),R*Math.sin(a)];});
  for(let it=0;it<200;it++){
    let mx=0;
    z=z.map((zk,k)=>{
      const fz=ceval(coeffs,zk),dfz=cderiv(coeffs,zk);
      let sum=[0,0];
      for(let j=0;j<n;j++)if(j!==k)sum=cadd(sum,cdiv([1,0],csub(zk,z[j])));
      const delta=cdiv(fz,csub(dfz,cmul(fz,sum)));
      mx=Math.max(mx,cabs(delta));
      return csub(zk,delta);
    });
    if(mx<1e-13)break;
  }
  return z;
}

function solve() {
  clearResults();
  let coeffs = getCoeffsForSolve();
  while (coeffs.length > 1 && coeffs[0] === 0) coeffs.shift();
  const n = coeffs.length - 1;
  if (n === 0) { showError(coeffs[0]===0?'Każda liczba jest rozwiązaniem.':'Brak rozwiązań.'); return; }
  document.getElementById('spinner').style.display='inline-block';
  setTimeout(()=>{
    document.getElementById('spinner').style.display='none';
    if (n === 2 && solveMethod === 'delta') {
      solveDelta(coeffs);
    } else {
      solveHorner(coeffs, n);
    }
  }, 100);
}

function r8(v){return Math.round(v*1e8)/1e8;}

function renderQuadraticChoice(quadCoeffs, foundRootsSoFar, htmlBefore) {
  _pendingQuadCoeffs = quadCoeffs;
  _pendingFoundRoots = [...foundRootsSoFar];
  _pendingHtmlBefore = htmlBefore;
  return `
  <div class="step-block quad-choice-block">
    <div class="step-title">Pozostał wielomian kwadratowy</div>
    <p class="step-text">Po zredukowaniu wielomianu metodą Hornera pozostał wielomian stopnia 2:</p>
    <p class="step-text" style="font-family:'Josefin Sans',sans-serif;font-size:1.1rem;color:#050A24;margin:8px 0 14px;">
      <span class="math-inline">${polyToMath(quadCoeffs)}</span>
    </p>
    <p class="step-text"><strong>Wybierz metodę rozwiązania:</strong></p>
    <div style="display:flex;gap:10px;margin-top:10px;">
      <button class="btn-solve" style="font-size:.9rem;padding:9px 22px;" onclick="continueWithQuadMethod('delta')">Δ Delta</button>
      <button class="btn-clear" style="font-size:.9rem;padding:9px 22px;" onclick="continueWithQuadMethod('horner')">Horner</button>
    </div>
  </div>`;
}

function continueWithQuadMethod(method) {
  const quadCoeffs = _pendingQuadCoeffs;
  const foundRoots = _pendingFoundRoots;
  let html = _pendingHtmlBefore;
  const stepNum = foundRoots.length > 0 ? 'Krok ' + (foundRoots.length + 3) : 'Krok 3';

  if (method === 'delta') {
    const [a,b,c] = quadCoeffs;
    const delta = b*b - 4*a*c;
    const d8v = r8(delta);
    html += `<div class="step-block">`;
    html += `<div class="step-title">${stepNum} — Rozwiązanie metodą Δ (delta) dla: <span class="math-inline">${polyToMath(quadCoeffs)}</span></div>`;
    html += `<p class="step-text">Współczynniki: <strong>a = ${fmtR(a)}</strong>, <strong>b = ${fmtR(b)}</strong>, <strong>c = ${fmtR(c)}</strong></p>`;
    html += `<p class="step-text"><span class="math-inline">Δ = b² − 4ac = (${fmtR(b)})² − 4·${fmtR(a)}·${fmtR(c)} = ${fmtR(b*b)} − ${fmtR(4*a*c)} = <strong>${fmtR(d8v)}</strong></span></p>`;
    let quadRoots = [];
    if (d8v > 0) {
      const sqrtD = Math.sqrt(delta);
      const x1 = r8((-b+sqrtD)/(2*a)), x2 = r8((-b-sqrtD)/(2*a));
      html += `<p class="step-text"><strong>Δ > 0</strong> → dwa różne pierwiastki rzeczywiste</p>`;
      html += `<p class="step-text"><span class="math-inline">x = (−b ± √Δ) / (2a)</span></p>`;
      html += `<p class="step-text"><span class="math-inline">x₁ = (${fmtR(-b)} + ${fmtR(r8(sqrtD))}) / ${fmtR(2*a)} = <strong>${fmtR(x1)}</strong></span></p>`;
      html += `<p class="step-text"><span class="math-inline">x₂ = (${fmtR(-b)} − ${fmtR(r8(sqrtD))}) / ${fmtR(2*a)} = <strong>${fmtR(x2)}</strong></span></p>`;
      quadRoots = [{value:x1,label:fmtR(x1),type:'int'},{value:x2,label:fmtR(x2),type:'int'}];
    } else if (d8v === 0) {
      const x0 = r8(-b/(2*a));
      html += `<p class="step-text"><strong>Δ = 0</strong> → jeden pierwiastek podwójny: <span class="math-inline">x = ${fmtR(x0)}</span></p>`;
      quadRoots = [{value:x0,label:fmtR(x0),type:'int'},{value:x0,label:fmtR(x0),type:'int'}];
    } else {
      html += `<p class="step-text"><strong>Δ < 0</strong> → brak pierwiastków rzeczywistych</p>`;
      if (rootMode === 'complex') {
        const sqrtAbsD = Math.sqrt(-delta);
        const re = r8(-b/(2*a)), im = r8(sqrtAbsD/(2*a));
        html += `<p class="step-text"><span class="math-inline">x₁ = ${fmtR(re)} + ${fmtR(im)}i, &nbsp; x₂ = ${fmtR(re)} − ${fmtR(im)}i</span></p>`;
      }
    }
    html += `</div>`;
    renderFinalResults(html, foundRoots, quadRoots, delta < 0 && rootMode==='complex' ? [[-r8(b/(2*a*-1)), Math.sqrt(-delta)/(2*Math.abs(quadCoeffs[0]))]] : []);
  } else {
    const intCands2 = [];
    const p2 = Math.abs(Math.round(quadCoeffs[quadCoeffs.length-1]));
    divisors(p2||1).forEach(d=>{intCands2.push(d);if(d)intCands2.push(-d);});
    const cands2 = [...new Set(intCands2)].sort((a,b)=>a-b);
    html += `<div class="step-block">`;
    html += `<div class="step-title">${stepNum} — Horner dla: <span class="math-inline">${polyToMath(quadCoeffs)}</span></div>`;
    let checkRows = '', quadRoots = [], remQ = [...quadCoeffs];
    for (const cand of cands2) {
      const val = evalPolyAt(remQ, cand);
      const isRoot = isNearZero(val);
      checkRows += `<tr class="${isRoot?'check-yes':'check-no'}"><td>x = ${cand}</td><td>W(${cand}) = ${fmtR(val)}</td><td>${isRoot?'✓ pierwiastek':'✗'}</td></tr>`;
      if (isRoot && quadRoots.length < 2) {
        quadRoots.push({value:cand,label:String(cand),type:'int'});
        const {html:hHtml, quotient} = renderHornerTable(remQ, cand, String(cand));
        html += `</div><div class="step-block"><div class="step-title">Schemat Hornera — x = ${cand}</div>${hHtml}</div><div class="step-block"><div class="step-title">Kontynuacja sprawdzania</div>`;
        remQ = quotient.map(v=>Math.round(v*1e9)/1e9);
      }
    }
    html += `<table class="check-table"><tbody>${checkRows}</tbody></table></div>`;
    renderFinalResults(html, foundRoots, quadRoots, []);
  }
}

function renderFinalResults(html, foundRoots, quadRoots, complexExtra) {
  const allReal = [...foundRoots, ...quadRoots];
  html += `<div class="step-block results-final"><div class="step-title">Wyniki</div>`;
  if (rootMode === 'real') {
    if (allReal.length === 0) {
      html += `<div class="no-real-roots">Brak pierwiastków rzeczywistych.</div>`;
    } else {
      html += `<ul class="roots-list">`;
      allReal.forEach((r,i)=>{
        const badge = r.type==='int'?'całkowity':r.type==='rat'?'wymierny':'numeryczny';
        html += `<li class="root-item"><span class="root-idx">x<sub>${i+1}</sub></span> = ${r.label} <span class="root-type">${badge}</span></li>`;
      });
      html += `</ul>`;
    }
  } else {
    if (allReal.length > 0) {
      html += `<ul class="roots-list">`;
      allReal.forEach((r,i)=>{
        const badge = r.type==='int'?'całkowity':r.type==='rat'?'wymierny':'numeryczny';
        html += `<li class="root-item"><span class="root-idx">x<sub>${i+1}</sub></span> = ${r.label} <span class="root-type">${badge}</span></li>`;
      });
      html += `</ul>`;
    }
    if (complexExtra.length > 0) {
      html += `<ul class="roots-list">`;
      let ci = allReal.length + 1;
      complexExtra.forEach(r=>{
        const re = r8(r[0]), im = r8(Math.abs(r[1]));
        html += `<li class="root-item complex"><span class="root-idx">x<sub>${ci++}</sub></span> = ${fmtR(re)} + ${fmtR(im)}i <span class="root-type">zespolony</span></li>`;
        html += `<li class="root-item complex"><span class="root-idx">x<sub>${ci++}</sub></span> = ${fmtR(re)} − ${fmtR(im)}i <span class="root-type">zespolony</span></li>`;
      });
      html += `</ul>`;
    }
  }
  html += `</div>`;
  document.getElementById('results-content').innerHTML = html;
}

function solveDelta(coeffs) {
  const panel = document.getElementById('results-panel');
  panel.classList.add('visible');
  const [a, b, c] = coeffs;
  const delta = b*b - 4*a*c;
  const d8 = r8(delta);
  let html = '';
  html += `<p class="solve-intro">Rozwiązanie równania kwadratowego <span class="math-inline">${polyToMath(coeffs)}</span> metodą wyróżnika (delta):</p>`;
  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 1 — Postać ogólna i identyfikacja współczynników</div>`;
  html += `<p class="step-text">Równanie kwadratowe: <span class="math-inline">ax² + bx + c = 0</span></p>`;
  html += `<p class="step-text">Odczytujemy współczynniki:<br>&emsp;<strong>a = ${fmtR(a)}</strong> &emsp; <strong>b = ${fmtR(b)}</strong> &emsp; <strong>c = ${fmtR(c)}</strong></p>`;
  html += `</div>`;
  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 2 — Obliczanie wyróżnika Δ (delta)</div>`;
  html += `<p class="step-text"><span class="math-inline">Δ = b² − 4ac</span></p>`;
  html += `<p class="step-text"><span class="math-inline">Δ = (${fmtR(b)})² − 4 · (${fmtR(a)}) · (${fmtR(c)})</span></p>`;
  html += `<p class="step-text"><span class="math-inline">Δ = ${fmtR(b*b)} − ${fmtR(4*a*c)}</span></p>`;
  html += `<p class="step-text"><strong><span class="math-inline">Δ = ${fmtR(d8)}</span></strong></p>`;
  html += `</div>`;
  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 3 — Interpretacja wyróżnika</div>`;
  if (d8 > 0) {
    html += `<p class="step-text"><strong>Δ > 0</strong> → równanie ma <strong>dwa różne pierwiastki rzeczywiste</strong></p>`;
    html += `<p class="step-text"><span class="math-inline">x = (−b ± √Δ) / (2a)</span></p>`;
  } else if (d8 === 0) {
    html += `<p class="step-text"><strong>Δ = 0</strong> → równanie ma <strong>jeden pierwiastek rzeczywisty (podwójny)</strong></p>`;
    html += `<p class="step-text"><span class="math-inline">x = −b / (2a)</span></p>`;
  } else {
    html += `<p class="step-text"><strong>Δ < 0</strong> → równanie <strong>nie ma pierwiastków rzeczywistych</strong></p>`;
    if (rootMode === 'complex') {
      html += `<p class="step-text">Pierwiastki zespolone: <span class="math-inline">x = (−b ± i√|Δ|) / (2a)</span></p>`;
    }
  }
  html += `</div>`;
  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 4 — Obliczenie pierwiastków</div>`;
  if (d8 > 0) {
    const sqrtD = Math.sqrt(delta);
    const x1 = r8((-b + sqrtD)/(2*a));
    const x2 = r8((-b - sqrtD)/(2*a));
    html += `<p class="step-text"><span class="math-inline">√Δ = √${fmtR(d8)} ≈ ${fmtR(r8(sqrtD))}</span></p>`;
    html += `<p class="step-text"><span class="math-inline">x₁ = (−(${fmtR(b)}) + ${fmtR(r8(sqrtD))}) / (2 · ${fmtR(a)}) = ${fmtR((-b+sqrtD))} / ${fmtR(2*a)} = <strong>${fmtR(x1)}</strong></span></p>`;
    html += `<p class="step-text"><span class="math-inline">x₂ = (−(${fmtR(b)}) − ${fmtR(r8(sqrtD))}) / (2 · ${fmtR(a)}) = ${fmtR((-b-sqrtD))} / ${fmtR(2*a)} = <strong>${fmtR(x2)}</strong></span></p>`;
    html += `</div>`;
    html += `<div class="step-block results-final"><div class="step-title">Wyniki</div>`;
    html += `<ul class="roots-list">`;
    html += `<li class="root-item"><span class="root-idx">x<sub>1</sub></span> = ${fmtR(x1)} <span class="root-type">rzeczywisty</span></li>`;
    html += `<li class="root-item"><span class="root-idx">x<sub>2</sub></span> = ${fmtR(x2)} <span class="root-type">rzeczywisty</span></li>`;
    html += `</ul></div>`;
  } else if (d8 === 0) {
    const x0 = r8(-b/(2*a));
    html += `<p class="step-text"><span class="math-inline">x = −b / (2a) = −(${fmtR(b)}) / (2 · ${fmtR(a)}) = ${fmtR(-b)} / ${fmtR(2*a)} = <strong>${fmtR(x0)}</strong></span></p>`;
    html += `</div>`;
    html += `<div class="step-block results-final"><div class="step-title">Wynik</div>`;
    html += `<ul class="roots-list">`;
    html += `<li class="root-item"><span class="root-idx">x<sub>1,2</sub></span> = ${fmtR(x0)} <span class="root-type">podwójny</span></li>`;
    html += `</ul></div>`;
  } else {
    html += `<p class="step-text">Brak pierwiastków rzeczywistych (Δ < 0).</p>`;
    if (rootMode === 'complex') {
      const sqrtAbsD = Math.sqrt(-delta);
      const re = r8(-b/(2*a));
      const im = r8(sqrtAbsD/(2*a));
      html += `<p class="step-text"><span class="math-inline">√|Δ| = √${fmtR(r8(-delta))} ≈ ${fmtR(r8(sqrtAbsD))}</span></p>`;
      html += `<p class="step-text"><span class="math-inline">x₁ = ${fmtR(re)} + ${fmtR(im)}i</span></p>`;
      html += `<p class="step-text"><span class="math-inline">x₂ = ${fmtR(re)} − ${fmtR(im)}i</span></p>`;
      html += `</div>`;
      html += `<div class="step-block results-final"><div class="step-title">Wyniki (zespolone)</div>`;
      html += `<ul class="roots-list">`;
      html += `<li class="root-item complex"><span class="root-idx">x<sub>1</sub></span> = ${fmtR(re)} + ${fmtR(im)}i <span class="root-type">zespolony</span></li>`;
      html += `<li class="root-item complex"><span class="root-idx">x<sub>2</sub></span> = ${fmtR(re)} − ${fmtR(im)}i <span class="root-type">zespolony</span></li>`;
      html += `</ul></div>`;
    } else {
      html += `</div>`;
      html += `<div class="step-block results-final"><div class="step-title">Wynik</div>`;
      html += `<div class="no-real-roots">Brak pierwiastków rzeczywistych (Δ < 0). Przełącz na <em>Zespolone</em>, aby zobaczyć pierwiastki zespolone.</div>`;
      html += `</div>`;
    }
  }
  document.getElementById('results-content').innerHTML = html;
}

function evalPolyAt(c, x) {
  let r = 0;
  for (let v of c) r = r * x + v;
  return r;
}

function hornerScheme(coeffs, r) {
  const steps = [coeffs[0]];
  let cur = coeffs[0];
  for (let i = 1; i < coeffs.length; i++) {
    cur = cur * r + coeffs[i];
    steps.push(cur);
  }
  return { remainder: steps[steps.length-1], quotient: steps.slice(0,-1), steps };
}

function gcd(a, b) { a=Math.abs(a); b=Math.abs(b); while(b){[a,b]=[b,a%b];} return a; }

function divisors(n) {
  n = Math.abs(Math.round(n));
  if (n === 0) return [];
  const d = [];
  for (let i = 1; i <= n; i++) if (n % i === 0) d.push(i);
  return d;
}

function isNearInt(v, eps=1e-9) { return Math.abs(v - Math.round(v)) < eps; }
function isNearZero(v, eps=1e-7) { return Math.abs(v) < eps; }

function renderHornerTable(coeffs, root, rootLabel) {
  const h = hornerScheme(coeffs, root);
  const n = coeffs.length - 1;
  const muls = [''];
  for (let i = 0; i < n; i++) muls.push(fmtR(h.steps[i] * root));
  let html = `
  <div class="horner-label">Schemat Hornera dla <strong>x = ${rootLabel}</strong>:</div>
  <div class="horner-wrap">
  <table class="horner-table">
    <tr class="hn-coeff">
      <td class="hn-r-empty"></td>
      ${coeffs.map(c=>`<td>${fmtR(c)}</td>`).join('')}
    </tr>
    <tr class="hn-mul">
      <td class="hn-r">${rootLabel}</td>
      ${muls.map(m=>`<td>${m}</td>`).join('')}
    </tr>
    <tr class="hn-result">
      <td></td>
      ${h.steps.map((s,i)=>`<td class="${i===h.steps.length-1?'hn-rem':''}">${fmtR(s)}</td>`).join('')}
    </tr>
  </table>
  </div>
  <p class="horner-note">Reszta = <strong>${fmtR(h.remainder)}</strong> ${isNearZero(h.remainder)?'✓ (x = '+rootLabel+' jest pierwiastkiem)':''}</p>
  <p class="horner-note">Wielomian po podzieleniu: <span class="math-inline">${polyToMath(h.quotient)}</span></p>
  `;
  return { html, quotient: h.quotient };
}

function fmtR(v) {
  if (isNearInt(v)) return String(Math.round(v));
  const f = toFrac(v);
  if (f && f.includes('/')) return f;
  return parseFloat(v.toFixed(4)).toString();
}

function polyToMath(c) {
  const n = c.length - 1;
  let s = '', first = true;
  for (let i = 0; i <= n; i++) {
    const p = n - i, v = c[i];
    if (isNearZero(v, 1e-9)) continue;
    const absV = Math.abs(v);
    const isOne = (isNearInt(absV) && Math.round(absV)===1);
    const sign = v < 0 ? (first?'&minus;':' &minus; ') : (first?'':' + ');
    const numStr = isOne && p>0 ? '' : toFrac(absV);
    let vp;
    if (p === 0) vp = toFrac(absV);
    else if (p === 1) vp = numStr+'<i>x</i>';
    else vp = numStr+'<i>x</i><sup>'+p+'</sup>';
    s += sign + vp;
    first = false;
  }
  return s || '0';
}

function candHtml(v) {
  const neg = v < 0;
  const abs = Math.abs(v);
  let bestP = 1, bestQ = 1, bestErr = Infinity;
  for (let q = 2; q <= 1000; q++) {
    const p = Math.round(abs * q);
    const err = Math.abs(abs - p/q);
    if (err < 1e-9) { bestP = p; bestQ = q; break; }
  }
  const g = gcdFrac(bestP, bestQ);
  const p = bestP/g, q = bestQ/g;
  if (q === 1) return `<span class="cand">${neg?'-':''}${p}</span>`;
  return `<span class="cand cand-frac">${neg?'<span class="cf-neg">&minus;</span>':''}<span class="cf-inner"><span class="cf-num">${p}</span><span class="cf-bar"></span><span class="cf-den">${q}</span></span></span>`;
}

function getFracPQ(v) {
  const neg = v < 0;
  const abs = Math.abs(v);
  if (Number.isInteger(abs) || Math.abs(abs-Math.round(abs)) < 1e-9) {
    return { p: Math.abs(Math.round(v)), q: 1 };
  }
  for (let q = 2; q <= 10000; q++) {
    const p = Math.round(abs * q);
    if (Math.abs(abs - p/q) < 1e-9) {
      const g = gcdFrac(p, q);
      return { p: p/g, q: q/g };
    }
  }
  return { p: Math.round(abs * 100), q: 100 };
}

function solveHorner(origCoeffs, origN) {
  const panel = document.getElementById('results-panel');
  panel.classList.add('visible');
  let html = '';
  let foundRoots = [];
  let remainingCoeffs = [...origCoeffs];
  let hornerSections = '';
  html += `<p class="solve-intro">Rozwiązanie równania wielomianowego stopnia <strong>${origN}</strong> metodą Hornera:</p>`;

  const hasNonIntCoeffs = origCoeffs.some(c => !(Number.isInteger(c) || Math.abs(c-Math.round(c)) < 1e-9));
  const lcmCoeffs = (useNWW && hasNonIntCoeffs) ? toIntCoeffs(origCoeffs) : origCoeffs.map(c => Math.round(c*1e9)/1e9);
  let leadInt, constInt, divP, divQ;
  if (!useNWW && hasNonIntCoeffs) {
    const a0 = origCoeffs[origCoeffs.length-1];
    const an = origCoeffs[0];
    const fracA0 = getFracPQ(a0);
    const fracAn = getFracPQ(an);
    constInt = fracA0.p;
    leadInt = fracAn.p;
    divP = divisors(constInt || 1);
    divQ = divisors(leadInt || 1);
  } else {
    constInt = Math.abs(Math.round(lcmCoeffs[lcmCoeffs.length - 1]));
    leadInt = Math.abs(Math.round(lcmCoeffs[0]));
    divP = divisors(constInt || 1);
    divQ = divisors(leadInt || 1);
  }

  const allCands = [];
  divP.forEach(p2 => divQ.forEach(q2 => {
    const v = p2/q2;
    allCands.push(v);
    if (v !== 0) allCands.push(-v);
  }));
  const candMap = new Map();
  allCands.forEach(v => { const k = Math.round(v*1e9); if (!candMap.has(k)) candMap.set(k,v); });
  const allCandsSorted = [...candMap.values()].sort((a,b)=>a-b);
  const intCandsSorted = allCandsSorted.filter(v => Number.isInteger(v) || Math.abs(v-Math.round(v))<1e-9);
  const ratKrok1 = allCandsSorted.filter(v => !(Number.isInteger(v) || Math.abs(v-Math.round(v))<1e-9));

  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 1 — Kandydaci na pierwiastki wymierne (±p/q)</div>`;
  if (constInt === 0) {
    html += `<p class="step-text">Wyraz wolny = 0, więc <strong>x = 0</strong> jest pierwiastkiem.</p>`;
  } else {
    html += `<p class="step-text">Pierwiastki wymierne wielomianu mogą być tylko w postaci <strong>±p/q</strong>, gdzie <em>p</em> | a₀ (wyraz wolny) i <em>q</em> | aₙ (wsp. wiodący).</p>`;
    if (hasNonIntCoeffs) {
      if (useNWW) {
        html += `<p class="step-text">Współczynniki są ułamkowe — mnożymy przez NWW mianowników (×${Math.round(lcmCoeffs[0]/origCoeffs[0])}), uzyskując wielomian o współczynnikach całkowitych: <span class="math-inline">${polyToMath(lcmCoeffs)}</span></p>`;
        html += `<p class="step-text" style="font-size:.8rem;color:#7a8ab0;">Mnożenie przez stałą nie zmienia pierwiastków.</p>`;
      } else {
        html += `<p class="step-text">Współczynniki są ułamkowe. Wyznaczamy kandydatów bezpośrednio z ułamkowej postaci: <strong>a₀ = ${toFrac(origCoeffs[origCoeffs.length-1])}</strong>, <strong>aₙ = ${toFrac(origCoeffs[0])}</strong>.</p>`;
      }
    }
    html += `<p class="step-text">Wyraz wolny a₀ = <strong>${constInt}</strong>, dzielniki: <em>${divP.join(', ')}</em></p>`;
    html += `<p class="step-text">Wsp. wiodący aₙ = <strong>${leadInt}</strong>, dzielniki: <em>${divQ.join(', ')}</em></p>`;
    html += `<p class="step-text"><strong>Kandydaci całkowici (q=1):</strong> ${intCandsSorted.map(c=>`<span class="cand">${Math.round(c)}</span>`).join(' ')}</p>`;
    if (ratKrok1.length > 0) {
      html += `<p class="step-text"><strong>Kandydaci wymierni (q>1):</strong> ${ratKrok1.map(v=>candHtml(v)).join(' ')}</p>`;
    }
  }
  html += `</div>`;

  html += `<div class="step-block">`;
  html += `<div class="step-title">Krok 2 — Sprawdzenie kandydatów całkowitych</div>`;
  let checkRows = '';
  for (const cand of intCandsSorted) {
    if (remainingCoeffs.length <= 1) break;
    const val = evalPolyAt(remainingCoeffs, cand);
    const isRoot = isNearZero(val);
    const candLabel2 = (Number.isInteger(cand) || Math.abs(cand-Math.round(cand))<1e-9) ? String(Math.round(cand)) : toFrac(cand);
    checkRows += `<tr class="${isRoot?'check-yes':'check-no'}">
      <td>x = ${candLabel2}</td>
      <td>W(${candLabel2}) = ${fmtR(r8(val))}</td>
      <td>${isRoot ? '✓ pierwiastek' : '✗'}</td>
    </tr>`;
    if (isRoot) {
      foundRoots.push({value: cand, label: candLabel2, type: (Number.isInteger(cand)||Math.abs(cand-Math.round(cand))<1e-9)?'int':'rat'});
      const { html: hHtml, quotient } = renderHornerTable(remainingCoeffs, cand, String(cand));
      hornerSections += `<div class="step-block"><div class="step-title">Schemat Hornera — x = ${cand}</div>${hHtml}</div>`;
      remainingCoeffs = quotient.map(v => Math.round(v*1e9)/1e9);
      while (remainingCoeffs.length > 1 && isNearZero(evalPolyAt(remainingCoeffs, cand))) {
        foundRoots.push({value: cand, label: String(cand), type:'int'});
        const { html: hHtml2, quotient: q2 } = renderHornerTable(remainingCoeffs, cand, String(cand));
        hornerSections += `<div class="step-block"><div class="step-title">Schemat Hornera — x = ${cand} (wielokrotny)</div>${hHtml2}</div>`;
        remainingCoeffs = q2.map(v => Math.round(v*1e9)/1e9);
      }
    }
  }
  html += `<table class="check-table"><tbody>${checkRows}</tbody></table>`;
  html += `</div>`;
  html += hornerSections;
  hornerSections = '';

  if (remainingCoeffs.length > 2) {
    const remLcm = toIntCoeffs(remainingCoeffs);
    const remLead = Math.abs(Math.round(remLcm[0]));
    const remConst = Math.abs(Math.round(remLcm[remLcm.length-1]));
    const divP2 = divisors(remConst || 1);
    const divQ2 = divisors(remLead || 1);
    const ratSet = new Map();
    divP2.forEach(p2 => divQ2.forEach(q2 => {
      if (q2 === 1) return;
      const v = p2/q2;
      const key1 = Math.round(v*1e8);
      const key2 = Math.round(-v*1e8);
      if (!ratSet.has(key1)) ratSet.set(key1, v);
      if (!ratSet.has(key2)) ratSet.set(key2, -v);
    }));
    const foundVals = new Set(foundRoots.map(r=>Math.round(r.value*1e8)));
    const ratCands = [...ratSet.values()].filter(v => !foundVals.has(Math.round(v*1e8))).sort((a,b)=>a-b);

    if (ratCands.length > 0) {
      html += `<div class="step-block">`;
      html += `<div class="step-title">Krok 3 — Kandydaci na pierwiastki wymierne</div>`;
      html += `<p class="step-text">Wśród liczb całkowitych nie znaleziono wszystkich pierwiastków. Sprawdzamy ułamki <strong>±p/q</strong>:</p>`;
      html += `<p class="step-text"><strong>Kandydaci wymierni:</strong> ${ratCands.map(v => candHtml(v)).join(' ')}</p>`;
      html += `</div>`;
      html += `<div class="step-block">`;
      html += `<div class="step-title">Krok 4 — Sprawdzenie kandydatów wymiernych</div>`;
      let checkRows2 = '';
      for (const cand of ratCands) {
        if (remainingCoeffs.length <= 1) break;
        const val = evalPolyAt(remainingCoeffs, cand);
        const isRoot = isNearZero(val);
        const g = gcd(Math.round(Math.abs(cand)*10000), 10000);
        const num = Math.round(cand*10000/g);
        const den = Math.round(10000/g);
        const candStr = den===1 ? String(num) : num+'/'+den;
        checkRows2 += `<tr class="${isRoot?'check-yes':'check-no'}">
          <td>x = ${candStr}</td>
          <td>W(${candStr}) ≈ ${fmtR(r8(val))}</td>
          <td>${isRoot ? '✓ pierwiastek' : '✗'}</td>
        </tr>`;
        if (isRoot) {
          foundRoots.push({value: cand, label: candStr, type:'rat'});
          const {html: hHtml, quotient} = renderHornerTable(remainingCoeffs, cand, candStr);
          hornerSections += `<div class="step-block"><div class="step-title">Schemat Hornera — x = ${candStr}</div>${hHtml}</div>`;
          remainingCoeffs = quotient.map(v=>Math.round(v*1e9)/1e9);
        }
      }
      html += `<table class="check-table"><tbody>${checkRows2}</tbody></table>`;
      html += `</div>`;
      html += hornerSections;
      hornerSections = '';
    } else if (foundRoots.length === 0) {
      html += `<div class="step-block">`;
      html += `<div class="step-title">Krok 3 — Kandydaci wymierni</div>`;
      html += `<p class="step-text">Brak kandydatów wymiernych (poza całkowitymi).</p>`;
      html += `</div>`;
    }
  }

  if (remainingCoeffs.length === 3 && foundRoots.length > 0) {
    html += renderQuadraticChoice(remainingCoeffs, foundRoots, html);
    document.getElementById('results-content').innerHTML = html;
    return;
  }

  let numRoots = [];
  const stepN = foundRoots.length > 0 ? 5 : 3;

  if (remainingCoeffs.length > 1) {
    const remN = remainingCoeffs.length - 1;
    if (remN === 1) {
      const [a, b] = remainingCoeffs;
      const x0 = -b / a;
      foundRoots.push({value: x0, label: (Number.isInteger(x0)||Math.abs(x0-Math.round(x0))<1e-9) ? fmtR(x0) : toFrac(x0), type: 'rat'});
      numRoots = [];
      html += `<div class="step-block">`;
      html += `<div class="step-title">Krok ${stepN} — Równanie liniowe</div>`;
      html += `<p class="step-text">Pozostało równanie liniowe: <span class="math-inline">${polyToMath(remainingCoeffs)} = 0</span></p>`;
      html += `<p class="step-text"><span class="math-inline">${toFrac(a)} · x = ${toFrac(-b)}</span></p>`;
      html += `<p class="step-text">x = <span style="display:inline-flex;align-items:center;gap:3px;vertical-align:middle;">${fracHtml(-b)}<span style="margin:0 3px;">÷</span>${fracHtml(a)}</span> = <strong style="font-size:1.05em;">${x0 < 0 ? '&minus;' : ''}${fracHtml(Math.abs(x0)).replace('class="mnum"','class="mnum" style="font-size:1em;"')}</strong></p>`;
      html += `</div>`;
    } else if (remN === 2) {
      const [a,b,c] = remainingCoeffs;
      const disc = b*b - 4*a*c;
      if (disc >= 0) numRoots = [[(-b+Math.sqrt(disc))/(2*a),0],[(-b-Math.sqrt(disc))/(2*a),0]];
      else numRoots = [[-b/(2*a),Math.sqrt(-disc)/(2*a)],[-b/(2*a),-Math.sqrt(-disc)/(2*a)]];
    } else {
      numRoots = aberth(remainingCoeffs, remN);
      html += `<div class="step-block">`;
      html += `<div class="step-title">Krok ${stepN} — Metoda numeryczna (dla pozostałego wielomianu)</div>`;
      html += `<p class="step-text">Pozostały wielomian: <span class="math-inline">${polyToMath(remainingCoeffs)}</span> — brak wymiernych pierwiastków. Wyznaczam numerycznie (metoda Abertha–Weierstrassena):</p>`;
      html += `</div>`;
    }
  }

  const eps = 1e-6;
  const numReal = numRoots.filter(r=>Math.abs(r[1])<eps).map(r=>r[0]);
  const numCplx = numRoots.filter(r=>Math.abs(r[1])>=eps);

  const allReal = [
    ...foundRoots,
    ...numReal.map(r=>({label:fmtR(r8(r)), value:r, type:'num'}))
  ];

  renderFinalResults(html, allReal, [], numCplx);
}

function toIntCoeffs(coeffs) {
  let lcmDen = 1;
  for (const c of coeffs) {
    const str = String(Math.abs(c));
    const dot = str.indexOf('.');
    const decimals = dot >= 0 ? str.length - dot - 1 : 0;
    const den = Math.round(Math.pow(10, decimals));
    lcmDen = lcmVal(lcmDen, den);
  }
  return coeffs.map(c => Math.round(c * lcmDen));
}

function lcmVal(a, b) { return Math.abs(a * b) / gcd(a, b); }

function clearResults() {
  document.getElementById('results-panel').classList.remove('visible');
  document.getElementById('results-content').innerHTML = '';
  document.getElementById('error-msg').classList.remove('visible');
}

function clearAll() {
  document.querySelectorAll('.coeff-input').forEach(i => i.value = '');
  updateEquation();
  clearResults();
}

function showError(msg) {
  const e = document.getElementById('error-msg');
  e.textContent = msg;
  e.classList.add('visible');
}

// INIT
document.addEventListener('DOMContentLoaded', () => {
  buildGrid();
});
</script>
