---
// =====================================================
// KALKULATOR: Równanie wielomianowe (stopień 2-12)
// Pierwszy aktywny kalkulator MATHOUSE.
// =====================================================
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Kalkulator równań wielomianowych — MATHOUSE"
  description="Darmowy kalkulator online do rozwiązywania równań wielomianowych stopnia 2-12. Metoda Hornera, delta, pierwiastki rzeczywiste i zespolone. Sprawdza wszystkie kandydatów ±p/q i pokazuje rozwiązanie krok po kroku."
>
  <!-- Breadcrumb -->
  <div class="kalk-breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> /
      <a href="/kalkulatory">Kalkulatory</a> /
      <span>Równanie wielomianowe</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="kalk-hero">
    <div class="container-content">
      <div class="section-label">⚙️ KALKULATOR · BETA</div>
      <h1 class="kalk-title">Równanie <span class="text-yellow">wielomianowe</span>.</h1>
      <p class="kalk-desc">
        Rozwiąż równanie postaci <strong>ax<sup>n</sup> + bx<sup>n−1</sup> + … + z = 0</strong>
        dla stopni od <strong>2 do 12</strong>. Wprowadź współczynniki — kalkulator pokaże
        pełne rozwiązanie krok po kroku (metoda Hornera lub delty dla równania kwadratowego).
      </p>
    </div>
  </section>

  <!-- WŁAŚCIWY KALKULATOR -->
  <section class="kalk-section">
    <div class="kalk-app-wrap">
      <div id="oblicz-app">
        <div class="container">
          <div class="related">
            Wypróbuj też:
            <a href="/kalkulatory">Wszystkie kalkulatory MATHOUSE</a> ·
            <a href="/kursy/wzory-skroconego-mnozenia">Wzory skróconego mnożenia</a> ·
            <a href="/kursy/wyrazenia-algebraiczne">Wyrażenia algebraiczne</a>
          </div>

          <div class="tabs">
            <button class="tab-btn" onclick="setDegree(2,this)">2. stopień</button>
            <button class="tab-btn" onclick="setDegree(3,this)">3. stopień</button>
            <button class="tab-btn active" onclick="setDegree(4,this)">4. stopień</button>
            <button class="tab-btn" onclick="setDegree(5,this)">5. stopień</button>
            <button class="tab-btn" id="tab-n" onclick="setDegreeN(this)">n. stopień</button>
          </div>

          <div class="panel">
            <div id="n-degree-panel" style="display:none; margin-bottom:20px;">
              <div class="section-title">Wybierz stopień wielomianu:</div>
              <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:4px;">
                <button class="deg-pick" onclick="pickN(6)">6</button>
                <button class="deg-pick" onclick="pickN(7)">7</button>
                <button class="deg-pick" onclick="pickN(8)">8</button>
                <button class="deg-pick" onclick="pickN(9)">9</button>
                <button class="deg-pick" onclick="pickN(10)">10</button>
                <button class="deg-pick" onclick="pickN(11)">11</button>
                <button class="deg-pick" onclick="pickN(12)">12</button>
              </div>
            </div>
            <div class="section-title">Podaj współczynniki równania:</div>
            <div class="coeff-wrap">
              <div class="coeff-horizontal" id="coeff-grid"></div>
            </div>

            <div class="equation-display" id="eq-display">
              <span class="eq-zero">Równanie pojawi się tutaj...</span>
            </div>

            <div class="mode-toggle" id="method-toggle" style="display:none;">
              <label>Metoda rozwiązania:</label>
              <div class="toggle-btns">
                <button class="toggle-btn active" id="btn-delta" onclick="setMethod('delta')">Δ Delta</button>
                <div class="toggle-sep-v"></div>
                <button class="toggle-btn" id="btn-horner" onclick="setMethod('horner')">Horner</button>
              </div>
              <span class="mode-hint" id="method-hint">Wyróżnik (delta) + wzory</span>
            </div>

            <div class="mode-toggle" id="nww-toggle" style="display:none;">
              <label>Przy ułamkowych współczynnikach:</label>
              <div class="toggle-btns">
                <button class="toggle-btn" id="btn-nww-yes" onclick="setNWW(true)">Pomnóż przez NWW</button>
                <div class="toggle-sep-v"></div>
                <button class="toggle-btn active" id="btn-nww-no" onclick="setNWW(false)">Zostaw ułamki</button>
              </div>
              <span class="mode-hint" id="nww-hint">Szukaj pierwiastków bez zamiany na liczby całkowite</span>
            </div>

            <div class="mode-toggle">
              <label>Wyświetl pierwiastki:</label>
              <div class="toggle-btns">
                <button class="toggle-btn active" id="btn-real" onclick="setMode('real')">Rzeczywiste</button>
                <div class="toggle-sep-v"></div>
                <button class="toggle-btn" id="btn-complex" onclick="setMode('complex')">Zespolone</button>
              </div>
              <span class="mode-hint" id="mode-hint">Tylko pierwiastki rzeczywiste</span>
            </div>

            <div class="error-msg" id="error-msg"></div>

            <div class="btn-row">
              <button class="btn-solve" onclick="solve()">
                Rozwiąż
                <span class="spinner" id="spinner"></span>
              </button>
              <button class="btn-clear" onclick="clearAll()">Wyczyść</button>
            </div>
          </div>

          <div class="results-panel" id="results-panel">
            <div class="section-title">Obliczenie</div>
            <div id="results-content"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POWIĄZANE KURSY MATHOUSE -->
  <section class="kalk-related">
    <div class="container-content">
      <div class="section-label">🎓 NAUCZ SIĘ TEMATU</div>
      <h2 class="related-title">Powiązane kursy MATHOUSE</h2>
      <div class="related-cards">
        <a href="/kursy/wielomiany" class="related-card">
          <div class="related-card-num">2.8</div>
          <div class="related-card-name">Wielomiany</div>
          <div class="related-card-desc">Działania na wielomianach, twierdzenie Bézouta, rozkład na czynniki, równania wielomianowe.</div>
        </a>
        <a href="/kursy/wzory-skroconego-mnozenia" class="related-card">
          <div class="related-card-num">1.7</div>
          <div class="related-card-name">Wzory skróconego mnożenia</div>
          <div class="related-card-desc">Kwadrat sumy, różnicy, różnica kwadratów. Niezbędnik do rozkładu wielomianów.</div>
        </a>
        <a href="/kursy/funkcja-kwadratowa" class="related-card">
          <div class="related-card-num">2.3</div>
          <div class="related-card-name">Funkcja kwadratowa</div>
          <div class="related-card-desc">Wyróżnik delta, wzory Viète'a, postać kanoniczna. Wszystko o równaniach 2 stopnia.</div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<!-- =============== STYLE KALKULATORA (1:1 z oryginału) =============== -->
<style is:global>
  #oblicz-app *, #oblicz-app *::before, #oblicz-app *::after {
    box-sizing: border-box;
  }

  #oblicz-app {
    font-family: 'Montserrat', sans-serif;
    background: #f0f2ff;
    color: #050A24;
    border-radius: 16px;
    overflow: hidden;
    padding: 0;
  }

  #oblicz-app .container {
    max-width: 100%;
    margin: 0 auto;
    padding: 24px 16px 40px;
  }

  #oblicz-app .related {
    font-size: .88rem;
    color: #7a8ab0;
    margin-bottom: 20px;
    line-height: 1.9;
  }
  #oblicz-app .related a { color: #3FCECF; text-decoration: none; font-weight: 600; }
  #oblicz-app .related a:hover { color: #050A24; text-decoration: underline; }

  /* TABS */
  #oblicz-app .tabs { display: flex; flex-wrap: wrap; border-bottom: 2px solid #3FCECF; }
  #oblicz-app .tab-btn {
    background: #EBEEFF; border: 1px solid #c8cde8; border-bottom: none;
    padding: 9px 15px; cursor: pointer; font-family: 'Montserrat', sans-serif; font-size: .84rem;
    font-weight: 700; color: #050A24; border-radius: 4px 4px 0 0; margin-right: 3px;
    transition: background .15s, color .15s;
  }
  #oblicz-app .tab-btn.active { background: #050A24; color: #FFDE59; border-color: #050A24; }
  #oblicz-app .tab-btn:hover:not(.active) { background: #3FCECF; color: #fff; }

  /* PANEL */
  #oblicz-app .panel {
    background: #EBEEFF; border: 1px solid #c8cde8; border-top: none;
    border-radius: 0 0 8px 8px; padding: 24px;
    box-shadow: 0 4px 16px rgba(63,206,207,.1); margin-bottom: 22px;
  }
  #oblicz-app .section-title {
    font-size: .78rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif;
    text-transform: uppercase; letter-spacing: .1em;
    color: #050A24; border-left: 4px solid #FFDE59; padding-left: 10px; margin-bottom: 18px;
  }

  #oblicz-app .coeff-wrap { overflow-x: auto; padding-bottom: 6px; }
  #oblicz-app .coeff-horizontal {
    display: flex; gap: 0; align-items: flex-end;
    min-width: min-content; margin-bottom: 20px;
  }
  #oblicz-app .coeff-cell {
    display: flex; flex-direction: column; align-items: center;
    gap: 6px; min-width: 70px; padding: 0 6px;
  }
  #oblicz-app .coeff-letter {
    display: flex; flex-direction: column; align-items: center;
    line-height: 1.15; gap: 1px;
  }
  #oblicz-app .letter-main {
    font-style: normal; font-family: 'Josefin Sans', sans-serif;
    color: #050A24; font-size: 1.1rem; font-weight: 700; letter-spacing: .04em;
  }
  #oblicz-app .letter-power { font-size: .65rem; color: #888; white-space: nowrap; }

  #oblicz-app .coeff-input {
    border: 2px solid #c8cde8; border-radius: 6px;
    padding: 8px 6px; font-size: 1rem;
    font-family: 'Montserrat', sans-serif; width: 100%;
    text-align: center; color: #050A24; font-weight: 600;
    background: #fff; transition: border-color .15s, box-shadow .15s;
    min-width: 58px;
  }
  #oblicz-app .coeff-input:focus {
    outline: none; border-color: #3FCECF; background: #fff;
    box-shadow: 0 0 0 3px rgba(63,206,207,.2);
  }
  #oblicz-app .coeff-sep {
    font-size: 1.4rem; color: #bbb; padding: 0 2px 8px;
    align-self: flex-end; line-height: 1;
    min-width: 18px; text-align: center; flex-shrink: 0;
  }

  #oblicz-app .equation-display {
    background: #050A24; border: 2px solid #FFDE59; border-radius: 8px;
    padding: 14px 20px; font-family: 'Josefin Sans', sans-serif;
    font-size: 1.2rem; color: #FFDE59;
    min-height: 60px; display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap; margin-bottom: 18px;
    box-shadow: 0 0 20px rgba(255,222,89,.12);
  }
  #oblicz-app .eq-zero {
    color: #7a8ab0; font-style: italic; font-size: .9rem;
    font-family: 'Montserrat', sans-serif;
  }

  #oblicz-app .mode-toggle {
    display: flex; align-items: center; gap: 12px; margin-bottom: 18px;
    background: #fff; border: 1px solid #c8cde8;
    border-radius: 8px; padding: 10px 16px; flex-wrap: wrap;
    box-shadow: 0 1px 4px rgba(63,206,207,.08);
  }
  #oblicz-app .mode-toggle label { font-size: .88rem; font-weight: 700; color: #050A24; }
  #oblicz-app .toggle-btns {
    display: flex; border: 2px solid #050A24;
    border-radius: 6px; overflow: hidden;
  }
  #oblicz-app .toggle-btn {
    padding: 7px 20px; font-size: .85rem; font-weight: 600; cursor: pointer;
    border: none; font-family: 'Montserrat', sans-serif;
    background: #fff; color: #050A24; transition: background .15s, color .15s;
  }
  #oblicz-app .toggle-btn.active { background: #050A24; color: #FFDE59; }
  #oblicz-app .toggle-btn:hover:not(.active) { background: #EBEEFF; }
  #oblicz-app .toggle-sep-v { width: 2px; background: #050A24; }
  #oblicz-app .mode-hint { font-size: .8rem; color: #7a8ab0; }

  #oblicz-app .btn-row { display: flex; gap: 10px; flex-wrap: wrap; }
  #oblicz-app .btn-solve {
    background: #FFDE59; color: #050A24; border: none;
    padding: 12px 32px; border-radius: 8px;
    font-family: 'Montserrat', sans-serif; font-size: 1rem;
    font-weight: 800; letter-spacing: .04em; cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: background .15s, transform .08s, box-shadow .15s;
    box-shadow: 0 4px 12px rgba(255,222,89,.35);
  }
  #oblicz-app .btn-solve:hover { background: #f5d040; box-shadow: 0 6px 18px rgba(255,222,89,.5); }
  #oblicz-app .btn-solve:active { transform: scale(.97); }
  #oblicz-app .btn-clear {
    background: #fff; color: #7a8ab0; border: 2px solid #c8cde8;
    padding: 12px 22px; border-radius: 8px;
    font-family: 'Montserrat', sans-serif; font-size: 1rem;
    font-weight: 600; cursor: pointer; transition: border-color .15s;
  }
  #oblicz-app .btn-clear:hover { border-color: #3FCECF; color: #050A24; }

  #oblicz-app .results-panel {
    background: #EBEEFF; border: 1px solid #c8cde8; border-radius: 8px;
    padding: 24px; box-shadow: 0 4px 16px rgba(63,206,207,.08);
    margin-bottom: 22px; display: none;
  }
  #oblicz-app .results-panel.visible { display: block; }
  #oblicz-app .result-header {
    font-family: 'Josefin Sans', sans-serif; font-size: 1.05rem; color: #050A24;
    margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
    font-weight: 700; letter-spacing: .04em;
  }
  #oblicz-app .result-header::before {
    content: ''; display: inline-block; width: 13px; height: 13px;
    background: #2ECC71; border-radius: 50%; flex-shrink: 0;
  }

  #oblicz-app .roots-list { list-style: none; display: flex; flex-direction: column; gap: 7px; margin-bottom: 12px; padding: 0; }
  #oblicz-app .root-item {
    background: #fff; border: 2px solid #2ECC71; border-radius: 8px;
    padding: 10px 16px; font-family: 'Josefin Sans', sans-serif;
    font-size: 1.05rem; color: #050A24;
    display: flex; align-items: center; gap: 10px; font-weight: 600;
  }
  #oblicz-app .root-item .root-idx {
    font-family: 'Montserrat', sans-serif; font-size: .78rem; font-weight: 800;
    color: #fff; background: #2ECC71; border-radius: 4px; padding: 3px 9px;
    min-width: 28px; text-align: center;
  }
  #oblicz-app .root-item.complex { background: #fff; border-color: #3FCECF; }
  #oblicz-app .root-item.complex .root-idx { background: #3FCECF; color: #fff; }

  #oblicz-app .no-real-roots {
    background: #fff0ef; border: 2px solid #E74C3C; border-radius: 8px;
    padding: 12px 16px; color: #E74C3C; font-size: .95rem; font-weight: 700;
  }

  #oblicz-app .steps-box {
    background: #f0f2ff; border: 1px solid #c8cde8; border-radius: 5px;
    padding: 13px 18px; font-size: .87rem; color: #444; line-height: 1.7; margin-top: 14px;
  }

  #oblicz-app .error-msg {
    background: #fff0ef; border: 2px solid #E74C3C; border-radius: 8px;
    padding: 12px 16px; color: #E74C3C; font-size: .92rem;
    margin-top: 10px; display: none; font-weight: 600;
  }
  #oblicz-app .error-msg.visible { display: block; }

  #oblicz-app .deg-pick {
    background: #EBEEFF; border: 2px solid #c8cde8; border-radius: 6px;
    padding: 8px 18px; font-size: 1rem; font-weight: 800; color: #050A24;
    cursor: pointer; font-family: 'Montserrat', sans-serif;
    transition: background .15s, color .15s, border-color .15s;
  }
  #oblicz-app .deg-pick.active { background: #050A24; color: #FFDE59; border-color: #050A24; }
  #oblicz-app .deg-pick:hover:not(.active) { background: #3FCECF; color: #fff; border-color: #3FCECF; }

  #oblicz-app .spinner {
    display: none; width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,.35); border-top-color: #fff;
    border-radius: 50%; animation: oblicz-spin .6s linear infinite;
  }
  @keyframes oblicz-spin { to { transform: rotate(360deg); } }

  /* UŁAMEK */
  #oblicz-app .mfrac { display: inline-flex; align-items: center; gap: 1px; vertical-align: middle; }
  #oblicz-app .mfrac-neg { color: #fff; margin-right: 2px; line-height: 1; align-self: center; }
  #oblicz-app .mfrac-inner { display: inline-flex; flex-direction: column; align-items: center; font-size: .75em; line-height: 1.15; gap: 0; }
  #oblicz-app .mfrac-num { color: #FFDE59; font-weight: 700; line-height: 1.2; }
  #oblicz-app .mfrac-bar { width: 100%; height: 1.5px; background: #FFDE59; display: block; min-width: 12px; margin: 1px 0; }
  #oblicz-app .mfrac-den { color: #FFDE59; font-weight: 700; line-height: 1.2; }

  /* MATH */
  #oblicz-app .math-display {
    display: inline-flex; align-items: center;
    font-family: 'Josefin Sans', sans-serif; letter-spacing: .01em;
    font-size: 1.22rem; color: #FFDE59;
    flex-wrap: wrap; gap: 0; line-height: 1.6;
  }
  #oblicz-app .math-display .mvar { font-style: italic; color: #3FCECF; }
  #oblicz-app .math-display .mnum { font-style: normal; color: #FFDE59; }
  #oblicz-app .math-display .mop { font-style: normal; padding: 0 6px; color: #fff; }
  #oblicz-app .math-display .meq { font-style: normal; padding: 0 8px; color: #FFDE59; font-weight: 700; }
  #oblicz-app .math-display .mterm { display: inline-flex; align-items: center; position: relative; vertical-align: middle; }
  #oblicz-app .math-display .msup {
    font-size: .58em; line-height: 1; vertical-align: super;
    font-style: normal; margin-left: 1px;
    font-family: 'Montserrat', sans-serif; font-weight: 700; color: #3FCECF;
    position: relative; top: -.3em;
  }

  /* HORNER / SOLVE */
  #oblicz-app .solve-intro { font-size: .9rem; color: #050A24; margin-bottom: 16px; font-weight: 500; }
  #oblicz-app .step-block {
    background: #fff; border: 1px solid #c8cde8; border-radius: 8px;
    padding: 16px 18px; margin-bottom: 14px; border-left: 4px solid #3FCECF;
  }
  #oblicz-app .step-block.results-final { background: #0d3b1e; border-color: #2ECC71; border-left-color: #2ECC71; }
  #oblicz-app .step-block.results-final .step-title { color: #2ECC71; }
  #oblicz-app .step-title {
    font-size: .78rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif;
    text-transform: uppercase; letter-spacing: .12em; color: #050A24; margin-bottom: 10px;
  }
  #oblicz-app .step-text { font-size: .88rem; color: #050A24; margin-bottom: 6px; line-height: 1.6; }
  #oblicz-app .step-text em { color: #3FCECF; font-weight: 700; }

  #oblicz-app .cand {
    display: inline-flex; align-items: center; justify-content: center;
    background: #FFDE59; color: #050A24; font-weight: 800;
    border-radius: 4px; padding: 3px 10px; margin: 2px;
    font-size: .88rem; min-height: 28px; vertical-align: middle;
  }
  #oblicz-app .cand-frac { padding: 3px 8px; }
  #oblicz-app .cf-neg { margin-right: 2px; font-weight: 900; }
  #oblicz-app .cf-inner { display: inline-flex; flex-direction: column; align-items: center; line-height: 1.1; gap: 1px; }
  #oblicz-app .cf-num { font-size: .8em; font-weight: 900; }
  #oblicz-app .cf-bar { width: 100%; min-width: 12px; height: 1.5px; background: #050A24; display: block; }
  #oblicz-app .cf-den { font-size: .8em; font-weight: 900; }

  #oblicz-app .check-table { width: 100%; border-collapse: collapse; font-size: .86rem; margin-top: 6px; border-radius: 6px; overflow: hidden; }
  #oblicz-app .check-table td { padding: 7px 12px; border-bottom: 1px solid #c8cde8; }
  #oblicz-app .check-table tr:last-child td { border-bottom: none; }
  #oblicz-app .check-yes td { background: rgba(46,204,113,.12); color: #2ECC71; font-weight: 700; }
  #oblicz-app .check-no td { color: #050A24; opacity: .5; }
  #oblicz-app .check-table td:first-child { font-family: 'Josefin Sans', sans-serif; font-style: italic; min-width: 90px; }
  #oblicz-app .check-table td:last-child { text-align: center; min-width: 60px; }

  #oblicz-app .horner-label { font-size: .86rem; color: #050A24; margin-bottom: 8px; font-weight: 600; }
  #oblicz-app .horner-wrap { overflow-x: auto; margin-bottom: 8px; }
  #oblicz-app .horner-table {
    border-collapse: collapse; font-size: .9rem;
    font-family: 'Josefin Sans', sans-serif;
    border-radius: 8px; overflow: hidden;
  }
  #oblicz-app .horner-table td {
    border: 1px solid #c8cde8; padding: 8px 16px; text-align: center; min-width: 50px;
  }
  #oblicz-app .hn-coeff td { background: #050A24; font-weight: 700; color: #FFDE59; font-size: 1rem; }
  #oblicz-app .hn-mul td { background: #f5f6ff; color: #3FCECF; font-style: italic; font-weight: 600; }
  #oblicz-app .hn-result td { background: #EBEEFF; font-weight: 700; color: #050A24; }
  #oblicz-app .hn-rem { background: #2ECC71 !important; color: #fff !important; font-weight: 800 !important; }
  #oblicz-app .hn-r { background: #FFDE59 !important; color: #050A24 !important; font-weight: 800; }
  #oblicz-app .hn-r-empty { background: transparent !important; border: none !important; }

  #oblicz-app .horner-note { font-size: .84rem; color: #050A24; margin-top: 4px; font-weight: 500; }
