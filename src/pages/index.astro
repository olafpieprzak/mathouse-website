<script>
  // === Aktualizacja licznika "X wolnych miejsc" w hero ===
  import { fetchAvailability } from '../config/tidycal.js';

  async function updateHeroAvailability() {
    try {
      const data = await fetchAvailability();
      const freeEl = document.querySelector('[data-hero-free]');
      const labelEl = document.querySelector('[data-hero-label]');
      if (freeEl && data.free_slots_this_week !== undefined) {
        freeEl.textContent = String(data.free_slots_this_week);
      }
      if (labelEl && data.free_slots_this_week !== undefined) {
        const n = data.free_slots_this_week;
        labelEl.textContent = n === 1
          ? 'wolne miejsce'
          : (n >= 2 && n <= 4)
            ? 'wolne miejsca'
            : 'wolnych miejsc';
      }
    } catch (err) {
      console.warn('[Hero] błąd:', err);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateHeroAvailability);
  } else {
    updateHeroAvailability();
  }
</script>
