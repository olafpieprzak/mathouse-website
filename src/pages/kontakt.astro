---
// =====================================================
// STRONA KONTAKT
// =====================================================
import Layout from '../layouts/Layout.astro';

const socialMedia = [
  { url: 'https://www.tiktok.com/@mathouse_pl', icon: 'brand-tiktok', bg: '#000', iconColor: '#FFDE59' },
  { url: 'https://www.instagram.com/mathouse_pl/', icon: 'brand-instagram', bg: 'linear-gradient(135deg,#833AB4,#FD1D1D,#FCB045)', iconColor: '#fff' },
  { url: 'https://www.youtube.com/@olafpieprzak9987', icon: 'brand-youtube', bg: '#FF0000', iconColor: '#fff' },
  { url: 'https://www.facebook.com/profile.php?id=100072045862164', icon: 'brand-facebook', bg: '#1877F2', iconColor: '#fff' },
];
---

<Layout
  title="Kontakt"
  description="Masz pytanie o korepetycje, kursy lub kompendia? Napisz do mnie. Odpowiadam w ciągu 24h. Email: olaf.pieprzak@gmail.com. Tel: 570 840 416. Pracownia: Ropczyce."
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Kontakt</span>
    </div>
  </div>

  <!-- ===================================================== -->
  <!-- HERO + FORMULARZ                                       -->
  <!-- ===================================================== -->
  <section class="kontakt-hero">
    <div class="container-content kontakt-grid">
      <!-- LEWA: dane kontaktowe -->
      <div>
        <span class="tag-teal">💬 odpowiadam w ciągu 24 godzin</span>
        <h1 class="kontakt-title">
          Masz pytanie?<br />
          <span class="text-yellow">Napisz.</span>
        </h1>
        <p class="kontakt-desc">
          Korepetycje, kursy, książki, współpraca, podcasty — odpiszę osobiście.
        </p>

        <div class="kontakt-rows">
          <a href="mailto:olaf.pieprzak@gmail.com" class="kontakt-row">
            <div class="kontakt-icon yellow"><i class="ti ti-mail"></i></div>
            <div class="kontakt-info">
              <div class="kontakt-label">EMAIL</div>
              <div class="kontakt-value">olaf.pieprzak@gmail.com</div>
            </div>
          </a>
          <a href="tel:+48570840416" class="kontakt-row">
            <div class="kontakt-icon teal"><i class="ti ti-phone"></i></div>
            <div class="kontakt-info">
              <div class="kontakt-label">TELEFON</div>
              <div class="kontakt-value">570 840 416</div>
            </div>
          </a>
          <div class="kontakt-row">
            <div class="kontakt-icon yellow"><i class="ti ti-map-pin"></i></div>
            <div class="kontakt-info">
              <div class="kontakt-label">PRACOWNIA</div>
              <div class="kontakt-value">ul. Piłsudskiego 26A/16</div>
              <div class="kontakt-sub">39-100 Ropczyce · stacjonarne lekcje</div>
            </div>
          </div>
        </div>

        <div class="social-section">
          <div class="social-label">ALBO ZNAJDŹ MNIE NA</div>
          <div class="social-buttons">
            {socialMedia.map((m) => (
              <a href={m.url} target="_blank" rel="noopener noreferrer" class="social-btn" style={`background:${m.bg}`}>
                <i class={`ti ti-${m.icon}`} style={`color:${m.iconColor}`}></i>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- PRAWA: formularz -->
      <div class="form-card">
        <div class="form-title">Formularz kontaktowy</div>

        <form class="kontakt-form" action="https://formspree.io/f/PLACEHOLDER" method="POST">
          <div class="form-group">
            <label for="imie" class="form-label">IMIĘ</label>
            <input type="text" id="imie" name="imie" placeholder="np. Karolina" class="form-input" required />
          </div>
          <div class="form-group">
            <label for="email" class="form-label">EMAIL</label>
            <input type="email" id="email" name="email" placeholder="np. karolina@gmail.com" class="form-input" required />
          </div>
          <div class="form-group">
            <label for="temat" class="form-label">TEMAT</label>
            <select id="temat" name="temat" class="form-input" required>
              <option value="korepetycje">Korepetycje</option>
              <option value="kursy">Kursy</option>
              <option value="sklep">Sklep</option>
              <option value="wspolpraca">Współpraca</option>
              <option value="inne">Inne</option>
            </select>
          </div>
          <div class="form-group">
            <label for="wiadomosc" class="form-label">WIADOMOŚĆ</label>
            <textarea id="wiadomosc" name="wiadomosc" placeholder="Napisz, w czym mogę pomóc..." rows="5" class="form-input" required></textarea>
          </div>

          <label class="form-rodo">
            <input type="checkbox" required />
            <span>Zgadzam się na przetwarzanie danych zgodnie z <a href="/polityka-prywatnosci">Polityką prywatności</a>.</span>
          </label>

          <button type="submit" class="form-submit">Wyślij wiadomość →</button>
          <p class="form-note">Odpiszę osobiście w ciągu 24h</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- 2 KOLUMNY: stacjonarne + online                        -->
  <!-- ===================================================== -->
  <section class="section-sposoby">
    <div class="container-content">
      <div class="section-label">INNE SPOSOBY KONTAKTU</div>
      <div class="sposoby-grid">

        <div class="sposob-card sposob-stacjonarne">
          <div class="sposob-map">
            <svg class="sposob-map-lines" viewBox="0 0 400 200">
              <line x1="0" y1="80" x2="400" y2="80" stroke="#EBEEFF" stroke-width="1" />
              <line x1="0" y1="130" x2="400" y2="130" stroke="#EBEEFF" stroke-width="1" />
              <line x1="150" y1="0" x2="150" y2="200" stroke="#EBEEFF" stroke-width="1" />
              <line x1="280" y1="0" x2="280" y2="200" stroke="#EBEEFF" stroke-width="1" />
            </svg>
            <div class="sposob-pin"><span>📍</span></div>
            <div class="sposob-pin-label">ul. Piłsudskiego 26A/16, Ropczyce</div>
          </div>
          <div class="sposob-body">
            <div class="sposob-head">
              <div class="sposob-icon yellow"><i class="ti ti-building"></i></div>
              <div class="sposob-title">Lekcje stacjonarne</div>
            </div>
            <p class="sposob-desc">
              Pracownia w Ropczycach (ul. Piłsudskiego 26A/16) — wygodne miejsce z tablicą i materiałami pod ręką.
            </p>
            <a href="https://www.google.com/maps/search/?api=1&query=ul.+Piłsudskiego+26A,+39-100+Ropczyce" target="_blank" rel="noopener noreferrer" class="btn-secondary sposob-btn">Otwórz w Google Maps</a>
          </div>
        </div>

        <div class="sposob-card sposob-online">
          <div class="sposob-online-bg">
            <div class="online-logo meet">GOOGLE MEET</div>
          </div>
          <div class="sposob-body">
            <div class="sposob-head">
              <div class="sposob-icon teal"><i class="ti ti-device-laptop"></i></div>
              <div class="sposob-title">Lekcje online</div>
            </div>
            <p class="sposob-desc">
              Google Meet — z każdego miejsca w Polsce. Tablica interaktywna, identyczna jakość jak stacjonarnie.
            </p>
            <a href="/korepetycje" class="btn-primary sposob-btn">Rezerwuj termin →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- WSPÓŁPRACA                                             -->
  <!-- ===================================================== -->
  <section class="section-wspolpraca">
    <div class="container-content wspolpraca-inner">
      <div class="wspolpraca-text">
        <div class="section-label yellow">WSPÓŁPRACA · MEDIA · PARTNERSTWO</div>
        <h3 class="wspolpraca-title">Jesteś korepetytorem, blogerem, podcasterem albo szkołą?</h3>
        <p class="wspolpraca-desc">Otwarty jestem na współpracę, podcasty, wywiady i partnerstwa edukacyjne.</p>
      </div>
      <a href="mailto:olaf.pieprzak@gmail.com" class="btn-primary wspolpraca-cta">
        Napisz: <strong>olaf.pieprzak@gmail.com</strong>
      </a>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb span { color: #FFDE59; }

  .text-yellow { color: #FFDE59; }

  /* ===================================================== */
  /* HERO + FORMULARZ                                       */
  /* ===================================================== */
  .kontakt-hero {
    padding: 48px 0;
  }
  .kontakt-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 42px;
    align-items: start;
  }
  .kontakt-title {
    font-size: 46px;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -1.2px;
    margin: 18px 0 14px;
  }
  .kontakt-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.65;
    margin-bottom: 26px;
    max-width: 380px;
  }

  .kontakt-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .kontakt-row {
    display: flex;
    gap: 14px;
    align-items: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 11px;
    padding: 13px 16px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .kontakt-row:hover {
    border-color: rgba(255, 222, 89, 0.3);
  }
  .kontakt-icon {
    width: 40px;
    height: 40px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .kontakt-icon.yellow {
    background: rgba(255, 222, 89, 0.15);
    color: #FFDE59;
  }
  .kontakt-icon.teal {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
  }
  .kontakt-icon i {
    font-size: 20px;
  }
  .kontakt-label {
    font-size: 10px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1px;
  }
  .kontakt-value {
    font-size: 14px;
    font-weight: 600;
  }
  .kontakt-sub {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.6);
    margin-top: 2px;
  }

  /* === Social === */
  .social-section {
    margin-top: 22px;
  }
  .social-label {
    font-size: 10px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1.5px;
    margin-bottom: 12px;
  }
  .social-buttons {
    display: flex;
    gap: 8px;
  }
  .social-btn {
    width: 40px;
    height: 40px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .social-btn:hover {
    transform: translateY(-2px);
  }
  .social-btn i {
    font-size: 18px;
  }

  /* === FORMULARZ === */
  .form-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 16px;
    padding: 26px;
  }
  .form-title {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
  }
  .form-label {
    font-size: 10px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1px;
    margin-bottom: 5px;
  }
  .form-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(235, 238, 255, 0.15);
    padding: 12px 15px;
    border-radius: 8px;
    font-size: 13px;
    color: #EBEEFF;
    font-family: 'Montserrat', sans-serif;
    box-sizing: border-box;
    transition: border-color 0.15s ease;
  }
  .form-input:focus {
    outline: none;
    border-color: rgba(255, 222, 89, 0.4);
  }
  select.form-input {
    cursor: pointer;
  }
  textarea.form-input {
    resize: vertical;
    min-height: 100px;
  }
  .form-rodo {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 4px;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.5;
    cursor: pointer;
  }
  .form-rodo input {
    width: 16px;
    height: 16px;
    accent-color: #FFDE59;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .form-rodo a {
    color: #3FCECF;
    text-decoration: underline;
  }
  .form-submit {
    background: #FFDE59;
    color: #050A24;
    padding: 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    border: none;
    cursor: pointer;
    margin-top: 6px;
    font-family: 'Montserrat', sans-serif;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .form-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 16px rgba(255, 222, 89, 0.25);
  }
  .form-note {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    text-align: center;
  }

  /* ===================================================== */
  /* INNE SPOSOBY                                           */
  /* ===================================================== */
  .section-sposoby {
    padding: 32px 0;
  }
  .sposoby-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 14px;
  }
  .sposob-card {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    overflow: hidden;
  }
  .sposob-stacjonarne {
    border: 1px solid rgba(255, 222, 89, 0.25);
  }
  .sposob-online {
    border: 1px solid rgba(63, 206, 207, 0.25);
  }
  .sposob-map {
    background: linear-gradient(135deg, #1a2347, #050A24);
    aspect-ratio: 16/8;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sposob-map-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.18;
  }
  .sposob-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-45deg);
    background: #FFDE59;
    color: #050A24;
    width: 40px;
    height: 40px;
    border-radius: 50% 50% 50% 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sposob-pin span {
    transform: rotate(45deg);
    font-size: 16px;
  }
  .sposob-pin-label {
    position: absolute;
    bottom: 10px;
    left: 12px;
    background: rgba(5, 10, 36, 0.85);
    padding: 5px 10px;
    border-radius: 5px;
    font-size: 10px;
    letter-spacing: 0.5px;
  }
  .sposob-online-bg {
    background: linear-gradient(135deg, #0a3a52, #050A24);
    aspect-ratio: 16/8;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
  .online-logo {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.5px;
  }
  .online-logo.zoom {
    background: #2D8CFF;
    color: #fff;
  }
  .online-logo.meet {
    background: #fff;
    color: #1f6bbb;
    font-size: 11px;
  }
  .online-plus {
    font-size: 24px;
    color: rgba(235, 238, 255, 0.5);
  }
  .sposob-body {
    padding: 18px;
  }
  .sposob-head {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 8px;
  }
  .sposob-icon {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sposob-icon.yellow {
    background: rgba(255, 222, 89, 0.15);
    color: #FFDE59;
  }
  .sposob-icon.teal {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
  }
  .sposob-icon i {
    font-size: 18px;
  }
  .sposob-title {
    font-size: 15px;
    font-weight: 600;
  }
  .sposob-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
    margin-bottom: 12px;
  }
  .sposob-btn {
    display: inline-block;
    font-size: 12px;
    padding: 9px 16px;
  }

  /* ===================================================== */
  /* WSPÓŁPRACA                                             */
  /* ===================================================== */
  .section-wspolpraca {
    padding: 28px 0;
    background: linear-gradient(90deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.08));
    border-top: 1px solid rgba(235, 238, 255, 0.1);
  }
  .wspolpraca-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .wspolpraca-text {
    flex: 1;
    min-width: 280px;
  }
  .wspolpraca-title {
    font-size: 20px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.3px;
    margin-top: 6px;
  }
  .wspolpraca-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    margin-top: 4px;
    line-height: 1.5;
  }
  .wspolpraca-cta {
    white-space: nowrap;
  }

  /* ===================================================== */
  /* RESPONSIVE                                             */
  /* ===================================================== */
  @media (max-width: 1024px) {
    .kontakt-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .kontakt-hero {
      padding: 32px 0;
    }
    .kontakt-title {
      font-size: 32px;
    }
    .sposoby-grid {
      grid-template-columns: 1fr;
    }
    .wspolpraca-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .wspolpraca-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
