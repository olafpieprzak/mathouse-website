---
// =====================================================
// MAPY MYŚLI — landing
// URL: /mapa-mysli
// =====================================================
import Layout from '../layouts/Layout.astro';
import { produkty } from '../data/produkty.js';

const p = produkty.mapaMysli;
const PRICE = p.price;
const EMBED_ID = p.sklepEmbedId;
const SHOP_URL = p.sklepUrl;
const FORMSPREE = p.formspreeId;
const IS_PAID = !!(EMBED_ID || SHOP_URL);
const IS_FREE_GATE = !IS_PAID && !!FORMSPREE;
---

<Layout
  title="Mapy myśli MATHOUSE — działy matury na jednej kartce"
  description="Każdy dział matury jako wizualna mapa myśli — wszystkie wzory, definicje i powiązania na jednej kartce. Idealne dla wzrokowców."
>
  <div class="kurs-breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Mapy myśli</span>
    </div>
  </div>

  <section class="lp-hero">
    <div class="container-content lp-hero-grid">
      <div class="lp-hero-left">
        <div class="section-label">🧠 WIZUALNA NAUKA</div>
        <h1 class="lp-title">
          Mapy <span class="text-teal">myśli</span>.<br />Cały dział na jednej kartce.
        </h1>
        <p class="lp-desc">
          Każdy dział matury jako jedna <strong>wizualna mapa myśli</strong> — wzory, definicje
          i powiązania połączone strzałkami tak, żeby mózg zapamiętał strukturę, nie suchy tekst.
          Stworzone z myślą o wzrokowcach i o szybkich powtórkach.
        </p>
        {IS_PAID && PRICE && (
          <div class="lp-price-row">
            <span class="lp-price">{PRICE} zł</span>
            {p.priceOld && <span class="lp-price-old">{p.priceOld} zł</span>}
          </div>
        )}
        <div class="lp-cta">
          {IS_PAID ? (
            <a href="#kup-teraz" class="btn-primary">🛒 Pobierz mapy myśli</a>
          ) : IS_FREE_GATE ? (
            <a href="#pobierz" class="btn-primary">🎁 Pobierz za darmo</a>
          ) : (
            <a href="/kontakt" class="btn-primary">📩 Powiadom mnie</a>
          )}
          <a href="/" class="btn-teal">← Wróć</a>
        </div>
      </div>
      <div class="lp-hero-right">
        <div class="lp-doc-mockup">
          <div class="lp-doc-icon">🗺️</div>
          <div class="lp-doc-pages">1 kartka</div>
          <div class="lp-doc-label">= cały dział</div>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-why">
    <div class="container-content">
      <div class="section-label">💡 DLACZEGO MAPY MYŚLI</div>
      <h2 class="section-title">Dlaczego mapy myśli działają?</h2>
      <div class="lp-why-grid">
        <div class="lp-why-card">
          <div class="lp-why-ico">👁️</div>
          <strong>Dla wzrokowców</strong>
          <span>Widzisz całą strukturę naraz — powiązania między wzorami zamiast listy do wykucia.</span>
        </div>
        <div class="lp-why-card">
          <div class="lp-why-ico">🔗</div>
          <strong>Powiązania</strong>
          <span>Strzałki pokazują jak jeden wzór wynika z drugiego — rozumiesz, nie tylko pamiętasz.</span>
        </div>
        <div class="lp-why-card">
          <div class="lp-why-ico">⚡</div>
          <strong>Błyskawiczne powtórki</strong>
          <span>Rzut oka na mapę przed klasówką przypomina Ci cały dział w 2 minuty.</span>
        </div>
      </div>
    </div>
  </section>

  <section id="kup-teraz" class="lp-cta-section">
    <div class="container-content">
      {IS_PAID && EMBED_ID ? (
        <div class="lp-embed-wrap">
          <h2 class="lp-cta-title">Pobierz mapy myśli</h2>
          <div class="lp-embed-frame">
            <style is:inline>.wtl-responsive-iframe { width: 1px; min-width: 100%; }</style>
            <iframe
              class="wtl-responsive-iframe"
              src={`https://kurs.mathouse.pl/assets/js/s.php?id=${EMBED_ID}`}
              frameborder="0" allowfullscreen loading="lazy" title="Zakup: Mapy myśli"
            ></iframe>
          </div>
        </div>
      ) : IS_PAID && SHOP_URL ? (
        <div class="lp-cta-center">
          <h2 class="lp-cta-title">Gotowy na pobranie?</h2>
          <a href={SHOP_URL} target="_blank" rel="noopener" class="btn-primary lp-cta-btn">🛒 Przejdź do sklepu →</a>
        </div>
      ) : IS_FREE_GATE ? (
        <div class="lp-cta-center" id="pobierz">
          <h2 class="lp-cta-title">Pobierz za darmo</h2>
          <p class="lp-cta-sub">Zostaw email — wyślę Ci mapy myśli prosto na skrzynkę.</p>
          <form class="lp-form" action={`https://formspree.io/f/${FORMSPREE}`} method="POST">
            <input type="hidden" name="_subject" value="MATHOUSE: pobranie map myśli" />
            <input type="hidden" name="produkt" value="Mapy myśli" />
            <input type="email" name="email" placeholder="twoj@email.pl" required class="lp-input" />
            <button type="submit" class="lp-form-btn">🎁 Wyślij mi mapy myśli →</button>
          </form>
        </div>
      ) : (
        <div class="lp-cta-center">
          <h2 class="lp-cta-title">Mapy myśli — wkrótce dostępne</h2>
          <p class="lp-cta-sub">Pracuję nad finalną wersją. Zostaw email — dam znać gdy będą gotowe.</p>
          <a href="/kontakt" class="btn-primary lp-cta-btn">📩 Powiadom mnie →</a>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .kurs-breadcrumb { padding: 14px 0; font-size: 11px; color: rgba(235, 238, 255, 0.5); border-bottom: 1px solid rgba(235, 238, 255, 0.06); }
  .kurs-breadcrumb a { color: inherit; text-decoration: none; }
  .kurs-breadcrumb a:hover { color: #3FCECF; }
  .kurs-breadcrumb span { color: #3FCECF; }
  .text-teal { color: #3FCECF; }

  .lp-hero { padding: 40px 0 30px; }
  .lp-hero-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 30px; align-items: center; }
  .section-label { font-size: 11px; color: #3FCECF; letter-spacing: 1px; font-weight: 700; margin-bottom: 8px; }
  .lp-title { font-size: 40px; font-weight: 600; line-height: 1.1; letter-spacing: -1.1px; margin: 10px 0 16px; }
  .lp-desc { font-size: 15px; color: rgba(235, 238, 255, 0.75); line-height: 1.65; margin-bottom: 22px; }
  .lp-desc strong { color: #EBEEFF; }
  .lp-price-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
  .lp-price { font-size: 32px; font-weight: 800; color: #3FCECF; }
  .lp-price-old { font-size: 18px; color: rgba(235, 238, 255, 0.45); text-decoration: line-through; }
  .lp-cta { display: flex; gap: 10px; flex-wrap: wrap; }

  .lp-hero-right { display: flex; justify-content: center; }
  .lp-doc-mockup {
    background: linear-gradient(135deg, rgba(63, 206, 207, 0.12), rgba(255, 222, 89, 0.06));
    border: 1px solid rgba(63, 206, 207, 0.3);
    border-radius: 18px;
    padding: 40px 50px;
    text-align: center;
  }
  .lp-doc-icon { font-size: 64px; }
  .lp-doc-pages { font-size: 28px; font-weight: 800; color: #3FCECF; margin-top: 10px; }
  .lp-doc-label { font-size: 12px; color: rgba(235, 238, 255, 0.6); text-transform: uppercase; letter-spacing: 0.5px; }

  .lp-why { padding: 44px 0; }
  .section-title { font-size: 28px; font-weight: 600; line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 22px; }
  .lp-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .lp-why-card {
    padding: 22px 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 12px;
  }
  .lp-why-ico { font-size: 34px; margin-bottom: 10px; }
  .lp-why-card strong { font-size: 15px; color: #EBEEFF; display: block; margin-bottom: 6px; }
  .lp-why-card span { font-size: 12.5px; color: rgba(235, 238, 255, 0.65); line-height: 1.55; }

  .lp-cta-section { padding: 50px 0; background: rgba(63, 206, 207, 0.05); border-top: 1px solid rgba(63, 206, 207, 0.2); }
  .lp-cta-center { text-align: center; max-width: 480px; margin: 0 auto; }
  .lp-cta-title { font-size: 26px; font-weight: 700; margin-bottom: 10px; }
  .lp-cta-sub { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; }
  .lp-cta-btn { display: inline-block; }
  .lp-form { display: flex; flex-direction: column; gap: 10px; }
  .lp-input {
    padding: 13px 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(235, 238, 255, 0.2);
    border-radius: 10px;
    color: #EBEEFF; font-size: 14px; font-family: inherit; text-align: center;
  }
  .lp-input:focus { outline: none; border-color: #3FCECF; }
  .lp-form-btn {
    padding: 14px; background: #3FCECF; color: #050A24; border: none;
    border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
  }
  .lp-form-btn:hover { background: #5CDADB; }
  .lp-embed-wrap { max-width: 560px; margin: 0 auto; }
  .lp-embed-frame { background: #fff; border-radius: 14px; overflow: hidden; min-height: 480px; margin-top: 16px; }
  .lp-embed-frame iframe { width: 100%; border: none; display: block; }

  @media (max-width: 900px) {
    .lp-hero-grid { grid-template-columns: 1fr; }
    .lp-title { font-size: 30px; }
    .lp-why-grid { grid-template-columns: 1fr; }
  }
</style>
