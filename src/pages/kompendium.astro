---
// =====================================================
// KOMPENDIUM MATURALNE — landing
// URL: /kompendium
// =====================================================
import Layout from '../layouts/Layout.astro';
import { produkty } from '../data/produkty.js';

const p = produkty.kompendium;
const PRICE = p.price;
const EMBED_ID = p.sklepEmbedId;
const SHOP_URL = p.sklepUrl;
const FORMSPREE = p.formspreeId;
const IS_PAID = !!(EMBED_ID || SHOP_URL);
const IS_FREE_GATE = !IS_PAID && !!FORMSPREE;

const tematy = [
  'Liczby rzeczywiste', 'Wyrażenia algebraiczne', 'Równania i nierówności',
  'Funkcje', 'Funkcja liniowa', 'Funkcja kwadratowa', 'Wielomiany',
  'Funkcje wymierne', 'Funkcja wykładnicza', 'Logarytmy', 'Ciągi',
  'Trygonometria', 'Planimetria', 'Geometria analityczna', 'Stereometria',
  'Kombinatoryka', 'Rachunek prawdopodobieństwa', 'Statystyka',
];
---

<Layout
  title="Kompendium maturalne MATHOUSE — cała teoria w pigułce"
  description="Cała teoria do matury z matematyki w jednym dokumencie — 26 tematów, definicje, wzory, twierdzenia. Do druku i na telefon."
>
  <div class="kurs-breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Kompendium</span>
    </div>
  </div>

  <section class="lp-hero">
    <div class="container-content lp-hero-grid">
      <div class="lp-hero-left">
        <div class="section-label">📘 TEORIA W PIGUŁCE</div>
        <h1 class="lp-title">
          Kompendium <span class="text-yellow">maturalne</span>.<br />Cała teoria w jednym miejscu.
        </h1>
        <p class="lp-desc">
          Wszystkie definicje, wzory i twierdzenia z matury podstawowej — <strong>26 tematów</strong>
          uporządkowanych tak, żebyś nie musiał wertować podręczników. Do wydruku i na telefon.
          Idealne na ostatnie powtórki przed egzaminem.
        </p>
        {IS_PAID && PRICE && (
          <div class="lp-price-row">
            <span class="lp-price">{PRICE} zł</span>
            {p.priceOld && <span class="lp-price-old">{p.priceOld} zł</span>}
          </div>
        )}
        <div class="lp-cta">
          {IS_PAID ? (
            <a href="#kup-teraz" class="btn-primary">🛒 Pobierz kompendium</a>
          ) : IS_FREE_GATE ? (
            <a href="#pobierz" class="btn-primary">🎁 Pobierz za darmo</a>
          ) : (
            <a href="/kontakt" class="btn-primary">📩 Powiadom mnie</a>
          )}
          <a href="/" class="btn-teal">← Wróć</a>
        </div>
      </div>
      <div class="lp-hero-right">
        <div class="lp-doc-mockup">
          <div class="lp-doc-icon">📄</div>
          <div class="lp-doc-pages">77 stron</div>
          <div class="lp-doc-label">teorii maturalnej</div>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-content">
    <div class="container-content">
      <div class="section-label">📋 CO W ŚRODKU</div>
      <h2 class="section-title">26 tematów maturalnych — wszystko czego potrzebujesz.</h2>
      <div class="lp-tematy-grid">
        {tematy.map((t, i) => (
          <div class="lp-temat">
            <span class="lp-temat-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="lp-temat-name">{t}</span>
          </div>
        ))}
        <div class="lp-temat lp-temat-more">
          <span class="lp-temat-name">+ pozostałe tematy</span>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-why">
    <div class="container-content">
      <div class="section-label">💡 DLACZEGO WARTO</div>
      <h2 class="section-title">Po co Ci kompendium?</h2>
      <div class="lp-why-grid">
        <div class="lp-why-card">
          <div class="lp-why-ico">⚡</div>
          <strong>Szybkie powtórki</strong>
          <span>Cała teoria w jednym pliku — nie szukasz po notatkach i podręcznikach.</span>
        </div>
        <div class="lp-why-card">
          <div class="lp-why-ico">🖨️</div>
          <strong>Do wydruku</strong>
          <span>Wydrukuj, podkreślaj, rób notatki na marginesie. Albo trzymaj na telefonie.</span>
        </div>
        <div class="lp-why-card">
          <div class="lp-why-ico">🎯</div>
          <strong>Pod maturę</strong>
          <span>Ułożone pod wymagania CKE — dokładnie to, co może być na egzaminie.</span>
        </div>
      </div>
    </div>
  </section>

  <section id="kup-teraz" class="lp-cta-section">
    <div class="container-content">
      {IS_PAID && EMBED_ID ? (
        <div class="lp-embed-wrap">
          <h2 class="lp-cta-title">Pobierz kompendium</h2>
          <div class="lp-embed-frame">
            <style is:inline>.wtl-responsive-iframe { width: 1px; min-width: 100%; }</style>
            <iframe
              class="wtl-responsive-iframe"
              src={`https://kurs.mathouse.pl/assets/js/s.php?id=${EMBED_ID}`}
              frameborder="0" allowfullscreen loading="lazy" title="Zakup: Kompendium"
            ></iframe>
          </div>
        </div>
      ) : IS_PAID && SHOP_URL ? (
        <div class="lp-cta-center">
          <h2 class="lp-cta-title">Gotowy na pobranie?</h2>
          <a href={SHOP_URL} target="_blank" rel="noopener" class="btn-primary lp-cta-btn">🛒 Przejdź do sklepu →</a>
        </div>
      ) : IS_FREE_GATE ? (
        <div class="lp-cta-center" id="pobierz">
          <h2 class="lp-cta-title">Pobierz za darmo</h2>
          <p class="lp-cta-sub">Zostaw email — wyślę Ci kompendium prosto na skrzynkę.</p>
          <form class="lp-form" action={`https://formspree.io/f/${FORMSPREE}`} method="POST">
            <input type="hidden" name="_subject" value="MATHOUSE: pobranie kompendium" />
            <input type="hidden" name="produkt" value="Kompendium maturalne" />
            <input type="email" name="email" placeholder="twoj@email.pl" required class="lp-input" />
            <button type="submit" class="lp-form-btn">🎁 Wyślij mi kompendium →</button>
          </form>
        </div>
      ) : (
        <div class="lp-cta-center">
          <h2 class="lp-cta-title">Kompendium — wkrótce dostępne</h2>
          <p class="lp-cta-sub">Pracuję nad finalną wersją. Zostaw email — dam znać gdy będzie gotowe.</p>
          <a href="/kontakt" class="btn-primary lp-cta-btn">📩 Powiadom mnie →</a>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .kurs-breadcrumb { padding: 14px 0; font-size: 11px; color: rgba(235, 238, 255, 0.5); border-bottom: 1px solid rgba(235, 238, 255, 0.06); }
  .kurs-breadcrumb a { color: inherit; text-decoration: none; }
  .kurs-breadcrumb a:hover { color: #FFDE59; }
  .kurs-breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }

  .lp-hero { padding: 40px 0 30px; }
  .lp-hero-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 30px; align-items: center; }
  .section-label { font-size: 11px; color: #3FCECF; letter-spacing: 1px; font-weight: 700; margin-bottom: 8px; }
  .lp-title { font-size: 40px; font-weight: 600; line-height: 1.1; letter-spacing: -1.1px; margin: 10px 0 16px; }
  .lp-desc { font-size: 15px; color: rgba(235, 238, 255, 0.75); line-height: 1.65; margin-bottom: 22px; }
  .lp-desc strong { color: #EBEEFF; }
  .lp-price-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
  .lp-price { font-size: 32px; font-weight: 800; color: #FFDE59; }
  .lp-price-old { font-size: 18px; color: rgba(235, 238, 255, 0.45); text-decoration: line-through; }
  .lp-cta { display: flex; gap: 10px; flex-wrap: wrap; }

  .lp-hero-right { display: flex; justify-content: center; }
  .lp-doc-mockup {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.12), rgba(63, 206, 207, 0.06));
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 18px;
    padding: 40px 50px;
    text-align: center;
  }
  .lp-doc-icon { font-size: 64px; }
  .lp-doc-pages { font-size: 28px; font-weight: 800; color: #FFDE59; margin-top: 10px; }
  .lp-doc-label { font-size: 12px; color: rgba(235, 238, 255, 0.6); text-transform: uppercase; letter-spacing: 0.5px; }

  .lp-content, .lp-why { padding: 44px 0; }
  .section-title { font-size: 28px; font-weight: 600; line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 22px; }
  .lp-tematy-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .lp-temat {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 10px;
  }
  .lp-temat-num { font-size: 13px; font-weight: 800; color: #FFDE59; }
  .lp-temat-name { font-size: 13px; color: #EBEEFF; font-weight: 600; }
  .lp-temat-more { border-style: dashed; opacity: 0.7; justify-content: center; }
  .lp-temat-more .lp-temat-name { color: rgba(63, 206, 207, 0.8); font-style: italic; }

  .lp-why { background: rgba(63, 206, 207, 0.03); border-top: 1px solid rgba(63, 206, 207, 0.12); }
  .lp-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .lp-why-card {
    padding: 22px 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 12px;
  }
  .lp-why-ico { font-size: 34px; margin-bottom: 10px; }
  .lp-why-card strong { font-size: 15px; color: #EBEEFF; display: block; margin-bottom: 6px; }
  .lp-why-card span { font-size: 12.5px; color: rgba(235, 238, 255, 0.65); line-height: 1.55; }

  .lp-cta-section { padding: 50px 0; background: rgba(255, 222, 89, 0.06); border-top: 1px solid rgba(255, 222, 89, 0.2); }
  .lp-cta-center { text-align: center; max-width: 480px; margin: 0 auto; }
  .lp-cta-title { font-size: 26px; font-weight: 700; margin-bottom: 10px; }
  .lp-cta-sub { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin-bottom: 20px; }
  .lp-cta-btn { display: inline-block; }
  .lp-form { display: flex; flex-direction: column; gap: 10px; }
  .lp-input {
    padding: 13px 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(235, 238, 255, 0.2);
    border-radius: 10px;
    color: #EBEEFF; font-size: 14px; font-family: inherit; text-align: center;
  }
  .lp-input:focus { outline: none; border-color: #FFDE59; }
  .lp-form-btn {
    padding: 14px; background: #FFDE59; color: #050A24; border: none;
    border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
  }
  .lp-form-btn:hover { background: #FFE680; }
  .lp-embed-wrap { max-width: 560px; margin: 0 auto; }
  .lp-embed-frame { background: #fff; border-radius: 14px; overflow: hidden; min-height: 480px; margin-top: 16px; }
  .lp-embed-frame iframe { width: 100%; border: none; display: block; }

  @media (max-width: 900px) {
    .lp-hero-grid { grid-template-columns: 1fr; }
    .lp-title { font-size: 30px; }
    .lp-tematy-grid { grid-template-columns: repeat(2, 1fr); }
    .lp-why-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .lp-tematy-grid { grid-template-columns: 1fr; }
  }
</style>
