---
// =====================================================
// STRONA SKLEP — PDF do nauki
// =====================================================
import Layout from '../layouts/Layout.astro';

const kompendia = [
  {
    name: 'Matura podstawowa',
    price: 77,
    title: 'Kompendium',
    subtitle: 'matura podstawowa',
    formula: '∫f(x)dx',
    meta: '26 DZIAŁÓW · PDF',
    desc: 'Cały materiał z matury podstawowej + wideo omówienie jak korzystać.',
    color: 'yellow', // żółta okładka
    slug: 'kompendium-matura-podstawowa',
  },
  {
    name: 'Matura rozszerzona',
    price: 97,
    title: 'Kompendium',
    subtitle: 'matura rozszerzona',
    formula: 'lim ∑ π',
    meta: '35 DZIAŁÓW · PDF',
    desc: 'Pełen materiał rozszerzony — z analizą, granicami, pochodnymi i całkami.',
    color: 'teal',
    badge: 'NAJOBSZERNIEJSZE',
    slug: 'kompendium-matura-rozszerzona',
  },
  {
    name: 'Ósmoklasista',
    price: 57,
    title: 'Kompendium',
    subtitle: 'ósmoklasista',
    formula: 'a² + b²',
    meta: '12 DZIAŁÓW · PDF',
    desc: 'Cała teoria do egzaminu ósmoklasisty. Zwięźle, z przykładami.',
    color: 'lavender',
    slug: 'kompendium-osmoklasista',
  },
];

const mapyKolory = [
  'teal','yellow','lavender','yellow','teal','lavender',
  'lavender','teal','yellow','yellow','lavender','teal',
];

const pojedyncze = [
  { num: '1.5', name: 'Logarytmy' },
  { num: '1.8', name: 'Funkcje i własności' },
  { num: '1.9', name: 'Funkcja liniowa' },
  { num: '1.12', name: 'Trygonometria cz.1' },
];

const kroki = [
  { num: 1, title: 'Wybierasz produkt', desc: 'Klikasz „Kup" na wybranym PDF', color: 'yellow' },
  { num: 2, title: 'Płacisz online', desc: 'BLIK / karta / Przelewy24', color: 'yellow' },
  { num: 3, title: 'Automatyczny dostęp', desc: 'Konto na kurs.mathouse.pl', color: 'yellow' },
  { num: 4, title: 'Pobierasz i uczysz się', desc: 'PDF + wideo "jak korzystać"', color: 'teal' },
];
---

<Layout
  title="Sklep — kompendia i mapy myśli"
  description="Kompendia teorii do matury podstawowej (77 zł), rozszerzonej (97 zł) i ósmoklasisty (57 zł). Mapy myśli klasy 1 (47 zł). Wszystkie materiały w formie PDF, dostarczane przez kurs.mathouse.pl."
>
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>Sklep</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="sklep-hero">
    <div class="container-content sklep-hero-inner">
      <span class="tag-teal">📄 wyłącznie PDF · automatyczny dostęp po zakupie</span>
      <h1 class="sklep-title">
        Materiały do nauki<span class="text-yellow">.</span>
      </h1>
      <p class="sklep-desc">
        Kompendia teorii i mapy myśli, które wykorzystuję na korepetycjach i w kursach.
        Dostarczane przez platformę kurs.mathouse.pl — automatycznie po zakupie.
      </p>
    </div>
  </section>

  <!-- 3 ZALETY -->
  <section class="sklep-zalety">
    <div class="container-content zalety-grid">
      <div class="zaleta">
        <div class="zaleta-icon yellow"><i class="ti ti-bolt"></i></div>
        <div>
          <div class="zaleta-title">Natychmiastowy dostęp</div>
          <div class="zaleta-desc">PDF dostępny po zakupie</div>
        </div>
      </div>
      <div class="zaleta">
        <div class="zaleta-icon teal"><i class="ti ti-printer"></i></div>
        <div>
          <div class="zaleta-title">Drukuj lub czytaj</div>
          <div class="zaleta-desc">tablet, papier, jak chcesz</div>
        </div>
      </div>
      <div class="zaleta">
        <div class="zaleta-icon yellow"><i class="ti ti-infinity"></i></div>
        <div>
          <div class="zaleta-title">Dostęp na zawsze</div>
          <div class="zaleta-desc">bez subskrypcji, bez limitów</div>
        </div>
      </div>
    </div>
  </section>

  <!-- KOMPENDIA -->
  <section class="section-kompendia">
    <div class="container-content">
      <div class="section-header">
        <div>
          <div class="section-label yellow">§ 01 · KOMPENDIA TEORII</div>
          <h2 class="section-title">
            Cała teoria do egzaminu <span class="text-yellow">w jednym PDF</span>
          </h2>
        </div>
        <div class="section-meta">Pełen materiał teoretyczny + wideo "jak korzystać"</div>
      </div>

      <div class="kompendia-grid">
        {kompendia.map((k) => (
          <article class={`produkt-card produkt-${k.color}`}>
            {k.badge && <span class="produkt-badge">{k.badge}</span>}
            <div class={`produkt-okladka okladka-${k.color}`}>
              <div class="okladka-brand">MATHOUSE · 2026</div>
              <div class="okladka-title">{k.title}</div>
              <div class="okladka-subtitle">{k.subtitle}</div>
              <div class="okladka-formula">{k.formula}</div>
              <div class="okladka-foot">{k.meta}</div>
            </div>
            <div class="produkt-info">
              <div class="produkt-head">
                <div class="produkt-name">{k.name}</div>
                <div class="produkt-price">{k.price} zł</div>
              </div>
              <p class="produkt-desc">{k.desc}</p>
              <div class="produkt-actions">
                <a href={`/sklep/${k.slug}`} class="btn-primary produkt-cta">Kup · {k.price} zł</a>
                <a href="#" class="produkt-probka">↓ próbka</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MAPY MYŚLI -->
  <section class="section-mapy">
    <div class="container-content">
      <div class="section-header" style="margin-bottom:18px">
        <div>
          <div class="section-label">§ 02 · MAPY MYŚLI</div>
          <h2 class="section-title">
            Cały dział na <span class="text-teal">jednej kartce</span>
          </h2>
          <p class="mapy-intro">
            Powtórka przed klasówką? Jedna mapa myśli = jeden dział. Wszystkie wzory, definicje
            i schematy w wizualnej formie.
          </p>
        </div>
      </div>

      <div class="mapy-grid">
        <!-- Komplet -->
        <div class="mapa-komplet">
          <div class="mapa-komplet-left">
            <div class="section-label">⭐ NAJLEPSZA WARTOŚĆ</div>
            <h3 class="mapa-komplet-h">Mapy myśli — komplet klasy 1 liceum</h3>
            <p class="mapa-komplet-d">
              12 map myśli, jedna na każdy dział klasy 1. Idealne na powtórki przed klasówką.
            </p>
            <div class="mapa-komplet-prices">
              <span class="mapa-now">47 zł</span>
              <span class="mapa-old">120 zł</span>
            </div>
            <a href="/sklep/mapy-mysli-klasa-1" class="btn-primary mapa-komplet-cta">Kup komplet →</a>
          </div>
          <div class="mapa-miniatury">
            {mapyKolory.map((color, i) => (
              <div class={`mapa-mini mapa-mini-${color}`}>1.{i + 1}</div>
            ))}
          </div>
        </div>

        <!-- Pojedyncze -->
        <div class="mapa-pojedyncze">
          <div class="poj-label">LUB KUP POJEDYNCZE · 9 ZŁ/SZT</div>
          <div class="poj-list">
            {pojedyncze.map((p) => (
              <div class="poj-row">
                <span><span class="poj-num">{p.num}</span> {p.name}</span>
                <span class="text-yellow">9 zł</span>
              </div>
            ))}
            <div class="poj-more">+ 8 innych →</div>
          </div>
        </div>
      </div>

      <p class="mapy-savings">
        Kupując pojedynczo zapłacisz 108 zł za 12 sztuk. Kupując komplet — 47 zł.
        <span class="text-teal">Oszczędzasz 61 zł.</span>
      </p>
    </div>
  </section>

  <!-- INNE -->
  <section class="section-inne">
    <div class="container-content">
      <div style="margin-bottom:18px">
        <div class="section-label lavender">§ 03 · INNE</div>
        <h2 class="section-title">Dodatkowe materiały</h2>
      </div>

      <div class="inne-grid">
        <div class="inne-card">
          <div class="inne-cover yellow">
            <i class="ti ti-rocket"></i>
          </div>
          <div class="inne-body">
            <span class="inne-badge">BESTSELLER</span>
            <div class="inne-name">Matematyczny Autopilot</div>
            <p class="inne-desc">Schemat krok po kroku — jak rozwiązywać zadania bez stresu.</p>
            <div class="inne-prices">
              <span class="inne-now">99 zł</span>
              <span class="inne-old">159 zł</span>
            </div>
          </div>
        </div>

        <div class="inne-card inne-card-soon">
          <div class="inne-cover-empty">+</div>
          <div class="inne-body">
            <span class="inne-badge inne-badge-soon">WKRÓTCE</span>
            <div class="inne-name soft">Mapy myśli klas 2, 3, 4</div>
            <p class="inne-desc">Pełne komplety na kolejne lata liceum.</p>
            <a href="#" class="inne-notify">Powiadom mnie →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DARMOWY FRAGMENT -->
  <section class="section-fragment">
    <div class="container-content fragment-grid">
      <div>
        <div class="section-label">📄 ZANIM KUPISZ</div>
        <h2 class="fragment-title">Zobacz darmowy fragment kompendium.</h2>
        <p class="fragment-desc">
          Wyślę Ci PDF z dwoma działami z kompendium podstawowego (20 stron). Sprawdź jakość zanim wydasz pieniądze.
        </p>
      </div>
      <form class="fragment-form" action="https://formspree.io/f/PLACEHOLDER" method="POST">
        <input type="text" name="imie" placeholder="Twoje imię" required class="fragment-input" />
        <input type="email" name="email" placeholder="Twój email" required class="fragment-input" />
        <button type="submit" class="btn-primary fragment-submit">Wyślij mi darmowy fragment →</button>
        <p class="fragment-note">Zgoda RODO. Możesz się wypisać w każdej chwili.</p>
      </form>
    </div>
  </section>

  <!-- JAK DZIAŁA -->
  <section class="section-jak-dziala">
    <div class="container-content">
      <div class="section-label" style="text-align:center">JAK DZIAŁA ZAKUP</div>
      <div class="kroki-grid">
        {kroki.map((k) => (
          <div class="krok-item">
            <div class={`krok-circle ${k.color}`}>{k.num}</div>
            <div class="krok-title">{k.title}</div>
            <div class="krok-desc">{k.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb span { color: #FFDE59; }
  .text-yellow { color: #FFDE59; }
  .text-teal { color: #3FCECF; }
  .lavender { color: #EBEEFF; opacity: 0.85; }

  /* ===================================================== */
  /* HERO + ZALETY                                          */
  /* ===================================================== */
  .sklep-hero {
    padding: 48px 0;
  }
  .sklep-hero-inner {
    text-align: center;
  }
  .sklep-title {
    font-size: 46px;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -1.2px;
    margin: 18px 0 14px;
  }
  .sklep-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .sklep-zalety {
    background: rgba(63, 206, 207, 0.05);
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    border-bottom: 1px solid rgba(235, 238, 255, 0.1);
    padding: 24px 0;
  }
  .zalety-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .zaleta {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .zaleta-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .zaleta-icon.yellow {
    background: rgba(255, 222, 89, 0.15);
    color: #FFDE59;
  }
  .zaleta-icon.teal {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
  }
  .zaleta-icon i {
    font-size: 20px;
  }
  .zaleta-title {
    font-size: 13px;
    font-weight: 600;
  }
  .zaleta-desc {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
  }

  /* ===================================================== */
  /* KOMPENDIA                                              */
  /* ===================================================== */
  .section-kompendia {
    padding: 40px 0;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 20px;
  }
  .section-title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.5px;
    line-height: 1.15;
  }
  .section-meta {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    max-width: 260px;
    text-align: right;
    line-height: 1.5;
  }

  .kompendia-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .produkt-card {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.15s ease;
  }
  .produkt-card:hover {
    transform: translateY(-2px);
  }
  .produkt-yellow { border: 1px solid rgba(255, 222, 89, 0.25); }
  .produkt-teal { border: 1px solid rgba(63, 206, 207, 0.3); }
  .produkt-lavender { border: 1px solid rgba(235, 238, 255, 0.15); }

  .produkt-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #3FCECF;
    color: #050A24;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 600;
    z-index: 5;
  }

  /* === Okładka PDF === */
  .produkt-okladka {
    aspect-ratio: 3/4;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    color: #050A24;
  }
  .okladka-yellow {
    background: linear-gradient(135deg, #FFDE59 0%, #FFB800 100%);
  }
  .okladka-teal {
    background: linear-gradient(135deg, #3FCECF 0%, #2B9899 100%);
  }
  .okladka-lavender {
    background: linear-gradient(135deg, #EBEEFF 0%, #B8C0D9 100%);
  }
  .okladka-brand {
    font-size: 9px;
    letter-spacing: 2px;
    opacity: 0.7;
  }
  .okladka-title {
    font-family: 'Instrument Serif', serif;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -1px;
    margin-top: 8px;
  }
  .okladka-subtitle {
    font-size: 14px;
    font-weight: 600;
    margin-top: 3px;
  }
  .okladka-formula {
    font-family: 'Instrument Serif', serif;
    font-size: 38px;
    margin-top: 18px;
    line-height: 1;
  }
  .okladka-foot {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #050A24;
    color: #FFDE59;
    padding: 6px;
    text-align: center;
    font-size: 9px;
    letter-spacing: 1.5px;
    font-weight: 600;
  }
  .produkt-teal .okladka-foot {
    color: #3FCECF;
  }
  .produkt-lavender .okladka-foot {
    color: #EBEEFF;
  }

  .produkt-info {
    padding: 18px;
  }
  .produkt-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .produkt-name {
    font-size: 15px;
    font-weight: 600;
  }
  .produkt-price {
    font-size: 22px;
    font-weight: 600;
    color: #FFDE59;
  }
  .produkt-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
    margin-bottom: 14px;
  }
  .produkt-actions {
    display: flex;
    gap: 6px;
  }
  .produkt-cta {
    flex: 1;
    text-align: center;
  }
  .produkt-probka {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
    padding: 10px 14px;
    border-radius: 7px;
    font-size: 12px;
    border: 1px solid rgba(63, 206, 207, 0.3);
    text-decoration: none;
  }

  /* ===================================================== */
  /* MAPY MYŚLI                                             */
  /* ===================================================== */
  .section-mapy {
    padding: 40px 0;
    background: rgba(63, 206, 207, 0.05);
    border-top: 1px solid rgba(63, 206, 207, 0.2);
    border-bottom: 1px solid rgba(63, 206, 207, 0.2);
  }
  .mapy-intro {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    max-width: 540px;
    margin-top: 8px;
    line-height: 1.6;
  }

  .mapy-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 14px;
  }

  .mapa-komplet {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(63, 206, 207, 0.3);
    border-radius: 14px;
    padding: 22px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    align-items: center;
  }
  .mapa-komplet-h {
    font-size: 19px;
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: 8px;
  }
  .mapa-komplet-d {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
    margin-bottom: 14px;
  }
  .mapa-komplet-prices {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 12px;
  }
  .mapa-now {
    font-size: 26px;
    font-weight: 600;
    color: #FFDE59;
  }
  .mapa-old {
    font-size: 13px;
    text-decoration: line-through;
    color: rgba(235, 238, 255, 0.5);
  }
  .mapa-komplet-cta {
    text-align: center;
    display: block;
  }

  .mapa-miniatury {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5px;
  }
  .mapa-mini {
    aspect-ratio: 1;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #050A24;
    font-size: 10px;
    font-weight: 600;
  }
  .mapa-mini-teal {
    background: linear-gradient(135deg, #3FCECF, #2B9899);
  }
  .mapa-mini-yellow {
    background: linear-gradient(135deg, #FFDE59, #FFB800);
  }
  .mapa-mini-lavender {
    background: linear-gradient(135deg, #EBEEFF, #B8C0D9);
  }

  .mapa-pojedyncze {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(235, 238, 255, 0.1);
    border-radius: 14px;
    padding: 20px;
  }
  .poj-label {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1px;
    margin-bottom: 12px;
  }
  .poj-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 12px;
  }
  .poj-row {
    display: flex;
    justify-content: space-between;
    padding: 7px 11px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
  }
  .poj-num {
    color: rgba(235, 238, 255, 0.5);
  }
  .poj-more {
    text-align: center;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    padding: 6px;
  }

  .mapy-savings {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    margin-top: 14px;
    text-align: center;
  }

  /* ===================================================== */
  /* INNE                                                   */
  /* ===================================================== */
  .section-inne {
    padding: 40px 0;
  }
  .inne-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .inne-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 222, 89, 0.25);
    border-radius: 12px;
    padding: 18px;
    display: flex;
    gap: 16px;
  }
  .inne-card-soon {
    border: 1px dashed rgba(235, 238, 255, 0.2);
  }
  .inne-cover {
    width: 64px;
    height: 84px;
    background: linear-gradient(135deg, #FFDE59, #FFB800);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #050A24;
    flex-shrink: 0;
  }
  .inne-cover i {
    font-size: 26px;
  }
  .inne-cover-empty {
