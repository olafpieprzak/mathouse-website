---
import Layout from '../../layouts/Layout.astro';

// =====================================================
// LANDING PAGE: KURS DZIAŁU - SZABLON
// URL: /kurs/zbiory-liczbowe
// =====================================================
// Ten plik to SZABLON do replikacji dla każdego działu.
// Skopiuj jako: src/pages/kurs/[slug].astro i zmień dane.
// =====================================================

const dzial = {
  num: '1.1',
  slug: 'zbiory-liczbowe',
  tytul: 'Zbiory liczbowe',
  podtytul: 'Fundament całej matematyki — zacznij tutaj.',
  czas: '~6 godzin',
  poziom: 'Liceum · Klasa 1',
  cena: '197 zł',
  cenaPrzed: '399 zł',

  // PEŁEN OPIS DZIAŁU (TY WYPEŁNISZ)
  opis: 'W tym dziale poznasz podstawy całej matematyki licealnej. Naucze się rozróżniać typy liczb, wykonywać działania na zbiorach i rozumieć dlaczego niektóre liczby są wymierne a inne nie. To fundament, na którym opiera się WSZYSTKO co będziesz robił przez następne 4 lata. Jeśli ogarniesz ten dział — reszta liceum będzie dużo prostsza.',

  // CO SIĘ NAUCZYSZ
  korzysci: [
    'Bezbłędnie rozróżniać liczby naturalne, całkowite, wymierne i niewymierne',
    'Wyznaczać NWD i NWW dwóch liczb',
    'Wykonywać działania na zbiorach (suma, iloczyn, różnica)',
    'Zapisywać przedziały liczbowe',
    'Rozumieć dlaczego pierwiastek z 2 jest niewymierny',
    'Zaliczać klasówki ze zbiorów z minimalnym wysiłkiem',
  ],

  // LEKCJE WEWNĄTRZ
  lekcje: [
    { num: 1, tytul: 'Zbiory liczbowe — wprowadzenie', czas: '52 min', free: true },
    { num: 2, tytul: 'Liczby naturalne, NWD, NWW', czas: '48 min', free: false },
    { num: 3, tytul: 'Liczby całkowite i wymierne', czas: '41 min', free: false },
    { num: 4, tytul: 'Liczby niewymierne', czas: '38 min', free: false },
    { num: 5, tytul: 'Liczby rzeczywiste', czas: '35 min', free: false },
    { num: 6, tytul: 'Działania na zbiorach', czas: '44 min', free: false },
    { num: 7, tytul: 'Przedziały liczbowe', czas: '36 min', free: false },
    { num: 8, tytul: 'Zadania maturalne ze zbiorów', czas: '58 min', free: false },
  ],

  // CO ZAWIERA
  zawartosc: [
    '8 lekcji wideo (~6 godzin)',
    'Pełna teoria krok po kroku',
    'Przykłady rozwiązanych zadań',
    'Zadania do samodzielnej pracy',
    'Rozwiązania krok po kroku',
    'Zadania maturalne z odpowiedziami',
    'Dostęp na zawsze',
    'Bez limitów oglądania',
  ],
};
---

<Layout
  title={`Kurs ${dzial.tytul} — ${dzial.poziom}`}
  description={`Kurs MATHOUSE: ${dzial.tytul}. ${dzial.opis.substring(0, 120)}...`}
>
  <main class="kurs-page">

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
      <div class="container-content">
        <a href="/">Strona</a> / <a href="/kursy">Kursy</a> / <a href="/kursy/liceum-podstawa">Liceum</a> / <span>{dzial.tytul}</span>
      </div>
    </div>

    <!-- HERO -->
    <section class="kurs-hero">
      <div class="container-content">
        <div class="hero-grid">
          <div class="hero-left">
            <div class="hero-badges">
              <span class="badge badge-num">{dzial.num}</span>
              <span class="badge badge-level">{dzial.poziom}</span>
              <span class="badge badge-time">⏱️ {dzial.czas}</span>
            </div>
            <h1 class="hero-title">{dzial.tytul}</h1>
            <p class="hero-sub">{dzial.podtytul}</p>
            <p class="hero-opis">{dzial.opis}</p>
            <div class="hero-cta">
              <a href="#lekcja-probna" class="btn-primary">▶️ Obejrzyj lekcję próbną</a>
              <a href="#kup" class="btn-secondary">Kup kurs — {dzial.cena}</a>
            </div>
          </div>

          <div class="hero-right">
            <!-- Karta z ceną -->
            <div class="price-card">
              <div class="price-label">CENA KURSU</div>
              <div class="price-main">
                <span class="price-now">{dzial.cena}</span>
                <span class="price-old">{dzial.cenaPrzed}</span>
              </div>
              <div class="price-saving">Oszczędzasz {parseInt(dzial.cenaPrzed) - parseInt(dzial.cena)} zł</div>
              <ul class="price-includes">
                {dzial.zawartosc.map((z) => <li>✓ {z}</li>)}
              </ul>
              <a href="#kup" class="btn-primary price-cta">Kup kurs →</a>
              <div class="price-guarantee">🛡️ 30 dni gwarancji zwrotu</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CO SIĘ NAUCZYSZ -->
    <section class="kurs-korzysci">
      <div class="container-content">
        <div class="section-label">CO ZYSKASZ</div>
        <h2 class="section-title">Po ukończeniu tego kursu...</h2>
        <div class="korzysci-grid">
          {dzial.korzysci.map((k) => (
            <div class="korzysc-item">
              <div class="korzysc-icon">✅</div>
              <div class="korzysc-text">{k}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LEKCJE -->
    <section class="kurs-lekcje">
      <div class="container-content">
        <div class="section-label">PROGRAM KURSU</div>
        <h2 class="section-title">{dzial.lekcje.length} lekcji wideo</h2>
        <p class="section-sub">Każda lekcja zawiera pełną teorię + przykłady + zadania</p>
        <div class="lekcje-list">
          {dzial.lekcje.map((l) => (
            <div class={`lekcja-item ${l.free ? 'lekcja-free' : ''}`}>
              <div class="lekcja-num">{l.num}</div>
              <div class="lekcja-info">
                <div class="lekcja-tytul">{l.tytul}</div>
                <div class="lekcja-czas">⏱️ {l.czas}</div>
              </div>
              {l.free ? (
                <a href="#lekcja-probna" class="lekcja-tag lekcja-tag-free">▶️ ZA DARMO</a>
              ) : (
                <div class="lekcja-tag">🔒 Płatne</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LEKCJA PRÓBNA -->
    <section id="lekcja-probna" class="kurs-probna">
      <div class="container-content">
        <div class="probna-box">
          <div class="section-label">🎁 LEKCJA PRÓBNA</div>
          <h2 class="probna-title">Zobacz jak uczę<br /><span class="text-yellow">— przed zakupem.</span></h2>
          <p class="probna-sub">
            Pierwsza lekcja kursu jest dostępna za darmo. Obejrzyj i zdecyduj sam czy chcesz dalej.
          </p>

          <!-- PLACEHOLDER WIDEO 9:16 -->
          <div class="probna-video">
            <div class="video-placeholder">
              <div class="play-btn">▶</div>
              <div class="video-label">Lekcja próbna: {dzial.lekcje[0].tytul}</div>
              <div class="video-time">⏱️ {dzial.lekcje[0].czas}</div>
              <div class="video-note">📹 Wgraj wideo do: /public/videos/lekcje-probne/{dzial.slug}.mp4</div>
            </div>
          </div>

          <div class="probna-cta">
            <p>Podobało Ci się? Kup kurs i ucz się dalej:</p>
            <a href="#kup" class="btn-primary">Kup kurs — {dzial.cena} →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ZAKUP -->
    <section id="kup" class="kurs-kup">
      <div class="container-content">
        <div class="kup-box">
          <div class="section-label">ZAMÓW KURS</div>
          <h2 class="kup-title">{dzial.tytul}<br /><span class="text-yellow">— pełny kurs</span></h2>

          <div class="kup-features">
            {dzial.zawartosc.map((z) => (
              <div class="kup-feature">✓ {z}</div>
            ))}
          </div>

          <div class="kup-price-box">
            <div class="kup-price-label">CENA</div>
            <div class="kup-price-amount">
              <span class="kup-price-now">{dzial.cena}</span>
              <span class="kup-price-old">{dzial.cenaPrzed}</span>
            </div>
          </div>

          <!-- TYMCZASOWY PLACEHOLDER - w przyszłości tu będzie Stripe / formularz -->
          <a href={`https://kurs.mathouse.pl/s/${dzial.slug}.html`} target="_blank" rel="noopener noreferrer" class="btn-primary kup-cta">
            Kup kurs na platformie →
          </a>

          <div class="kup-payment">
            <strong>Metody płatności:</strong> BLIK · Przelew · Karta · PayPal
          </div>
          <div class="kup-guarantee">
            🛡️ <strong>Gwarancja zwrotu pieniędzy</strong> — masz 30 dni żeby się rozczarować
          </div>
        </div>
      </div>
    </section>

    <!-- POWRÓT -->
    <section class="kurs-back">
      <div class="container-content">
        <a href="/kursy/liceum-podstawa" class="back-link">← Wszystkie działy klasy 1</a>
      </div>
    </section>

  </main>
</Layout>

<style>
  .kurs-page { color: #EBEEFF; }
  .text-yellow { color: #FFDE59; }

  .breadcrumb { padding: 16px 0; font-size: 12px; color: rgba(235,238,255,0.5); }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: #FFDE59; }
  .breadcrumb span { color: #FFDE59; }

  /* HERO */
  .kurs-hero { padding: 40px 0 60px; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: flex-start;
  }
  .hero-badges { display: flex; gap: 8px; margin-bottom: 18px; flex-wrap: wrap; }
  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .badge-num { background: rgba(63, 206, 207, 0.15); color: #3FCECF; }
  .badge-level { background: rgba(255, 222, 89, 0.15); color: #FFDE59; }
  .badge-time { background: rgba(235, 238, 255, 0.06); color: rgba(235, 238, 255, 0.7); }
  .hero-title { font-size: 48px; font-weight: 700; line-height: 1.1; letter-spacing: -1px; margin: 0 0 12px; }
  .hero-sub { font-size: 18px; color: #FFDE59; font-weight: 600; margin-bottom: 18px; }
  .hero-opis { font-size: 15px; color: rgba(235, 238, 255, 0.75); line-height: 1.7; margin-bottom: 24px; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* PRICE CARD */
  .price-card {
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.08), rgba(63, 206, 207, 0.04));
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 18px;
    padding: 28px;
    position: sticky;
    top: 100px;
  }
  .price-label { font-size: 10px; letter-spacing: 1.5px; color: rgba(235, 238, 255, 0.5); margin-bottom: 8px; }
  .price-main { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .price-now { font-size: 38px; font-weight: 700; color: #FFDE59; }
  .price-old { font-size: 16px; text-decoration: line-through; color: rgba(235, 238, 255, 0.4); }
  .price-saving { font-size: 12px; color: #3FCECF; margin-bottom: 20px; font-weight: 600; }
  .price-includes { list-style: none; padding: 0; margin: 0 0 18px; }
  .price-includes li { font-size: 13px; color: rgba(235, 238, 255, 0.8); padding: 5px 0; }
  .price-cta { display: block; text-align: center; }
  .price-guarantee { font-size: 11px; color: rgba(235, 238, 255, 0.55); text-align: center; margin-top: 12px; }

  /* SECTIONS */
  .kurs-korzysci, .kurs-lekcje, .kurs-probna, .kurs-kup {
    padding: 60px 0;
  }
  .kurs-korzysci { background: rgba(255, 255, 255, 0.02); }
  .kurs-probna { background: rgba(63, 206, 207, 0.04); }
  .kurs-kup {
    background: linear-gradient(180deg, transparent, rgba(255, 222, 89, 0.04));
    padding-bottom: 80px;
  }

  .section-title { font-size: 36px; font-weight: 700; line-height: 1.15; margin: 8px 0 14px; letter-spacing: -0.5px; }
  .section-sub { font-size: 14px; color: rgba(235, 238, 255, 0.65); margin: 0 0 28px; }

  /* KORZYŚCI */
  .korzysci-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-top: 28px;
  }
  .korzysc-item {
    display: flex;
    gap: 14px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
  }
  .korzysc-icon { font-size: 18px; flex-shrink: 0; color: #3FCECF; }
  .korzysc-text { font-size: 14px; color: #EBEEFF; line-height: 1.55; }

  /* LEKCJE */
  .lekcje-list { display: flex; flex-direction: column; gap: 8px; margin-top: 24px; }
  .lekcja-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px;
    align-items: center;
    padding: 16px 20px;
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
  }
  .lekcja-free { border-color: rgba(63, 206, 207, 0.4); }
  .lekcja-num {
    width: 32px; height: 32px;
    background: rgba(255, 222, 89, 0.1);
    color: #FFDE59;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px;
  }
  .lekcja-tytul { font-size: 15px; font-weight: 600; margin-bottom: 2px; }
  .lekcja-czas { font-size: 11px; color: rgba(235, 238, 255, 0.5); }
  .lekcja-tag {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    background: rgba(235, 238, 255, 0.05);
    padding: 6px 12px;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
  }
  .lekcja-tag-free {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
    cursor: pointer;
  }

  /* LEKCJA PRÓBNA */
  .probna-box {
    background: rgba(5, 10, 36, 0.5);
    border: 2px solid rgba(63, 206, 207, 0.3);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
  }
  .probna-title { font-size: 36px; font-weight: 700; line-height: 1.1; margin: 8px 0 14px; }
  .probna-sub { font-size: 15px; color: rgba(235, 238, 255, 0.7); margin-bottom: 28px; }

  /* WIDEO 9:16 placeholder */
  .probna-video {
    max-width: 360px;
    margin: 0 auto 28px;
    aspect-ratio: 9 / 16;
    background: rgba(5, 10, 36, 0.8);
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 16px;
    overflow: hidden;
  }
  .video-placeholder {
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 20px;
    background: linear-gradient(135deg, rgba(255, 222, 89, 0.05), rgba(63, 206, 207, 0.05));
  }
  .play-btn {
    width: 72px; height: 72px;
    background: #FFDE59;
    color: #050A24;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px;
    cursor: pointer;
    transition: transform 0.2s ease;
    margin-bottom: 8px;
  }
  .play-btn:hover { transform: scale(1.1); }
  .video-label { font-size: 14px; font-weight: 700; color: #EBEEFF; text-align: center; }
  .video-time { font-size: 12px; color: rgba(235, 238, 255, 0.6); }
  .video-note { font-size: 10px; color: rgba(255, 222, 89, 0.6); margin-top: 8px; padding: 6px 10px; background: rgba(255, 222, 89, 0.05); border-radius: 6px; }

  .probna-cta p { font-size: 14px; color: rgba(235, 238, 255, 0.7); margin-bottom: 14px; }

  /* KUP */
  .kup-box {
    background: rgba(5, 10, 36, 0.5);
    border: 2px solid rgba(255, 222, 89, 0.3);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .kup-title { font-size: 32px; font-weight: 700; line-height: 1.15; margin: 8px 0 24px; }
  .kup-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    text-align: left;
    margin-bottom: 28px;
  }
  .kup-feature { font-size: 13px; color: rgba(235, 238, 255, 0.85); padding: 4px 0; }
  .kup-price-box {
    background: rgba(255, 222, 89, 0.08);
    border: 1px solid rgba(255, 222, 89, 0.3);
    border-radius: 14px;
    padding: 22px;
    margin-bottom: 24px;
  }
  .kup-price-label { font-size: 11px; letter-spacing: 2px; color: rgba(235, 238, 255, 0.5); margin-bottom: 8px; }
  .kup-price-amount { display: flex; align-items: baseline; justify-content: center; gap: 14px; }
  .kup-price-now { font-size: 48px; font-weight: 700; color: #FFDE59; }
  .kup-price-old { font-size: 18px; text-decoration: line-through; color: rgba(235, 238, 255, 0.4); }
  .kup-cta { font-size: 16px; padding: 16px 36px; }
  .kup-payment { margin-top: 16px; font-size: 12px; color: rgba(235, 238, 255, 0.65); }
  .kup-guarantee { margin-top: 12px; font-size: 13px; color: rgba(235, 238, 255, 0.75); padding: 12px; background: rgba(63, 206, 207, 0.06); border-radius: 8px; }

  /* BACK */
  .kurs-back { padding: 30px 0 60px; }
  .back-link {
    color: rgba(235, 238, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  .back-link:hover { color: #FFDE59; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .price-card { position: static; }
    .hero-title { font-size: 32px; }
    .section-title, .probna-title, .kup-title { font-size: 26px; }
    .korzysci-grid, .kup-features { grid-template-columns: 1fr; }
    .lekcja-item { grid-template-columns: auto 1fr; gap: 12px; padding: 14px; }
    .lekcja-tag { grid-column: 2; justify-self: flex-start; }
  }
</style>
