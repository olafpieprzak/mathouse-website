---
import Layout from '../layouts/Layout.astro';
import { dzialy } from '../data/dzialy.js';

// Pobieram działy z centralnej bazy danych
const klasa1 = dzialy.filter((d) => d.klasaNum === 1);
const klasa2 = dzialy.filter((d) => d.klasaNum === 2);
const klasa3 = dzialy.filter((d) => d.klasaNum === 3);
const klasa4 = dzialy.filter((d) => d.klasaNum === 4);

const osmoklasista = ['Liczby naturalne', 'Ułamki', 'Procenty', 'Wyrażenia algebraiczne', 'Równania 1°', 'Proporcjonalność', 'Geom. płaska', 'Geom. przestrzenna', 'Statystyka'];

// Lista wszystkich klas dla akordeonu mobilnego
const wszystkieKlasy = [
  { num: 1, label: 'Klasa 1', subtitle: '12 działów · ✅ Dostępne', dzialy: klasa1, defaultOpen: true, status: 'live' },
  { num: 2, label: 'Klasa 2', subtitle: '8 działów · ⏳ Wkrótce', dzialy: klasa2, defaultOpen: false, status: 'soon' },
  { num: 3, label: 'Klasa 3', subtitle: '6 działów · ⏳ Wkrótce', dzialy: klasa3, defaultOpen: false, status: 'soon' },
  { num: 4, label: 'Klasa 4', subtitle: '6 działów · ⏳ Wkrótce', dzialy: klasa4, defaultOpen: false, status: 'soon' },
];
---

<Layout
  title="Mapa Nauki Matematyki — wszystkie kursy MATHOUSE"
  description="Pełna ścieżka nauki matematyki od podstawówki do matury rozszerzonej. Cały plan krok po kroku ze strzałkami pokazującymi kolejność."
>
  <main class="mapa-page">
    <div class="container-content">

      <section class="mapa-hero">
        <div class="section-label">🗺️ MAPA NAUKI</div>
        <h1 class="mapa-title">Cały plan nauki<br /><span class="text-yellow">krok po kroku.</span></h1>
        <p class="mapa-sub">
          Działy ułożone w kolejności od pierwszego do ostatniego.<br />
          <span class="desktop-only"><strong>Najedź</strong> na dział → zobaczysz co zawiera. <strong>Klik</strong> → otwiera kurs.</span>
          <span class="mobile-only"><strong>Dotknij</strong> klasy aby rozwinąć. <strong>Dotknij</strong> działu aby zobaczyć szczegóły.</span>
        </p>
      </section>

      <!-- ====================================================== -->
      <!-- WERSJA DESKTOP — krok po kroku z popupem na hover     -->
      <!-- ====================================================== -->
      <section class="path-section path-priority desktop-only">
        <div class="path-header">
          <div class="path-icon">📘</div>
          <div>
            <div class="path-label">⭐ PRIORYTET · ŚCIEŻKA LICEUM</div>
            <h2 class="path-title">Klasa 1 — krok po kroku</h2>
            <p class="path-desc">12 działów w kolejności. Idź od 1.1 do 1.12.</p>
          </div>
        </div>

        <div class="steps-flow">
          {klasa1.map((d, i) => (
            <>
              <a href={`/kursy/${d.slug}`} class="step-tile step-tile-live">
                <div class="step-tile-head">
                  <div class="step-num">{d.num}</div>
                </div>
                <div class="step-name">{d.short}</div>
                <div class="step-content">
                  <div class="step-content-title">📚 W tym dziale:</div>
                  <ul class="step-content-list">
                    {d.podpunkty.map((p) => <li>{p}</li>)}
                  </ul>
                </div>
                <div class="step-content-cta">Przejdź do kursu →</div>
              </a>
              {i < klasa1.length - 1 && <div class="step-arrow">→</div>}
            </>
          ))}
        </div>

        <div class="big-arrow">↓</div>

        <div class="klasa-strip klasa-strip-soon klasa-strip-expanded">
          <div class="strip-label">KLASA 2 · 8 działów · ⏳ Wkrótce</div>
          <div class="strip-tiles strip-tiles-grid">
            {klasa2.map((d) => (
              <a href={`/kursy/${d.slug}`} class="step-tile step-tile-soon" data-step-toggle>
                <div class="step-tile-head">
                  <div class="step-num">{d.num}</div>
                </div>
                <div class="step-name">{d.short}</div>
                <div class="step-content">
                  <div class="step-content-title">📚 W tym dziale:</div>
                  <ul class="step-content-list step-content-list-collapsible">
                    {d.podpunkty.slice(0, 3).map((p) => <li>{p}</li>)}
                    {d.podpunkty.slice(3).map((p) => <li class="step-content-extra">{p}</li>)}
                    {d.podpunkty.length > 3 && (
                      <li class="step-content-more">
                        <button type="button" onclick="togglePodpunkty(event, this)" class="step-more-btn">
                          + pokaż jeszcze {d.podpunkty.length - 3}
                        </button>
                      </li>
                    )}
                  </ul>
                </div>
                <div class="step-content-cta">Zobacz szczegóły →</div>
              </a>
            ))}
          </div>
        </div>

        <div class="big-arrow">↓</div>

        <div class="klasa-strip klasa-strip-soon klasa-strip-expanded">
          <div class="strip-label">KLASA 3 · 6 działów · ⏳ Wkrótce</div>
          <div class="strip-tiles strip-tiles-grid">
            {klasa3.map((d) => (
              <a href={`/kursy/${d.slug}`} class="step-tile step-tile-soon" data-step-toggle>
                <div class="step-tile-head">
                  <div class="step-num">{d.num}</div>
                </div>
                <div class="step-name">{d.short}</div>
                <div class="step-content">
                  <div class="step-content-title">📚 W tym dziale:</div>
                  <ul class="step-content-list step-content-list-collapsible">
                    {d.podpunkty.slice(0, 3).map((p) => <li>{p}</li>)}
                    {d.podpunkty.slice(3).map((p) => <li class="step-content-extra">{p}</li>)}
                    {d.podpunkty.length > 3 && (
                      <li class="step-content-more">
                        <button type="button" onclick="togglePodpunkty(event, this)" class="step-more-btn">
                          + pokaż jeszcze {d.podpunkty.length - 3}
                        </button>
                      </li>
                    )}
                  </ul>
                </div>
                <div class="step-content-cta">Zobacz szczegóły →</div>
              </a>
            ))}
          </div>
        </div>

        <div class="big-arrow">↓</div>

        <div class="klasa-strip klasa-strip-soon klasa-strip-expanded">
          <div class="strip-label">KLASA 4 · 6 działów · ⏳ Wkrótce</div>
          <div class="strip-tiles strip-tiles-grid">
            {klasa4.map((d) => (
              <a href={`/kursy/${d.slug}`} class="step-tile step-tile-soon" data-step-toggle>
                <div class="step-tile-head">
                  <div class="step-num">{d.num}</div>
                </div>
                <div class="step-name">{d.short}</div>
                <div class="step-content">
                  <div class="step-content-title">📚 W tym dziale:</div>
                  <ul class="step-content-list step-content-list-collapsible">
                    {d.podpunkty.slice(0, 3).map((p) => <li>{p}</li>)}
                    {d.podpunkty.slice(3).map((p) => <li class="step-content-extra">{p}</li>)}
                    {d.podpunkty.length > 3 && (
                      <li class="step-content-more">
                        <button type="button" onclick="togglePodpunkty(event, this)" class="step-more-btn">
                          + pokaż jeszcze {d.podpunkty.length - 3}
                        </button>
                      </li>
                    )}
                  </ul>
                </div>
                <div class="step-content-cta">Zobacz szczegóły →</div>
              </a>
            ))}
          </div>
        </div>

        <div class="split-row">
          <div class="split-arrow">↙</div>
          <div class="split-info">Po klasie 4 wybierasz poziom matury:</div>
          <div class="split-arrow">↘</div>
        </div>

        <div class="finales">
          <a href="/kursy/matura-podstawowa" class="finale-card finale-live">
            <div class="finale-icon">📕</div>
            <div class="finale-title">Matura podstawowa</div>
            <div class="finale-tag">✅ Dostępne</div>
          </a>
          <a href="/kursy/matura-rozszerzona" class="finale-card finale-soon">
            <div class="finale-icon">🔬</div>
            <div class="finale-title">Matura rozszerzona</div>
            <div class="finale-tag">⏳ Wkrótce</div>
          </a>
        </div>
      </section>

      <!-- ====================================================== -->
      <!-- WERSJA MOBILE — akordeon klas + rozwijane działy     -->
      <!-- ====================================================== -->
      <section class="mobile-only mobile-mapa">
        <div class="mobile-mapa-header">
          <div class="mobile-mapa-icon">📘</div>
          <div>
            <div class="path-label">⭐ ŚCIEŻKA LICEUM</div>
            <h2 class="mobile-mapa-title">Plan nauki</h2>
          </div>
        </div>

        {wszystkieKlasy.map((klasa) => (
          <div class={`klasa-akordeon ${klasa.status === 'live' ? 'klasa-live' : 'klasa-soon'} ${klasa.defaultOpen ? 'is-open' : ''}`} data-klasa-toggle>
            <button type="button" class="klasa-akordeon-btn" onclick="toggleKlasa(this)" aria-expanded={klasa.defaultOpen ? 'true' : 'false'}>
              <div class="klasa-akordeon-left">
                <span class="klasa-akordeon-num">{klasa.num}</span>
                <div>
                  <div class="klasa-akordeon-label">{klasa.label}</div>
                  <div class="klasa-akordeon-sub">{klasa.subtitle}</div>
                </div>
              </div>
              <span class="klasa-akordeon-chevron">▾</span>
            </button>

            <div class="klasa-akordeon-body">
              {klasa.dzialy.map((d) => (
                <div class="dzial-row" data-dzial-toggle>
                  <button type="button" class="dzial-row-btn" onclick="toggleDzial(this)" aria-expanded="false">
                    <div class="dzial-row-left">
                      <span class="dzial-row-num">{d.num}</span>
                      <span class="dzial-row-name">{d.short}</span>
                    </div>
                    <span class="dzial-row-chevron">▾</span>
                  </button>
                  <div class="dzial-row-body">
                    <div class="dzial-row-desc">{d.desc}</div>
                    <div class="dzial-row-podpunkty-label">📚 W tym dziale:</div>
                    <ul class="dzial-row-podpunkty">
                      {d.podpunkty.map((p) => <li>{p}</li>)}
                    </ul>
                    <a href={`/kursy/${d.slug}`} class="dzial-row-cta">
                      {d.status === 'live' ? 'Otwórz kurs →' : 'Zobacz szczegóły →'}
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        <div class="big-arrow">↓</div>

        <div class="mobile-finales">
          <div class="mobile-finales-label">Po klasie 4 — matura:</div>
          <a href="/kursy/matura-podstawowa" class="finale-card finale-live">
            <div class="finale-icon">📕</div>
            <div class="finale-title">Matura podstawowa</div>
            <div class="finale-tag">✅ Dostępne</div>
          </a>
          <a href="/kursy/matura-rozszerzona" class="finale-card finale-soon">
            <div class="finale-icon">🔬</div>
            <div class="finale-title">Matura rozszerzona</div>
            <div class="finale-tag">⏳ Wkrótce</div>
          </a>
        </div>
      </section>

      <!-- ====================================================== -->
      <!-- EGZAMIN 8-KLASISTY                                    -->
      <!-- ====================================================== -->
      <section class="path-section path-priority">
        <div class="path-header">
          <div class="path-icon">🎓</div>
          <div>
            <div class="path-label">⭐ PRIORYTET · EGZAMIN 8-KLASISTY</div>
            <h2 class="path-title">Egzamin 8-klasisty</h2>
            <p class="path-desc">9 działów CKE. Idealne przygotowanie przed liceum.</p>
          </div>
        </div>

        <div class="klasa-strip klasa-strip-soon">
          <div class="strip-label">KLASA 8 · 9 działów CKE · ⏳ Wkrótce</div>
          <div class="strip-tiles">
            {osmoklasista.map((d) => <div class="strip-tile">{d}</div>)}
          </div>
        </div>
      </section>

      <!-- FINAL CTA -->
      <section class="mapa-final">
        <div class="mapa-final-box">
          <h2>Potrzebujesz pomocy?</h2>
          <p>Wybierz najlepszą opcję dla siebie:</p>
          <div class="mapa-final-cta">
            <a href="/kursy" class="btn-primary">🎯 Sprawdź kursy →</a>
            <a href="/korepetycje" class="btn-secondary">👨‍🏫 Sprawdź korepetycje →</a>
          </div>
        </div>
      </section>

    </div>
  </main>
</Layout>

<script is:inline>
  function toggleKlasa(btn) {
    var akordeon = btn.closest('[data-klasa-toggle]');
    if (!akordeon) return;
    var open = akordeon.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  }
  function toggleDzial(btn) {
    var row = btn.closest('[data-dzial-toggle]');
    if (!row) return;
    var open = row.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  }
  // Klasy 2/3/4 desktop - rozwinięcie ukrytych podpunktów wewnątrz kafelka
  function togglePodpunkty(event, btn) {
    // Nie chcemy żeby kliknięcie "pokaż jeszcze" przeniosło na podstronę kursu
    event.preventDefault();
    event.stopPropagation();
    var tile = btn.closest('[data-step-toggle]');
    if (!tile) return;
    var open = tile.classList.toggle('is-expanded');
    if (open) {
      btn.textContent = '− zwiń';
    } else {
      var hidden = tile.querySelectorAll('.step-content-extra').length;
      btn.textContent = '+ pokaż jeszcze ' + hidden;
    }
  }
</script>

<style>
  .mapa-page { color: #EBEEFF; padding: 40px 0 80px; }
  .text-yellow { color: #FFDE59; }

  /* Przełączanie desktop/mobile */
  .desktop-only { display: block; }
  .mobile-only { display: none; }
  @media (max-width: 768px) {
    .desktop-only { display: none !important; }
    .mobile-only { display: block; }
  }

  .mapa-hero { text-align: center; padding: 30px 0 50px; }
  .mapa-title {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1px;
    margin: 12px 0 16px;
  }
  .mapa-sub {
    font-size: 16px;
    color: rgba(235, 238, 255, 0.7);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto;
  }

  .path-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 18px;
    padding: 32px;
    margin-bottom: 28px;
  }
  .path-priority {
    background: rgba(255, 222, 89, 0.04);
    border-color: rgba(255, 222, 89, 0.25);
  }
  .path-header {
    display: flex;
    gap: 18px;
    align-items: center;
    margin-bottom: 28px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(235, 238, 255, 0.08);
  }
  .path-icon { font-size: 44px; line-height: 1; }
  .path-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #FFDE59;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .path-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.5px;
  }
  .path-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    margin: 0;
  }

  /* KROKI Z STRZAŁKAMI (DESKTOP) — kafelki z listą podpunktów NA STAŁE */
  .steps-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: stretch;
    justify-content: center;
    margin-bottom: 28px;
  }
  .step-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
    background: rgba(5, 10, 36, 0.55);
    border: 1px solid rgba(255, 222, 89, 0.25);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    width: 200px;
    min-height: 240px;
    cursor: pointer;
  }
  .step-tile:hover {
    border-color: #FFDE59;
    background: rgba(255, 222, 89, 0.08);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 222, 89, 0.18);
  }
  .step-tile-soon {
    border-color: rgba(235, 238, 255, 0.15);
    opacity: 0.85;
  }
  .step-tile-soon:hover {
    border-color: rgba(255, 222, 89, 0.5);
    background: rgba(255, 255, 255, 0.04);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3);
  }
  .step-tile-head {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .step-num {
    font-size: 11px;
    font-weight: 700;
    color: #3FCECF;
    background: rgba(63, 206, 207, 0.15);
    padding: 3px 8px;
    border-radius: 6px;
  }
  .step-name {
    font-size: 14px;
    font-weight: 700;
    color: #EBEEFF;
    line-height: 1.25;
    letter-spacing: -0.2px;
  }
  .step-content {
    flex: 1;
    padding-top: 6px;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
  }
  .step-content-title {
    font-size: 10px;
    color: #FFDE59;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }
  .step-content-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .step-content-list li {
    font-size: 11.5px;
    color: rgba(235, 238, 255, 0.78);
    padding: 3px 0 3px 12px;
    position: relative;
    line-height: 1.4;
  }
  .step-content-list li::before {
    content: '·';
    position: absolute;
    left: 2px;
    color: #3FCECF;
    font-weight: 700;
  }
  .step-content-cta {
    font-size: 11px;
    color: #FFDE59;
    font-weight: 700;
    text-align: center;
    padding-top: 8px;
    margin-top: 4px;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
  }

  /* Ukryte podpunkty (klasy 2/3/4) — pokazywane po kliknięciu „pokaż jeszcze” */
  .step-content-extra {
    display: none;
  }
  .step-tile.is-expanded .step-content-extra {
    display: list-item;
  }
  .step-content-more {
    list-style: none;
    padding: 6px 0 0 !important;
  }
  .step-content-more::before {
    content: none !important;
  }
  .step-more-btn {
    background: transparent;
    border: 1px dashed rgba(255, 222, 89, 0.35);
    color: #FFDE59;
    font-size: 10.5px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    cursor: pointer;
    width: 100%;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .step-more-btn:hover {
    background: rgba(255, 222, 89, 0.1);
    border-color: #FFDE59;
    border-style: solid;
  }

  .step-arrow {
    color: #FFDE59;
    font-size: 24px;
    font-weight: 700;
    padding: 0 4px;
    user-select: none;
    align-self: center;
  }

  /* POP-UP DESKTOP */
  .step-popup {
    position: absolute;
    top: 0;
    left: calc(100% + 10px);
    width: 240px;
    background: rgba(5, 10, 36, 0.98);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 222, 89, 0.4);
    border-radius: 12px;
    padding: 14px;
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    pointer-events: none;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
  }
  .step-tile:hover .step-popup {
    opacity: 1;
    visibility: visible;
    transform: translateX(4px);
  }
  .step-popup::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 16px;
    width: 12px;
    height: 12px;
    background: rgba(5, 10, 36, 0.98);
    border-left: 1px solid rgba(255, 222, 89, 0.4);
    border-bottom: 1px solid rgba(255, 222, 89, 0.4);
    transform: rotate(45deg);
  }
  .popup-title {
    font-size: 11px;
    color: #FFDE59;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }
  .popup-list { list-style: none; padding: 0; margin: 0 0 10px; }
  .popup-list li {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.75);
    padding: 4px 0 4px 14px;
    position: relative;
    line-height: 1.4;
  }
  .popup-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: #3FCECF;
    font-weight: 700;
  }
  .popup-cta {
    font-size: 11px;
    color: #FFDE59;
    font-weight: 700;
    text-align: center;
    padding-top: 8px;
    border-top: 1px solid rgba(235, 238, 255, 0.08);
  }
  .step-tile:nth-child(4n) .step-popup,
  .step-tile:nth-child(4n-1) .step-popup {
    left: auto;
    right: calc(100% + 10px);
  }
  .step-tile:nth-child(4n) .step-popup::before,
  .step-tile:nth-child(4n-1) .step-popup::before {
    left: auto;
    right: -6px;
    border-left: none;
    border-bottom: none;
    border-right: 1px solid rgba(255, 222, 89, 0.4);
    border-top: 1px solid rgba(255, 222, 89, 0.4);
  }

  .big-arrow {
    text-align: center;
    font-size: 36px;
    color: rgba(255, 222, 89, 0.5);
    line-height: 1;
    margin: 8px 0;
  }

  /* KLASA STRIP (desktop dla klasy 2/3/4/8) */
  .klasa-strip {
    background: rgba(5, 10, 36, 0.5);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 14px;
