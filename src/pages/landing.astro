---
// =====================================================
// SEKRETNY DASHBOARD - /landing
// =====================================================
// URL: mathouse-website-pages.pages.dev/landing
// Nie jest w nawigacji ani footerze.
// Pokazuje Ci wszystkie landing pages + przyciski ON/OFF.
//
// Jak wyłączyć landing? Otwórz src/config/landingPages.js
// i zmień `enabled: true` na `enabled: false` dla danej strony.
// =====================================================
import Layout from '../layouts/Layout.astro';
import { LANDING_PAGES } from '../config/landingPages.js';
---

<Layout
  title="Panel Olafa — Landing Pages (SEKRETNE)"
  description="Wewnętrzny panel zarządzania landing pages"
  noindex={true}
>
  <main class="lp-dashboard">
    <div class="container-content">
      <div class="lp-header">
        <div class="lp-badge">🔒 PANEL WEWNĘTRZNY</div>
        <h1 class="lp-title">Twoje Landing Pages</h1>
        <p class="lp-subtitle">
          Lista wszystkich stron sprzedażowych. Tylko Ty znasz ten URL.<br />
          Żeby <strong>włączyć/wyłączyć</strong> daną stronę — otwórz <code>src/config/landingPages.js</code> i zmień <code>enabled: true/false</code>.
        </p>
      </div>

      <!-- Statystyki -->
      <div class="lp-stats">
        <div class="lp-stat">
          <div class="lp-stat-num">{LANDING_PAGES.length}</div>
          <div class="lp-stat-label">Wszystkich</div>
        </div>
        <div class="lp-stat">
          <div class="lp-stat-num lp-stat-on">{LANDING_PAGES.filter(p => p.enabled).length}</div>
          <div class="lp-stat-label">Aktywne (LIVE)</div>
        </div>
        <div class="lp-stat">
          <div class="lp-stat-num lp-stat-off">{LANDING_PAGES.filter(p => !p.enabled).length}</div>
          <div class="lp-stat-label">Wyłączone</div>
        </div>
      </div>

      <!-- Lista landing pages -->
      <div class="lp-list">
        {LANDING_PAGES.map((page) => (
          <div class={`lp-card ${page.enabled ? 'lp-card-on' : 'lp-card-off'}`}>
            <div class="lp-card-status">
              {page.enabled ? (
                <span class="lp-status lp-status-on">● LIVE</span>
              ) : (
                <span class="lp-status lp-status-off">○ WYŁĄCZONA</span>
              )}
            </div>

            <div class="lp-card-icon">{page.icon}</div>

            <div class="lp-card-body">
              <h3 class="lp-card-title">{page.shortTitle}</h3>
              <p class="lp-card-desc">{page.description}</p>

              <div class="lp-card-meta">
                <div class="lp-card-meta-item">
                  <span class="lp-meta-label">CENA</span>
                  <span class="lp-meta-value">{page.price}</span>
                </div>
                <div class="lp-card-meta-item">
                  <span class="lp-meta-label">URL</span>
                  <span class="lp-meta-value lp-meta-url">/{page.slug}</span>
                </div>
              </div>
            </div>

            <div class="lp-card-actions">
              {page.enabled ? (
                <a href={`/${page.slug}`} target="_blank" rel="noopener noreferrer" class="btn-primary lp-btn">
                  Otwórz stronę →
                </a>
              ) : (
                <div class="lp-btn-disabled">
                  Włącz w config aby otworzyć
                </div>
              )}
              <div class="lp-toggle-hint">
                Plik: <code>src/config/landingPages.js</code><br />
                Zmień: <code>enabled: {page.enabled ? 'true → false' : 'false → true'}</code>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Info dla Ciebie -->
      <div class="lp-info-box">
        <h3>📝 Jak zarządzać landing pages?</h3>
        <ol>
          <li>Otwórz plik <code>src/config/landingPages.js</code> na GitHubie</li>
          <li>Znajdź odpowiednią stronę (po <code>slug</code> lub <code>id</code>)</li>
          <li>Zmień <code>enabled: true</code> na <code>enabled: false</code> żeby wyłączyć</li>
          <li>Commit changes — Cloudflare zbuduje stronę w 60 sek</li>
          <li>Po wyłączeniu strona pokazuje <strong>404</strong> dla odwiedzających</li>
        </ol>

        <h3 style="margin-top: 32px;">🔗 Link sprzedażowy</h3>
        <p>Każdy landing page ma pole <code>purchaseUrl</code> w configu. Na razie ustawione na <code>#</code> — podmień na właściwy link do zakupu (np. ze sklepu).</p>

        <h3 style="margin-top: 32px;">🔒 Bezpieczeństwo</h3>
        <p>
          Ta strona <strong>/landing</strong> nie jest w nawigacji ani footerze, więc nikt jej nie znajdzie z poziomu strony głównej.<br />
          <strong>UWAGA:</strong> Google MOŻE ją zaindeksować (np. przez linki zewnętrzne) — jeśli zauważysz to w SERPie, daj znać, dodam <code>noindex</code>.
        </p>
      </div>

    </div>
  </main>
</Layout>

<style>
  .lp-dashboard {
    padding: 60px 0 80px;
    min-height: 100vh;
  }
  .lp-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .lp-badge {
    display: inline-block;
    background: rgba(255, 222, 89, 0.1);
    border: 1px solid rgba(255, 222, 89, 0.3);
    color: #FFDE59;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 18px;
  }
  .lp-title {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -1px;
    margin-bottom: 12px;
  }
  .lp-subtitle {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto;
  }
  .lp-subtitle code {
    background: rgba(255, 222, 89, 0.1);
    color: #FFDE59;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
  }

  /* Statystyki */
  .lp-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .lp-stat {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .lp-stat-num {
    font-size: 36px;
    font-weight: 700;
    color: #EBEEFF;
    line-height: 1;
    margin-bottom: 6px;
  }
  .lp-stat-on { color: #3FCECF; }
  .lp-stat-off { color: rgba(235, 238, 255, 0.4); }
  .lp-stat-label {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Lista landing pages */
  .lp-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
  }
  .lp-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 14px;
    padding: 22px;
    display: grid;
    grid-template-columns: auto 60px 1fr auto;
    gap: 20px;
    align-items: center;
    transition: all 0.2s ease;
  }
  .lp-card-on {
    border-color: rgba(63, 206, 207, 0.3);
    background: rgba(63, 206, 207, 0.04);
  }
  .lp-card-off {
    opacity: 0.55;
  }
  .lp-card-status {
    align-self: flex-start;
  }
  .lp-status {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
  }
  .lp-status-on {
    background: rgba(63, 206, 207, 0.15);
    color: #3FCECF;
  }
  .lp-status-off {
    background: rgba(235, 238, 255, 0.05);
    color: rgba(235, 238, 255, 0.5);
  }
  .lp-card-icon {
    font-size: 36px;
    text-align: center;
  }
  .lp-card-body {}
  .lp-card-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 6px;
    color: #EBEEFF;
  }
  .lp-card-desc {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.55;
    margin: 0 0 12px;
  }
  .lp-card-meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .lp-card-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .lp-meta-label {
    font-size: 9px;
    color: rgba(235, 238, 255, 0.4);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .lp-meta-value {
    font-size: 13px;
    font-weight: 600;
    color: #FFDE59;
  }
  .lp-meta-url {
    font-family: 'Courier New', monospace;
    color: #3FCECF;
  }
  .lp-card-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
    min-width: 200px;
  }
  .lp-btn {
    white-space: nowrap;
  }
  .lp-btn-disabled {
    background: rgba(235, 238, 255, 0.05);
    color: rgba(235, 238, 255, 0.4);
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 11px;
    text-align: center;
    border: 1px dashed rgba(235, 238, 255, 0.1);
  }
  .lp-toggle-hint {
    font-size: 10px;
    color: rgba(235, 238, 255, 0.4);
    text-align: right;
    line-height: 1.5;
  }
  .lp-toggle-hint code {
    background: rgba(255, 222, 89, 0.08);
    color: #FFDE59;
    padding: 1px 5px;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
    font-size: 10px;
  }

  /* Info box */
  .lp-info-box {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(235, 238, 255, 0.08);
    border-radius: 14px;
    padding: 28px;
  }
  .lp-info-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: #EBEEFF;
  }
  .lp-info-box p {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.7;
    margin: 0;
  }
  .lp-info-box ol {
    font-size: 13px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.8;
    padding-left: 20px;
  }
  .lp-info-box code {
    background: rgba(255, 222, 89, 0.1);
    color: #FFDE59;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .lp-title { font-size: 28px; }
    .lp-stats { grid-template-columns: 1fr; }
    .lp-card {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .lp-card-actions {
      align-items: stretch;
      min-width: 0;
    }
    .lp-toggle-hint {
      text-align: left;
    }
  }
</style>
