---
// =====================================================
// STRONA "O MNIE"
// =====================================================
import Layout from '../layouts/Layout.astro';

// Timeline — kamienie milowe
const timeline = [
  {
    year: '2012',
    title: 'Pierwsze korepetycje',
    desc: 'Tłumaczę matmę znajomym — przypadkiem odkrywam swoje powołanie.',
    side: 'left',
    color: 'yellow',
  },
  {
    year: '2013–2018',
    title: 'Studia na Politechnice Rzeszowskiej',
    desc: 'Matematyka — zastosowania matematyki w ekonomii. Od teraz uczę też studentów.',
    side: 'right',
    color: 'teal',
  },
  {
    year: '2019',
    title: 'Pomysł na MATHOUSE',
    desc: 'Zaczynam planować — będzie platforma, gdzie każdy zrozumie matmę. Pracuję nad konceptem.',
    side: 'left',
    color: 'yellow',
  },
  {
    year: '2021',
    title: 'Startuje mathouse.pl',
    desc: 'Pierwsza wersja strony — wizytówka i pierwsze materiały edukacyjne.',
    side: 'right',
    color: 'teal',
  },
  {
    year: '2023',
    title: 'Pierwsze kursy online',
    desc: 'Uruchomienie kurs.mathouse.pl — platformy sprzedażowej. Zaczyna się era kursów wideo i obecności na TikToku.',
    side: 'left',
    color: 'yellow',
  },
  {
    year: '2026',
    title: 'Następny etap — kursy do wszystkich klas',
    desc: 'Pełna oferta: każda klasa liceum, każdy dział, matura podstawowa i rozszerzona, ósmoklasista, kompendia i mapy myśli.',
    side: 'right',
    color: 'teal',
  },
  {
    year: 'w przyszłości',
    title: 'Matematyka w biznesie i inwestycjach',
    desc: 'Dzisiaj matma szkolna. Długoterminowo — praktyczne użycie matematyki w życiu codziennym, biznesie i finansach. Buduję coś więcej niż "kolejna platforma edukacyjna".',
    side: 'left',
    color: 'yellow-future',
  },
];

const socialMedia = [
  { name: 'TikTok', handle: '@mathouse_pl', url: 'https://www.tiktok.com/@mathouse_pl', icon: 'brand-tiktok', bg: '#000', iconColor: '#FFDE59' },
  { name: 'Instagram', handle: '@mathouse_pl', url: 'https://www.instagram.com/mathouse_pl/', icon: 'brand-instagram', bg: 'linear-gradient(135deg,#833AB4,#FD1D1D,#FCB045)', iconColor: '#fff' },
  { name: 'YouTube', handle: '@olafpieprzak9987', url: 'https://www.youtube.com/@olafpieprzak9987', icon: 'brand-youtube', bg: '#FF0000', iconColor: '#fff' },
  { name: 'Facebook', handle: 'MATHOUSE', url: 'https://www.facebook.com/Mathousepl', icon: 'brand-facebook', bg: '#1877F2', iconColor: '#fff' },
];
---

<Layout
  title="O mnie — Olaf Pieprzak"
  description="Olaf Pieprzak — założyciel MATHOUSE. Uczę matematyki od 2012 roku, pomogłem 1000+ uczniom. Magister matematyki, Politechnika Rzeszowska. Tłumaczę prosto, czasem nawet prymitywnie."
>
  <!-- ===================================================== -->
  <!-- BREADCRUMB                                             -->
  <!-- ===================================================== -->
  <div class="breadcrumb">
    <div class="container-content">
      <a href="/">←&nbsp;Strona główna</a> / <span>O mnie</span>
    </div>
  </div>

  <!-- ===================================================== -->
  <!-- HERO                                                   -->
  <!-- ===================================================== -->
  <section class="hero-omnie">
    <div class="container-content hero-omnie-grid">
      <div>
        <div class="section-label">UCZĘ MATMY OD 2012 ROKU</div>
        <h1 class="hero-omnie-title">
          Cześć, jestem<br />
          <span class="text-yellow">Olaf Pieprzak</span>.
        </h1>
        <p class="hero-omnie-desc">
          Założyciel MATHOUSE. Pokażę Ci matematykę
          <strong>w bardzo prosty, czasem nawet prymitywny sposób</strong>
          — tak, żebyś naprawdę zrozumiał, a nie tylko wkuwał wzory.
        </p>

        <div class="hero-omnie-stats">
          <div class="omnie-stat">
            <div class="omnie-stat-num">2013</div>
            <div class="omnie-stat-label">pierwsze korepetycje</div>
          </div>
          <div class="omnie-stat-sep"></div>
          <div class="omnie-stat">
            <div class="omnie-stat-num" id="licznik-uczniow">1000+</div>
            <div class="omnie-stat-label">uczniów</div>
          </div>
          <div class="omnie-stat-sep"></div>
          <div class="omnie-stat">
            <div class="omnie-stat-num teal">13 lat</div>
            <div class="omnie-stat-label">doświadczenia</div>
          </div>
        </div>

        <div class="omnie-cta">
          <a href="/kursy" class="btn-primary">Sprawdź kursy →</a>
          <a href="/korepetycje" class="btn-secondary">Umów korepetycje</a>
        </div>
      </div>

      <!-- Zdjęcie placeholder -->
      <div class="hero-omnie-photo">
        <div class="photo-deco-circle"></div>
        <div class="photo-deco-square"></div>
        <div class="photo-frame">
          <div class="photo-placeholder">
            <div class="photo-icon">👤</div>
            <div class="photo-text">TWOJE ZDJĘCIE</div>
            <div class="photo-subtext">portret zawodowy</div>
          </div>
          <div class="photo-badge">
            <div class="photo-name">Olaf Pieprzak</div>
            <div class="photo-role">założyciel MATHOUSE</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- HISTORIA                                               -->
  <!-- ===================================================== -->
  <section class="section-historia">
    <div class="container-content historia-grid">
      <div>
        <div class="section-label">§ MOJA HISTORIA</div>
        <h2 class="historia-title">
          Od „<span class="text-yellow">Olaf, mógłbyś?</span>"<br />
          do <span class="text-yellow">tysięcy</span> uczniów.
        </h2>
      </div>
      <div class="historia-text">
        <p>
          Moja przygoda z matematyką zaczęła się prozaicznie — od pytań znajomych:
          <em class="text-yellow">"Olaf, mógłbyś wytłumaczyć mi matmę?"</em>.
          Tłumaczyłem im na korytarzu, w stołówce, przez Messenger.
          Okazało się, że <strong>naprawdę mi to wychodzi</strong>.
        </p>
        <p>
          W 2012 zacząłem udzielać korepetycji. Rok później rozpocząłem studia na
          <strong>Politechnice Rzeszowskiej</strong> na kierunku „Matematyka — zastosowania
          matematyki w ekonomii". Skończyłem z magisterką, ale nie używam tego stopnia w marketingu —
          <em>interesuje mnie to, co ludzie mają w głowie, nie papier który zdobyli</em>.
        </p>
        <p>
          Pomysł na MATHOUSE chodził za mną od <strong class="text-yellow">2019 roku</strong>.
          Brakowało mi platformy, gdzie matma byłaby wyjaśniona
          <strong class="text-yellow">prosto, czasem nawet prymitywnie</strong>
          — tak, żeby każdy mógł zrozumieć.
        </p>
        <p>
          MATHOUSE to nie tylko matma. <strong>Coś więcej niż matma</strong>
          — bo długoterminowo idę w stronę matematyki w biznesie i inwestycjach.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- TIMELINE                                               -->
  <!-- ===================================================== -->
  <section class="section-timeline">
    <div class="container-content">
      <div class="section-label timeline-label">MOJA DROGA — KAMIENIE MILOWE</div>
      <div class="timeline">
        <div class="timeline-line"></div>
        {timeline.map((item) => (
          <div class={`timeline-row timeline-row-${item.side}`}>
            {item.side === 'left' ? (
              <>
                <div class="timeline-content timeline-content-left">
                  <div class={`timeline-year timeline-year-${item.color}`}>{item.year}</div>
                  <div class="timeline-h">{item.title}</div>
                  <div class="timeline-d">{item.desc}</div>
                </div>
                <div class={`timeline-dot timeline-dot-${item.color}`}></div>
                <div></div>
              </>
            ) : (
              <>
                <div></div>
                <div class={`timeline-dot timeline-dot-${item.color}`}></div>
                <div class="timeline-content timeline-content-right">
                  <div class={`timeline-year timeline-year-${item.color}`}>{item.year}</div>
                  <div class="timeline-h">{item.title}</div>
                  <div class="timeline-d">{item.desc}</div>
                </div>
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- FILOZOFIA — CO MNIE WYRÓŻNIA                          -->
  <!-- ===================================================== -->
  <section class="section-filozofia">
    <div class="container-content">
      <div class="filozofia-header">
        <div class="section-label yellow">CO MNIE WYRÓŻNIA</div>
        <h2 class="filozofia-title">
          Nie wkuwasz wzorów.<br />
          Rozumiesz <span class="text-yellow">mechanizm</span>.
        </h2>
        <p class="filozofia-desc">
          Większość uczniów nie kończy matury z dwóją bo "nie ogarniają".
          Kończą bo <strong>nikt im porządnie nie wytłumaczył</strong>.
          Moje lekcje wyglądają inaczej.
        </p>
      </div>

      <div class="filozofia-grid">
        <div class="card">
          <div class="fil-icon-wrap fil-icon-yellow">
            <i class="ti ti-bulb"></i>
          </div>
          <div class="fil-title">Tłumaczę „prymitywnie"</div>
          <p class="fil-desc">
            Nie boję się powtórzyć tematu 5 razy. Lepiej żebyś rozumiał niż żebym wyglądał na mądrego.
          </p>
        </div>
        <div class="card">
          <div class="fil-icon-wrap fil-icon-teal">
            <i class="ti ti-puzzle"></i>
          </div>
          <div class="fil-title">Wracamy do podstaw</div>
          <p class="fil-desc">
            Nie rozumiesz logarytmów? Bo brakuje Ci potęg. Wracamy i naprawiamy fundament.
          </p>
        </div>
        <div class="card">
          <div class="fil-icon-wrap fil-icon-yellow">
            <i class="ti ti-target-arrow"></i>
          </div>
          <div class="fil-title">Cel: zdana matura</div>
          <p class="fil-desc">
            Plan nauki dopasowany do Twojego progu i terminu egzaminu. Nie do mojego ego.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- MEDIA SPOŁECZNOŚCIOWE                                  -->
  <!-- ===================================================== -->
  <section class="section-media">
    <div class="container-content">
      <div class="section-header">
        <div>
          <div class="section-label">ZNAJDŹ MNIE W SIECI</div>
          <h2 class="section-title">
            Codziennie dzielę się<br />
            <span class="text-yellow">matmą za darmo</span>.
          </h2>
        </div>
        <div class="media-meta">Krótkie rozwiązania, tipy maturalne, ciekawostki.</div>
      </div>

      <div class="media-grid">
        {socialMedia.map((m) => (
          <a href={m.url} target="_blank" rel="noopener noreferrer" class="card media-card">
            <div class="media-icon-wrap" style={`background:${m.bg}`}>
              <i class={`ti ti-${m.icon}`} style={`color:${m.iconColor}`}></i>
            </div>
            <div class="media-name">{m.name}</div>
            <div class="media-handle">{m.handle}</div>
            <div class="media-link">odwiedź profil →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- TESTIMONIAL                                            -->
  <!-- ===================================================== -->
  <section class="section-testimonial">
    <div class="container-content">
      <div class="testimonial">
        <div class="testimonial-quote">"</div>
        <p class="testimonial-text">
          Olaf nie tłumaczy jak nauczyciel — tłumaczy jak starszy brat, który po prostu chce żebyś zrozumiał. Po pół roku z 2 zrobiłam 4.
        </p>
        <div class="testimonial-author">— Karolina, klasa 3 LO · matura 2025</div>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- WIZJA                                                  -->
  <!-- ===================================================== -->
  <section class="section-wizja">
    <div class="container-content wizja-grid">
      <div>
        <div class="section-label">DOKĄD ZMIERZAM</div>
        <h2 class="wizja-title">
          Matma <span class="text-yellow">w życiu, biznesie<br />i inwestycjach</span>.
        </h2>
      </div>
      <div class="wizja-text">
        <p>
          MATHOUSE to dziś matma szkolna. Ale długoterminowo idę dalej —
          buduję coś, gdzie matematyka będzie pokazana w realnym życiu, na konkretnych liczbach i sytuacjach.
        </p>
        <p>
          <strong class="text-yellow">Coś więcej niż matma</strong> — to nie hasło, to plan.
          Krok po kroku, bez spinania, bez wielkich obietnic. Po prostu robię swoje.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================================================== -->
  <!-- CTA                                                    -->
  <!-- ===================================================== -->
  <section class="section-cta-omnie">
    <div class="container-content cta-omnie-inner">
      <div>
        <h3 class="cta-title">Gotowy, żebym Cię nauczył?</h3>
        <p class="cta-desc">Zacznij od darmowej lekcji albo umów korepetycje.</p>
      </div>
      <div class="cta-buttons">
        <a href="/kursy" class="cta-button">▶ Darmowa lekcja</a>
        <a href="/korepetycje" class="cta-button-secondary">Umów korepetycje</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================== */
  /* BREADCRUMB                                             */
  /* ===================================================== */
  .breadcrumb {
    padding: 14px 0;
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
    border-bottom: 1px solid rgba(235, 238, 255, 0.06);
  }
  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }
  .breadcrumb span {
    color: #FFDE59;
  }

  /* ===================================================== */
  /* HERO                                                   */
  /* ===================================================== */
  .hero-omnie {
    padding: 64px 0 40px;
  }
  .hero-omnie-grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 48px;
    align-items: center;
  }
  .hero-omnie-title {
    font-size: 56px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -2px;
    margin: 14px 0 18px;
  }
  .text-yellow {
    color: #FFDE59;
  }
  .text-teal {
    color: #3FCECF;
  }
  .hero-omnie-desc {
    font-size: 15px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 24px;
  }
  .hero-omnie-desc strong {
    color: #EBEEFF;
  }

  .hero-omnie-stats {
    display: flex;
    gap: 22px;
    margin-bottom: 24px;
  }
  .omnie-stat-num {
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    color: #FFDE59;
  }
  .omnie-stat-num.teal {
    color: #3FCECF;
  }
  .omnie-stat-label {
    font-size: 11px;
    color: rgba(235, 238, 255, 0.5);
  }
  .omnie-stat-sep {
    width: 1px;
    background: rgba(235, 238, 255, 0.1);
  }
  .omnie-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* === Zdjęcie === */
  .hero-omnie-photo {
    position: relative;
  }
  .photo-deco-circle {
    position: absolute;
    top: -12px;
    left: -12px;
    background: #3FCECF;
    width: 90px;
    height: 90px;
    border-radius: 50%;
  }
  .photo-deco-square {
    position: absolute;
    bottom: -14px;
    right: -14px;
    background: #FFDE59;
    width: 68px;
    height: 68px;
    border-radius: 14px;
    transform: rotate(15deg);
  }
  .photo-frame {
    position: relative;
    z-index: 2;
    background: linear-gradient(135deg, #1a2347 0%, #050A24 100%);
    border-radius: 18px;
    aspect-ratio: 4/5;
    border: 1px solid rgba(235, 238, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .photo-placeholder {
    text-align: center;
    color: rgba(235, 238, 255, 0.5);
  }
  .photo-icon {
    font-size: 64px;
  }
  .photo-text {
    font-size: 11px;
    margin-top: 8px;
    letter-spacing: 1px;
  }
  .photo-subtext {
    font-size: 9px;
    margin-top: 4px;
  }
  .photo-badge {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(5, 10, 36, 0.85);
    padding: 9px 13px;
    border-radius: 9px;
    border: 1px solid rgba(235, 238, 255, 0.1);
    backdrop-filter: blur(8px);
  }
  .photo-name {
    font-size: 12px;
    font-weight: 600;
  }
  .photo-role {
    font-size: 10px;
    color: rgba(235, 238, 255, 0.5);
  }

  /* ===================================================== */
  /* HISTORIA                                               */
  /* ===================================================== */
  .section-historia {
    padding: 48px 0;
    background: rgba(63, 206, 207, 0.05);
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    border-bottom: 1px solid rgba(235, 238, 255, 0.1);
  }
  .historia-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
  }
  .historia-title {
    font-size: 32px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.5px;
  }
  .historia-text {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.7);
    line-height: 1.75;
    max-width: 600px;
  }
  .historia-text p {
    margin-bottom: 16px;
  }
  .historia-text p:last-child {
    margin-bottom: 0;
  }
  .historia-text strong {
    color: #EBEEFF;
  }
  .historia-text em {
    color: rgba(235, 238, 255, 0.65);
  }

  /* ===================================================== */
  /* TIMELINE                                               */
  /* ===================================================== */
  .section-timeline {
    padding: 48px 0;
  }
  .timeline-label {
    text-align: center;
  }
  .timeline {
    position: relative;
    margin-top: 28px;
  }
  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(235, 238, 255, 0.1);
  }
  .timeline-row {
    display: grid;
    grid-template-columns: 1fr 30px 1fr;
    gap: 24px;
    align-items: center;
    margin-bottom: 24px;
    position: relative;
  }
  .timeline-content-left {
    text-align: right;
  }
  .timeline-content-left .timeline-d {
    margin-left: auto;
  }
  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 3px solid #050A24;
    margin: 0 auto;
  }
  .timeline-dot-yellow {
    background: #FFDE59;
    box-shadow: 0 0 0 1px #FFDE59;
  }
  .timeline-dot-teal {
    background: #3FCECF;
    box-shadow: 0 0 0 1px #3FCECF;
  }
  .timeline-dot-yellow-future {
    background: rgba(255, 222, 89, 0.4);
    box-shadow: 0 0 0 1px rgba(255, 222, 89, 0.5);
  }
  .timeline-year {
    font-size: 11px;
    letter-spacing: 1.5px;
    font-weight: 600;
    text-transform: uppercase;
  }
  .timeline-year-yellow,
  .timeline-year-yellow-future {
    color: #FFDE59;
  }
  .timeline-year-teal {
    color: #3FCECF;
  }
  .timeline-h {
    font-size: 16px;
    font-weight: 600;
    margin-top: 5px;
  }
  .timeline-d {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
    margin-top: 4px;
    line-height: 1.55;
    max-width: 340px;
  }

  /* ===================================================== */
  /* FILOZOFIA                                              */
  /* ===================================================== */
  .section-filozofia {
    padding: 48px 0;
    background: rgba(255, 222, 89, 0.06);
    border-top: 1px solid rgba(235, 238, 255, 0.1);
    border-bottom: 1px solid rgba(235, 238, 255, 0.1);
  }
  .filozofia-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 32px;
  }
  .filozofia-title {
    font-size: 34px;
    font-weight: 600;
    letter-spacing: -0.5px;
    line-height: 1.15;
    margin: 6px 0 14px;
  }
  .filozofia-desc {
    font-size: 14px;
    color: rgba(235, 238, 255, 0.65);
    line-height: 1.7;
  }
  .filozofia-desc strong {
    color: #EBEEFF;
  }
  .filozofia-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .fil-icon-wrap {
    width: 46px;
    height: 46px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .fil-icon-yellow {
    background: rgba(255, 222, 89, 0.15);
  }
  .fil-icon-yellow i {
    color: #FFDE59;
    font-size: 22px;
  }
  .fil-icon-teal {
    background: rgba(63, 206, 207, 0.15);
  }
  .fil-icon-teal i {
    color: #3FCECF;
    font-size: 22px;
  }
  .fil-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .fil-desc {
    font-size: 12px;
    color: rgba(235, 238, 255, 0.65);
